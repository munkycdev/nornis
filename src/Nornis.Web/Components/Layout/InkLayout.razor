   the canvas owns the whole viewport (OneNote-style). *@

<MudThemeProvider Theme="NornisTheme.Theme" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="nornis-ink-shell">
    @Body
</div>
