@inherits LayoutComponentBase

<MudThemeProvider Theme="NornisTheme.Theme" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudDrawer @bind-Open="_navOpen"
               Fixed="true"
               Elevation="0"
               Variant="DrawerVariant.Persistent"
               Class="nornis-sidebar">
        <NavMenu OnCollapse="ToggleNav" />
    </MudDrawer>

    <MudMainContent Class="nornis-main">
        <header class="nornis-topbar">
            @if (!_navOpen)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" OnClick="ToggleNav" aria-label="Show navigation" />
            }
            <div class="nornis-search">
                <MudTextField T="string"
                              Placeholder="Search Nornis…"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              AdornmentColor="Color.Tertiary"
                              Immediate="false" />
            </div>
            <MudBadge Dot="true" Color="Color.Secondary" Overlap="true" Bordered="true">
                <MudIconButton Icon="@Icons.Material.Filled.NotificationsNone" Color="Color.Inherit" aria-label="Notifications" />
            </MudBadge>
            <div class="nornis-account">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled">N</MudAvatar>
                <div>
                    <div class="nornis-account-name">Game Master</div>
                    <div class="nornis-account-role">Loremaster</div>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Tertiary" Size="Size.Small" />
            </div>
        </header>

        <div class="nornis-page">
            @Body
        </div>
    </MudMainContent>
</MudLayout>

@code {
    private bool _navOpen = true;

    private void ToggleNav() => _navOpen = !_navOpen;
}
