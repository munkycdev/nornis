@inherits LayoutComponentBase
@implements IDisposable
@inject WorldState Worlds

<MudThemeProvider Theme="NornisTheme.Theme" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @* Persistent from md up; below that it closes itself and reopens as an overlay from the topbar. *@
    <MudDrawer @bind-Open="_navOpen"
               Fixed="true"
               Elevation="0"
               Variant="DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Md"
               Class="nornis-sidebar">
        <NavMenu OnCollapse="ToggleNav" />
    </MudDrawer>

    <MudMainContent Class="nornis-main">
        @* Rendered only when it has something in it — search needs a world, and the menu
           button only appears once the drawer has closed itself. *@
        @if (!_navOpen || Worlds.Current is not null)
        {
            <header class="nornis-topbar">
                @if (!_navOpen)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" OnClick="ToggleNav" aria-label="Show navigation" />
                }
                <GlobalSearch />
            </header>
        }

        <div class="nornis-page">
            @Body
        </div>

        <footer class="nornis-footer">
            <a href="/about">About</a>
            <a href="/changelog">Changelog</a>
            <a href="/privacy">Privacy</a>
            <a href="/terms">Terms</a>
            <a href="/licenses">Licenses</a>
        </footer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _navOpen = true;

    private void ToggleNav() => _navOpen = !_navOpen;

    protected override void OnInitialized() => Worlds.Changed += OnWorldChanged;

    // The top bar comes and goes with the world selection, so it has to re-render on change.
    private void OnWorldChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Worlds.Changed -= OnWorldChanged;
}
