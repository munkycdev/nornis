<a href="/" class="nornis-brand nornis-brand-link" aria-label="Nornis home">
    <img src="images/logo.png" alt="Nornis" class="nornis-brand-logo" />
    <div class="nornis-brand-name">NORNIS</div>
    <div class="nornis-brand-tagline">Your world, remembered.</div>
</a>

<MudMenu AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" Class="nornis-world-menu">
    <ActivatorContent>
        <div class="nornis-world">
            <MudIcon Icon="@Icons.Material.Outlined.Terrain" Color="Color.Secondary" />
            <div class="flex-grow-1">
                <div class="nornis-world-name">@(Worlds.Current?.Name ?? "No world")</div>
                <div class="nornis-world-label">@(Worlds.Current is null ? "Select or create" : "World")</div>
            </div>
            <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" />
        </div>
    </ActivatorContent>
    <ChildContent>
        @foreach (var world in Worlds.Worlds)
        {
            <MudMenuItem OnClick="@(() => SelectWorldAsync(world.Id))">@world.Name</MudMenuItem>
        }
        @if (Worlds.Worlds.Count > 0)
        {
            <MudDivider />
        }
        <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="CreateWorld">New world</MudMenuItem>
    </ChildContent>
</MudMenu>

<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.ChatBubbleOutline">Ask</MudNavLink>
    <MudNavLink Href="/capture" Icon="@Icons.Material.Outlined.Create">Capture</MudNavLink>
    <MudNavLink Href="/artifacts" Icon="@Icons.Material.Outlined.Category">Codex</MudNavLink>
    <MudNavLink Href="/timeline" Icon="@Icons.Material.Outlined.Timeline">Timeline</MudNavLink>
    <MudNavLink Href="/locations" Icon="@Icons.Material.Outlined.Place">Locations</MudNavLink>
    <MudNavLink Href="/review" Icon="@Icons.Material.Outlined.FactCheck">
        Review
        @if (_activity is { PendingProposals: > 0 })
        {
            <span class="nornis-nav-count">@(_activity.PendingProposalsCapped ? "200+" : _activity.PendingProposals.ToString())</span>
        }
    </MudNavLink>
    <MudNavLink Href="/sources" Icon="@Icons.Material.Outlined.Layers">
        Sources
        @if (_activity is { Failed: > 0 })
        {
            <span class="nornis-nav-count nornis-nav-count-failed" title="@($"{_activity.Failed} failed")">@_activity.Failed</span>
        }
        else if (_activity is { InFlight: > 0 })
        {
            <span class="nornis-nav-count" title="processing">@_activity.InFlight</span>
        }
    </MudNavLink>
    <MudNavLink Href="/library" Icon="@Icons.Material.Outlined.MenuBook">Library</MudNavLink>
    @if (Worlds.Current?.MyRole == "GM")
    {
        <MudNavLink Href="/admin" Icon="@Icons.Material.Outlined.AdminPanelSettings">Admin</MudNavLink>
    }
</MudNavMenu>

@if (Worlds.Current?.MyRole == "GM")
{
<div class="nornis-memory">
    <div class="nornis-memory-title">World Memory</div>
    <div class="nornis-memory-row">
        <div class="nornis-ring">
            <MudProgressCircular Value="@(Worlds.Continuity?.EffectiveScore ?? 0)" Min="0" Max="100"
                                 Color="@HealthColor" Size="Size.Medium" StrokeWidth="4" Class="nornis-ring-onnavy" />
        </div>
        <div class="nornis-memory-figure">
            @if (Worlds.Continuity is { HasData: true } a)
            {
                <span class="nornis-memory-pct">@a.EffectiveScore%</span>
                <span class="nornis-memory-state">AI assessed</span>
            }
            else
            {
                <span class="nornis-memory-pct">—</span>
                <span class="nornis-memory-state">Not yet assessed</span>
            }
        </div>
    </div>
    <MudButton Variant="Variant.Text"
               Color="Color.Secondary"
               EndIcon="@Icons.Material.Filled.ArrowForward"
               Href="/world-memory"
               Class="nornis-collapse pa-0">
        View details
    </MudButton>
</div>
}

@if (Auth.Enabled)
{
    <AuthorizeView>
        <Authorized>
            <div class="nornis-member-row px-4 py-2">
                <a href="/profile" class="nornis-link d-flex align-center gap-2 flex-grow-1" title="Your settings">
                    <MudIcon Icon="@Icons.Material.Outlined.AccountCircle" Size="Size.Small" />
                    <span class="nornis-list-sub">@context.User.Identity?.Name</span>
                </a>
                <MudTooltip Text="Sign out">
                    <MudIconButton Icon="@Icons.Material.Filled.Logout" Size="Size.Small"
                                   Href="/account/logout" aria-label="Sign out" />
                </MudTooltip>
            </div>
        </Authorized>
    </AuthorizeView>
}
else
{
    @* Dev auth: no identity to show, but the profile page still needs its entry point. *@
    <div class="nornis-member-row px-4 py-2">
        <a href="/profile" class="nornis-link d-flex align-center gap-2 flex-grow-1" title="Your settings">
            <MudIcon Icon="@Icons.Material.Outlined.AccountCircle" Size="Size.Small" />
            <span class="nornis-list-sub">Your settings</span>
        </a>
    </div>
}

<MudButton Variant="Variant.Text"
           StartIcon="@Icons.Material.Filled.KeyboardDoubleArrowLeft"
           OnClick="OnCollapse"
           Class="nornis-collapse">
    Collapse
</MudButton>

@implements IDisposable
@inject WorldState Worlds
@inject NornisApiClient Api
@inject Nornis.Web.Authentication.AuthFeature Auth
@inject IDialogService DialogService
@inject IJSRuntime JS

@code {
    private const string SelectedWorldKey = "nornis:world";

    [Parameter]
    public EventCallback OnCollapse { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Worlds.Changed += OnWorldsChanged;
        await Worlds.EnsureLoadedAsync();
        await RefreshActivityAsync();
        _ = PollActivityAsync();
    }

    // Light poll so processing/review badges move without navigation.
    private SourceActivity? _activity;
    private readonly CancellationTokenSource _activityCts = new();

    private async Task PollActivityAsync()
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(15));
            while (await timer.WaitForNextTickAsync(_activityCts.Token))
            {
                await RefreshActivityAsync();
            }
        }
        catch (OperationCanceledException)
        {
            // Component disposed.
        }
    }

    private async Task RefreshActivityAsync()
    {
        if (Worlds.Current is null)
        {
            _activity = null;
            return;
        }

        var result = await Api.GetSourceActivityAsync(Worlds.Current.Id, _activityCts.Token);
        if (result.IsSuccess)
        {
            _activity = result.Value;
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        // Restore the world the user last had selected (localStorage needs JS, so after render).
        // Ensure the list is loaded first — OnAfterRender can fire before OnInitializedAsync's load.
        await Worlds.EnsureLoadedAsync();
        try
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", SelectedWorldKey);
            if (Guid.TryParse(saved, out var id) && id != Worlds.Current?.Id
                && Worlds.Worlds.Any(c => c.Id == id))
            {
                Worlds.Select(id);
            }
        }
        catch
        {
            // Best-effort restore; ignore storage failures.
        }
    }

    private async Task SelectWorldAsync(Guid worldId)
    {
        Worlds.Select(worldId);
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", SelectedWorldKey, worldId.ToString());
        }
        catch
        {
            // Best-effort persist.
        }
    }

    private void OnWorldsChanged() => InvokeAsync(async () =>
    {
        await RefreshActivityAsync();
        StateHasChanged();
    });

    private Color HealthColor => (Worlds.Continuity?.EffectiveScore ?? 0) switch
    {
        >= 70 => Color.Success,
        >= 50 => Color.Warning,
        _ => Color.Error,
    };

    private async Task CreateWorld()
    {
        var dialog = await DialogService.ShowAsync<CreateWorldDialog>("New world");
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is WorldSummary created)
        {
            await Worlds.ReloadAsync();
            await SelectWorldAsync(created.Id);
        }
    }

    public void Dispose()
    {
        _activityCts.Cancel();
        _activityCts.Dispose();
        Worlds.Changed -= OnWorldsChanged;
    }
}
