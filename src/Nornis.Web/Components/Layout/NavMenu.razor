<div class="nornis-brand">
    <MudIcon Icon="@Icons.Material.Filled.Park" Color="Color.Secondary" Size="Size.Small" />
    <div class="nornis-brand-mark">N</div>
    <div class="nornis-brand-name">NORNIS</div>
    <div class="nornis-brand-tagline">Shape fate. Build legacy.</div>
</div>

<MudMenu AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" Class="nornis-campaign-menu">
    <ActivatorContent>
        <div class="nornis-campaign">
            <MudIcon Icon="@Icons.Material.Outlined.Terrain" Color="Color.Secondary" />
            <div class="flex-grow-1">
                <div class="nornis-campaign-name">@(Campaigns.Current?.Name ?? "No campaign")</div>
                <div class="nornis-campaign-label">@(Campaigns.Current is null ? "Select or create" : "Campaign")</div>
            </div>
            <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" />
        </div>
    </ActivatorContent>
    <ChildContent>
        @foreach (var campaign in Campaigns.Campaigns)
        {
            <MudMenuItem OnClick="@(() => Campaigns.Select(campaign.Id))">@campaign.Name</MudMenuItem>
        }
        @if (Campaigns.Campaigns.Count > 0)
        {
            <MudDivider />
        }
        <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="CreateCampaign">New campaign</MudMenuItem>
    </ChildContent>
</MudMenu>

<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.ChatBubbleOutline">Ask</MudNavLink>
    <MudNavLink Href="/capture" Icon="@Icons.Material.Outlined.Create">Capture</MudNavLink>
    <MudNavLink Href="/artifacts" Icon="@Icons.Material.Outlined.Category">Artifacts</MudNavLink>
    <MudNavLink Href="/storylines" Icon="@Icons.Material.Outlined.Hub">Storylines</MudNavLink>
    <MudNavLink Href="/canon" Icon="@Icons.Material.Outlined.MenuBook">Canon</MudNavLink>
    <MudNavLink Href="/sources" Icon="@Icons.Material.Outlined.Layers">Sources</MudNavLink>
    <MudNavLink Href="/costs" Icon="@Icons.Material.Outlined.Paid">Costs</MudNavLink>
    <MudNavLink Href="/settings" Icon="@Icons.Material.Outlined.Settings">Settings</MudNavLink>
</MudNavMenu>

<div class="nornis-memory">
    <div class="nornis-memory-title">Campaign Memory</div>
    <div class="nornis-memory-row">
        <div class="nornis-ring">
            <MudProgressCircular Value="@(Campaigns.Health?.OverallScore ?? 0)" Min="0" Max="100"
                                 Color="@HealthColor" Size="Size.Medium" StrokeWidth="4" Class="nornis-ring-onnavy" />
        </div>
        <div class="nornis-memory-figure">
            @if (Campaigns.Health is { HasData: true } h)
            {
                <span class="nornis-memory-pct">@h.OverallScore%</span>
                <span class="nornis-memory-state">@h.Label</span>
            }
            else
            {
                <span class="nornis-memory-pct">—</span>
                <span class="nornis-memory-state">@(Campaigns.Health is null ? "Loading…" : "No data yet")</span>
            }
        </div>
    </div>
    <MudButton Variant="Variant.Text"
               Color="Color.Secondary"
               EndIcon="@Icons.Material.Filled.ArrowForward"
               Href="/"
               Class="nornis-collapse pa-0">
        View details
    </MudButton>
</div>

<MudButton Variant="Variant.Text"
           StartIcon="@Icons.Material.Filled.KeyboardDoubleArrowLeft"
           OnClick="OnCollapse"
           Class="nornis-collapse">
    Collapse
</MudButton>

@implements IDisposable
@inject CampaignState Campaigns
@inject IDialogService DialogService

@code {
    [Parameter]
    public EventCallback OnCollapse { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Campaigns.Changed += OnCampaignsChanged;
        await Campaigns.EnsureLoadedAsync();
    }

    private void OnCampaignsChanged() => InvokeAsync(StateHasChanged);

    private Color HealthColor => (Campaigns.Health?.OverallScore ?? 0) switch
    {
        >= 70 => Color.Success,
        >= 50 => Color.Warning,
        _ => Color.Error,
    };

    private async Task CreateCampaign()
    {
        var dialog = await DialogService.ShowAsync<CreateCampaignDialog>("New campaign");
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is CampaignSummary created)
        {
            await Campaigns.ReloadAsync();
            Campaigns.Select(created.Id);
        }
    }

    public void Dispose() => Campaigns.Changed -= OnCampaignsChanged;
}
