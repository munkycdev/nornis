@inherits LayoutComponentBase

<MudThemeProvider Theme="NornisTheme.Theme" IsDarkMode="false" />
<MudPopoverProvider />

<div class="nornis-public">
    <header class="nornis-public-nav">
        <a href="/welcome" class="nornis-public-brand">
            <img src="images/mini-logo.png" alt="" class="nornis-public-brand-mark" />
            <span class="nornis-public-brand-name">NORNIS</span>
        </a>
        <nav class="nornis-public-links" aria-label="Public pages">
            <a href="/about">About</a>
            <a href="/features">Features</a>
            <a href="/changelog">Change Log</a>
        </nav>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/" Class="nornis-public-signin">
            Sign in
        </MudButton>
    </header>

    <main class="nornis-public-main">
        @Body
    </main>

    <footer class="nornis-public-footer">
        <div class="nornis-public-footer-brand">
            <img src="images/mini-logo.png" alt="" class="nornis-public-brand-mark" />
            <div>
                <div class="nornis-public-footer-name">Nornis</div>
                <div class="nornis-public-footer-tag">It's your epic. Every source leaves a mark.</div>
            </div>
        </div>
        <nav class="nornis-public-footer-links" aria-label="Legal and info">
            <a href="/about">About</a>
            <a href="/features">Features</a>
            <a href="/changelog">Change Log</a>
            <a href="/privacy">Privacy Policy</a>
            <a href="/terms">Terms of Service</a>
            <a href="/licenses">Licenses</a>
        </nav>
        <div class="nornis-public-footer-copy">
            <span class="nornis-public-footer-made">Made with ❤️ by 👨 and 🤖 for people who love 🎲</span>
            <span class="nornis-public-footer-version">© @DateTime.UtcNow.Year Nornis · v@(Nornis.Web.AppVersion.Display)</span>
        </div>
    </footer>
</div>
