<MudPaper Elevation="0" Class="nornis-card nornis-card-pad nornis-comingsoon">
    <MudIcon Icon="@Icon" Size="Size.Large" Class="nornis-comingsoon-icon" />
    <MudText Typo="Typo.h4" Class="nornis-serif">@Title</MudText>
    @if (!string.IsNullOrWhiteSpace(Description))
    {
        <MudText Typo="Typo.body1" Class="nornis-comingsoon-text mt-2">@Description</MudText>
    }
    <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small" Class="mt-6">
        Coming soon
    </MudChip>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Icon { get; set; } = Icons.Material.Filled.Circle;

    [Parameter]
    public string? Description { get; set; }
}
