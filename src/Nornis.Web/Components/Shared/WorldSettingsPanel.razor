@implements IDisposable
@inject WorldState Worlds
@inject NornisApiClient Api
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

@* World configuration, campaigns, characters, and members. Formerly the /settings page;
   now a tab on the GM-only Admin page. *@

<div class="nornis-narrow">
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">World configuration and members.</MudText>

    @if (Worlds.Current is null)
    {
        <NoWorld />
    }
    else
    {
        <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
            <div class="nornis-detail-section-title">World</div>
            @if (_isGm)
            {
                <MudTextField @bind-Value="_name" Label="Name" Required="true" Immediate="true"
                              MaxLength="200" Variant="Variant.Outlined" Class="mb-3" />
                <MudTextField @bind-Value="_description" Label="Description" Lines="2"
                              Variant="Variant.Outlined" Class="mb-3" />
                <MudTextField @bind-Value="_gameSystem" Label="Game system" Placeholder="e.g. D&D 5e"
                              Variant="Variant.Outlined" Class="mb-3" />
                <MudNumericField T="decimal?" @bind-Value="_dailyAiBudget" Label="Daily AI budget (USD)"
                                 Placeholder="server default" Min="0.01m" Max="100m" Step="0.5m"
                                 HelperText="Cap on this world's AI spend per day (extraction, Loremaster, audits). Leave empty to use the server default."
                                 Variant="Variant.Outlined" Class="mb-3" />

                <div class="nornis-detail-section-title mt-2">Public access</div>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                    Share this world's party-visible knowledge — codex, timeline, and sessions —
                    with anyone via a read-only link. GM-only and private material never appears.
                </MudText>
                <MudTextField @bind-Value="_publicSlug" Label="Public URL slug" Immediate="true"
                              Placeholder="@SuggestedSlug" MaxLength="60"
                              HelperText="Lowercase letters, digits, and hyphens (3–60 characters)."
                              Variant="Variant.Outlined" Class="mb-2"
                              Adornment="Adornment.Start" AdornmentText="nornis.app/w/" />
                <div class="d-flex align-center gap-3 mb-3">
                    <MudSwitch T="bool" @bind-Value="_publicAccessEnabled" Color="Color.Secondary"
                               Label="Publicly accessible" Disabled="@(string.IsNullOrWhiteSpace(_publicSlug))" />
                    @if (_publicAccessEnabled && !string.IsNullOrWhiteSpace(_publicSlug))
                    {
                        <MudTooltip Text="Copy public link">
                            <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy" Size="Size.Small"
                                           OnClick="CopyPublicLinkAsync" aria-label="Copy public link" />
                        </MudTooltip>
                        <a href="@PublicUrl" target="_blank" rel="noopener" class="nornis-link">@PublicUrl</a>
                    }
                </div>

                @if (_worldError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_worldError</MudAlert>
                }
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="SaveWorldAsync" Disabled="_savingWorld">
                    Save changes
                </MudButton>
            }
            else
            {
                <div class="nornis-kv"><span class="nornis-kv-key">Name</span><span class="nornis-kv-value">@Worlds.Current.Name</span></div>
                <div class="nornis-kv"><span class="nornis-kv-key">Description</span><span class="nornis-kv-value">@(string.IsNullOrWhiteSpace(Worlds.Current.Description) ? "—" : Worlds.Current.Description)</span></div>
                <div class="nornis-kv"><span class="nornis-kv-key">Game system</span><span class="nornis-kv-value">@(string.IsNullOrWhiteSpace(Worlds.Current.GameSystem) ? "—" : Worlds.Current.GameSystem)</span></div>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">Only GMs can edit world settings.</MudText>
            }
        </MudPaper>

        <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
            <div class="nornis-detail-section-title">Campaigns</div>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                Runs of play within this world. Sources can declare which campaign their events happened in.
            </MudText>

            @if (_loadingCampaigns)
            {
                <LoadingRows Rows="2" Height="48px" />
            }
            else if (_campaignsError is not null)
            {
                <MudAlert Severity="Severity.Error">@_campaignsError</MudAlert>
            }
            else
            {
                @if (_campaigns.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">No campaigns yet.</MudText>
                }
                @foreach (var c in _campaigns)
                {
                    <div class="nornis-member-row">
                        <div class="nornis-list-body">
                            <div class="nornis-list-title">@c.Name</div>
                            <div class="nornis-list-sub">
                                @CampaignDates(c)
                                @if (CampaignCharacterNames(c) is { Length: > 0 } names)
                                {
                                    <span> · @names</span>
                                }
                            </div>
                        </div>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                 Color="@(c.Status == "Active" ? Color.Success : Color.Default)">@c.Status</MudChip>
                        @if (_isGm)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="() => BeginEditCampaign(c)" aria-label="Edit campaign" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="() => DeleteCampaignAsync(c)" aria-label="Delete campaign" />
                        }
                    </div>
                    @if (_isGm && _editingCampaignId == c.Id)
                    {
                        <div class="nornis-card-pad mb-2">
                            <MudTextField @bind-Value="_campaignName" Label="Name" Required="true" MaxLength="200"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
                            <MudTextField @bind-Value="_campaignDescription" Label="Description" Lines="2"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
                            <MudSelect T="string" @bind-Value="_campaignStatus" Label="Status" Dense="true"
                                       Variant="Variant.Outlined" Class="mb-2">
                                @foreach (var status in _campaignStatuses)
                                {
                                    <MudSelectItem Value="@status">@status</MudSelectItem>
                                }
                            </MudSelect>
                            <MudSelect T="Guid" MultiSelection="true" @bind-SelectedValues="_campaignCharacterIds"
                                       Label="Characters in this campaign" Dense="true" Variant="Variant.Outlined" Class="mb-2">
                                @foreach (var ch in _characters)
                                {
                                    <MudSelectItem T="Guid" Value="@ch.Id">@ch.Name</MudSelectItem>
                                }
                            </MudSelect>
                            @if (_campaignError is not null)
                            {
                                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">@_campaignError</MudAlert>
                            }
                            <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small"
                                       OnClick="SaveCampaignAsync" Disabled="_savingCampaign" Class="mr-2">Save</MudButton>
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="CancelEditCampaign">Cancel</MudButton>
                        </div>
                    }
                }

                @if (_isGm)
                {
                    <div class="nornis-add-member mt-3">
                        <MudTextField @bind-Value="_newCampaignName" Label="New campaign name" MaxLength="200"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="AddCampaignAsync" Disabled="_addingCampaign">
                            Add
                        </MudButton>
                    </div>
                    @if (_addCampaignError is not null)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_addCampaignError</MudAlert>
                    }
                }
            }
        </MudPaper>

        <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
            <div class="nornis-detail-section-title">Members</div>

            @if (_loadingMembers)
            {
                <LoadingRows Rows="3" Height="48px" />
            }
            else if (_membersError is not null)
            {
                <MudAlert Severity="Severity.Error">@_membersError</MudAlert>
            }
            else
            {
                @foreach (var m in _members)
                {
                    <div class="nornis-member-row">
                        <MudAvatar Color="Color.Primary" Size="Size.Small">@Initial(m)</MudAvatar>
                        <div class="nornis-list-body">
                            <div class="nornis-list-title">@DisplayName(m)</div>
                        </div>
                        @if (_isGm)
                        {
                            <MudSelect T="string" Value="m.Role" ValueChanged="(string r) => ChangeRoleAsync(m, r)"
                                       Dense="true" Variant="Variant.Outlined" Class="nornis-role-select" Disabled="@_busyMembers.Contains(m.UserId)">
                                @foreach (var role in _roles)
                                {
                                    <MudSelectItem Value="@role">@RoleLabel(role)</MudSelectItem>
                                }
                            </MudSelect>
                            <MudIconButton Icon="@Icons.Material.Filled.PersonRemove" Color="Color.Error" Size="Size.Small"
                                           OnClick="() => RemoveAsync(m)" Disabled="@_busyMembers.Contains(m.UserId)" aria-label="Remove member" />
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">@RoleLabel(m.Role)</MudChip>
                        }
                    </div>
                }

                @if (_isGm)
                {
                    <div class="nornis-add-member mt-3">
                        <MudTextField @bind-Value="_newUserId" Label="Add member by user ID" Placeholder="00000000-0000-0000-0000-000000000000"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
                        <MudSelect T="string" @bind-Value="_newRole" Dense="true" Variant="Variant.Outlined" Class="nornis-role-select">
                            @foreach (var role in _roles)
                            {
                                <MudSelectItem Value="@role">@RoleLabel(role)</MudSelectItem>
                            }
                        </MudSelect>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
                                   OnClick="AddMemberAsync" Disabled="_addingMember">
                            Add
                        </MudButton>
                    </div>
                    @if (_addError is not null)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_addError</MudAlert>
                    }
                }
            }
        </MudPaper>
    }
</div>

@code {
    private readonly string[] _roles = ["GM", "Player", "Observer"];

    private bool _isGm => Worlds.Current?.MyRole == "GM";

    // World settings form
    private string _name = string.Empty;
    private string? _description;
    private string? _gameSystem;
    private decimal? _dailyAiBudget;
    private string? _publicSlug;
    private bool _publicAccessEnabled;
    private bool _savingWorld;
    private string? _worldError;

    // Members
    private bool _loadingMembers;
    private string? _membersError;
    private IReadOnlyList<WorldMember> _members = [];
    private readonly HashSet<Guid> _busyMembers = [];

    // Add member
    private string _newUserId = string.Empty;
    private string _newRole = "Player";
    private bool _addingMember;
    private string? _addError;

    // Campaigns
    private readonly string[] _campaignStatuses = ["Active", "Completed", "Archived"];
    private bool _loadingCampaigns;
    private string? _campaignsError;
    private IReadOnlyList<CampaignDto> _campaigns = [];
    private string _newCampaignName = string.Empty;
    private bool _addingCampaign;
    private string? _addCampaignError;
    private Guid? _editingCampaignId;
    private string _campaignName = string.Empty;
    private string? _campaignDescription;
    private string _campaignStatus = "Active";
    private IEnumerable<Guid> _campaignCharacterIds = [];
    private bool _savingCampaign;
    private string? _campaignError;

    // Characters are managed on each member's /profile page; loaded here only so the
    // Campaigns section can name and assign them.
    private IReadOnlyList<CharacterDto> _characters = [];

    private Guid _loadedWorldId;

    protected override void OnInitialized() => Worlds.Changed += OnWorldChanged;

    protected override async Task OnInitializedAsync()
    {
        await Worlds.EnsureLoadedAsync();
        SyncFromWorld();
        await LoadMembersAsync();
        await LoadCampaignsAndCharactersAsync();
    }

    private void OnWorldChanged() => InvokeAsync(async () =>
    {
        SyncFromWorld();
        await LoadMembersAsync();
        await LoadCampaignsAndCharactersAsync();
    });

    private async Task LoadCampaignsAndCharactersAsync()
    {
        if (Worlds.Current is null)
        {
            _campaigns = [];
            _characters = [];
            return;
        }

        _loadingCampaigns = true;
        _campaignsError = null;
        StateHasChanged();

        var campaignsTask = Api.GetCampaignsAsync(Worlds.Current.Id);
        var charactersTask = Api.GetCharactersAsync(Worlds.Current.Id);
        var campaigns = await campaignsTask;
        var characters = await charactersTask;

        _loadingCampaigns = false;
        if (campaigns.IsSuccess)
        {
            _campaigns = campaigns.Value!;
        }
        else
        {
            _campaignsError = campaigns.Error!.Message;
            _campaigns = [];
        }

        // Character names decorate the Campaigns section; a failure just hides them.
        _characters = characters.IsSuccess ? characters.Value! : [];
        StateHasChanged();
    }

    private string CampaignDates(CampaignDto c)
    {
        var start = c.StartedAt?.ToString("MMM yyyy");
        var end = c.EndedAt?.ToString("MMM yyyy");
        return (start, end) switch
        {
            (null, null) => "No dates set",
            (not null, null) => $"Since {start}",
            (null, not null) => $"Until {end}",
            _ => $"{start} – {end}"
        };
    }

    private string CampaignCharacterNames(CampaignDto c) =>
        string.Join(", ", _characters.Where(ch => ch.CampaignIds.Contains(c.Id)).Select(ch => ch.Name));

    private async Task AddCampaignAsync()
    {
        _addCampaignError = null;
        if (string.IsNullOrWhiteSpace(_newCampaignName))
        {
            _addCampaignError = "Enter a campaign name.";
            return;
        }

        _addingCampaign = true;
        var result = await Api.CreateCampaignAsync(Worlds.Current!.Id, new CreateCampaignRequest(_newCampaignName.Trim()));
        _addingCampaign = false;

        if (result.IsSuccess)
        {
            _campaigns = _campaigns.Prepend(result.Value!).ToList();
            _newCampaignName = string.Empty;
            Snackbar.Add("Campaign created.", Severity.Success);
        }
        else
        {
            _addCampaignError = result.Error!.Message;
        }
        StateHasChanged();
    }

    private void BeginEditCampaign(CampaignDto c)
    {
        _editingCampaignId = c.Id;
        _campaignName = c.Name;
        _campaignDescription = c.Description;
        _campaignStatus = c.Status;
        _campaignCharacterIds = _characters.Where(ch => ch.CampaignIds.Contains(c.Id)).Select(ch => ch.Id).ToList();
        _campaignError = null;
    }

    private void CancelEditCampaign() => _editingCampaignId = null;

    private async Task SaveCampaignAsync()
    {
        if (_editingCampaignId is not { } campaignId || Worlds.Current is null)
        {
            return;
        }

        _savingCampaign = true;
        _campaignError = null;

        var update = await Api.UpdateCampaignAsync(Worlds.Current.Id, campaignId,
            new UpdateCampaignRequest(_campaignName, _campaignDescription, _campaignStatus));

        if (!update.IsSuccess)
        {
            _savingCampaign = false;
            _campaignError = update.Error!.Message;
            return;
        }

        var assign = await Api.AssignCampaignCharactersAsync(Worlds.Current.Id, campaignId, _campaignCharacterIds.ToList());
        _savingCampaign = false;

        if (!assign.IsSuccess)
        {
            _campaignError = assign.Error!.Message;
            return;
        }

        _editingCampaignId = null;
        Snackbar.Add("Campaign saved.", Severity.Success);
        await LoadCampaignsAndCharactersAsync();
    }

    private async Task DeleteCampaignAsync(CampaignDto c)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Delete campaign?",
            $"Delete \"{c.Name}\"? Sources keep their content and revert to no campaign; nothing else is removed.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        var result = await Api.DeleteCampaignAsync(Worlds.Current!.Id, c.Id);
        if (result.IsSuccess)
        {
            _campaigns = _campaigns.Where(x => x.Id != c.Id).ToList();
            Snackbar.Add("Campaign deleted.", Severity.Info);
        }
        else
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
        }
        StateHasChanged();
    }

    private void SyncFromWorld()
    {
        if (Worlds.Current is { } c && c.Id != _loadedWorldId)
        {
            _name = c.Name;
            _description = c.Description;
            _gameSystem = c.GameSystem;
            _dailyAiBudget = c.DailyAiBudgetUsd;
            _publicSlug = c.PublicSlug;
            _publicAccessEnabled = c.PublicAccessEnabled;
            _loadedWorldId = c.Id;
        }
    }

    private string SuggestedSlug =>
        Worlds.Current is { } c
            ? new string(c.Name.ToLowerInvariant().Select(ch => char.IsLetterOrDigit(ch) ? ch : '-').ToArray()).Trim('-')
            : "my-world";

    private string PublicUrl => $"https://nornis.app/w/{_publicSlug?.Trim().ToLowerInvariant()}";

    private async Task CopyPublicLinkAsync()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", PublicUrl);
        Snackbar.Add("Public link copied.", Severity.Info);
    }

    private async Task SaveWorldAsync()
    {
        if (Worlds.Current is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_name))
        {
            _worldError = "Name is required.";
            return;
        }

        _savingWorld = true;
        _worldError = null;

        var result = await Api.UpdateWorldAsync(Worlds.Current.Id,
            new UpdateWorldRequest(_name.Trim(), _description, _gameSystem,
                DailyAiBudgetUsd: _dailyAiBudget,
                ClearDailyAiBudget: _dailyAiBudget is null,
                PublicSlug: string.IsNullOrWhiteSpace(_publicSlug) ? null : _publicSlug.Trim(),
                PublicAccessEnabled: _publicAccessEnabled));

        _savingWorld = false;
        if (!result.IsSuccess)
        {
            _worldError = result.Error!.Message;
            return;
        }

        await Worlds.ReloadAsync(); // refresh the sidebar name
        Snackbar.Add("World settings saved.", Severity.Success);
    }

    private async Task LoadMembersAsync()
    {
        if (Worlds.Current is null)
        {
            _members = [];
            return;
        }

        _loadingMembers = true;
        _membersError = null;
        StateHasChanged();

        var result = await Api.GetMembersAsync(Worlds.Current.Id);

        _loadingMembers = false;
        if (result.IsSuccess)
        {
            _members = result.Value!;
        }
        else
        {
            _membersError = result.Error!.Message;
            _members = [];
        }
        StateHasChanged();
    }

    private async Task ChangeRoleAsync(WorldMember member, string newRole)
    {
        if (newRole == member.Role)
        {
            return;
        }

        _busyMembers.Add(member.UserId);
        var result = await Api.UpdateMemberRoleAsync(Worlds.Current!.Id, member.UserId, newRole);
        _busyMembers.Remove(member.UserId);

        if (result.IsSuccess)
        {
            _members = _members.Select(x => x.UserId == member.UserId ? x with { Role = newRole } : x).ToList();
            Snackbar.Add($"Role updated to {RoleLabel(newRole)}.", Severity.Success);
        }
        else
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
        }
        StateHasChanged();
    }

    private async Task RemoveAsync(WorldMember member)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Remove member?",
            $"Remove {DisplayName(member)} from this world?",
            yesText: "Remove", cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        _busyMembers.Add(member.UserId);
        var result = await Api.RemoveMemberAsync(Worlds.Current!.Id, member.UserId);
        _busyMembers.Remove(member.UserId);

        if (result.IsSuccess)
        {
            _members = _members.Where(x => x.UserId != member.UserId).ToList();
            Snackbar.Add("Member removed.", Severity.Info);
        }
        else
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
        }
        StateHasChanged();
    }

    private async Task AddMemberAsync()
    {
        _addError = null;

        if (!Guid.TryParse(_newUserId, out var userId))
        {
            _addError = "Enter a valid user ID (GUID).";
            return;
        }

        _addingMember = true;
        var result = await Api.AddMemberAsync(Worlds.Current!.Id, new AddMemberRequest(userId, _newRole));
        _addingMember = false;

        if (result.IsSuccess)
        {
            _members = _members.Append(result.Value!).ToList();
            _newUserId = string.Empty;
            Snackbar.Add("Member added.", Severity.Success);
        }
        else
        {
            _addError = result.Error!.Message;
        }
        StateHasChanged();
    }

    private static string DisplayName(WorldMember m) =>
        !string.IsNullOrWhiteSpace(m.DisplayName) ? m.DisplayName! : $"User {m.UserId.ToString()[..8]}";

    private static string Initial(WorldMember m) => DisplayName(m)[..1].ToUpperInvariant();

    private static string RoleLabel(string role) => role == "Observer" ? "Fly on the wall" : role;

    public void Dispose() => Worlds.Changed -= OnWorldChanged;
}
