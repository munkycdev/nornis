@using System.Globalization
@implements IAsyncDisposable
@inject NavigationManager Nav
@inject IJSRuntime JS

@* Branching storyline timeline on a real-world calendar, drawn like a git tree.
   Lanes are storylines grouped into campaign bands and ordered as families: children
   indent beneath their PartOf parent, fork connectors drop where a child arc begins,
   and Resolved children merge back into their parent where they end. Rows read top-down
   in campaign order, then by when each storyline opened, then by when it closed. Labels
   are an HTML layer over the SVG; drag-to-nest is pointer-based via nornis-timeline.js —
   grab a label and release anywhere on the target storyline's row. *@

@if (Rows.Count == 0)
{
    <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            No dated storyline activity yet — sessions need an "occurred at" date to place
            their developments on the calendar.
        </MudText>
    </MudPaper>
}
else
{
    <div class="nornis-timeline-legend">
        @foreach (var (status, color) in StatusColors)
        {
            <span class="nornis-graph-legend-item">
                <span class="nornis-graph-dot" style="background:@color"></span>@status
            </span>
        }
        <span class="nornis-list-meta">larger dot = busier session</span>
        <span class="nornis-list-meta">halo = open question</span>
        <span class="nornis-list-meta">band = session touching several storylines</span>
        @if (CanEdit)
        {
            <span class="nornis-list-meta">drag a storyline label onto another row to nest it</span>
        }
    </div>

    <div class="nornis-timeline-scroll">
        <div id="@_elementId" class="nornis-timeline-wrap" style="width:@(TotalWidth)px; height:@(TotalHeight)px">
            <svg width="@TotalWidth" height="@TotalHeight" role="img" aria-label="Storyline timeline">

                @* Month gridlines + calendar labels along the bottom *@
                @foreach (var month in MonthTicks)
                {
                    var mx = X(month);
                    <line x1="@mx" y1="@PlotTop" x2="@mx" y2="@LaneBottom" stroke="rgba(42,59,76,0.08)" stroke-width="1" />
                    @SvgText(mx + 4, LaneBottom + 34, 11, "rgba(42,59,76,0.55)",
                        month.ToString(month.Month == 1 ? "MMM yyyy" : "MMM", CultureInfo.InvariantCulture))
                }

                @* Convergence bands: sessions advancing 2+ storylines *@
                @foreach (var session in Data.Sessions.Where(s => s.StorylineCount >= 2))
                {
                    var sx = X(session.OccurredAt);
                    <line x1="@sx" y1="@PlotTop" x2="@sx" y2="@LaneBottom" stroke="rgba(63,96,121,0.16)" stroke-width="3"
                          data-nornis-tip="@SessionTitle(session)" />
                }

                @* Axis baseline + session ticks *@
                <line x1="@GutterWidth" y1="@LaneBottom" x2="@TotalWidth" y2="@LaneBottom" stroke="rgba(42,59,76,0.25)" stroke-width="1" />
                @foreach (var session in Data.Sessions)
                {
                    var sx = X(session.OccurredAt);
                    <line x1="@sx" y1="@LaneBottom" x2="@sx" y2="@(LaneBottom + 8)"
                          stroke="@(session.StorylineCount >= 2 ? "#3F6079" : "rgba(42,59,76,0.45)")" stroke-width="2"
                          data-nornis-tip="@SessionTitle(session)" />
                }

                @* Fork and merge connectors (drawn beneath the lane dots) *@
                @foreach (var connector in Connectors)
                {
                    <path d="@connector.Path" fill="none" stroke="@connector.Color" stroke-width="1.5" opacity="0.7"
                          data-nornis-tip="@connector.Title" />
                }

                @* Non-hierarchy storyline links stay dashed *@
                @foreach (var link in DrawableLinks)
                {
                    <path d="@link.Path" fill="none" stroke="#9AA5B1" stroke-width="1.5" stroke-dasharray="4 3" opacity="0.8"
                          data-nornis-tip="@link.Title" />
                }

                @* Lane tracks and dots *@
                @foreach (var row in Rows.Where(r => r.Lane is not null))
                {
                    var lane = row.Lane!;
                    var y = RowCenterY(row);
                    var color = StatusColor(lane.Status);
                    var first = X(lane.Points[0].OccurredAt);
                    var last = X(lane.Points[^1].OccurredAt);

                    @if (last > first)
                    {
                        <line x1="@first" y1="@y" x2="@last" y2="@y" stroke="@color" stroke-width="2" opacity="0.45" />
                        @* Invisible wide hit target: the 2px track is too thin to hover reliably. *@
                        <line x1="@first" y1="@y" x2="@last" y2="@y" stroke="transparent" stroke-width="12"
                              data-nornis-tip="@LaneTitle(lane)" />
                    }

                    @foreach (var point in lane.Points)
                    {
                        var px = X(point.OccurredAt);
                        var r = 4 + Math.Min(point.Developments.Count - 1, 3);
                        <g style="cursor:pointer" data-nornis-tip="@PointTitle(lane, point)"
                           @onclick="@(() => Nav.NavigateTo($"{SourceLinkBase}/{point.SourceId}"))">
                            @if (point.Developments.Any(d => d.IsOpenQuestion))
                            {
                                <circle cx="@px" cy="@y" r="@(r + 4)" fill="none" stroke="@color" stroke-width="1.5" opacity="0.55" />
                            }
                            <circle cx="@px" cy="@y" r="@r" fill="@color" stroke="#FDFBF7" stroke-width="2" />
                        </g>
                    }

                    @* Campaign crossings: a small diamond above the lane wherever the arc moves
                       from one campaign into another — the dual of a convergence band. *@
                    @if ((lane.Campaigns?.Count ?? 0) >= 2)
                    {
                        @for (var i = 1; i < lane.Points.Count; i++)
                        {
                            var cur = lane.Points[i];
                            if (cur.CampaignId is { } cid && cur.CampaignId != lane.Points[i - 1].CampaignId)
                            {
                                <path d="@DiamondAbove(X(cur.OccurredAt), y)" fill="@color" stroke="#FDFBF7"
                                      stroke-width="1" opacity="0.9" data-nornis-tip="@($"Enters {CampaignNameFor(lane, cid)}")" />
                            }
                        }
                    }
                }
            </svg>

            @* HTML label layer: band headers and draggable lane labels over the gutter *@
            @foreach (var row in Rows)
            {
                @if (row.Lane is null)
                {
                    <div class="nornis-timeline-band" style="top:@(row.Top)px; height:@(row.Height)px; width:@(TotalWidth)px">
                        @row.BandName
                    </div>
                }
                else
                {
                    var lane = row.Lane;
                    <div class="nornis-timeline-label @(CanEdit ? "nornis-timeline-draggable" : "")"
                         style="top:@(row.Top)px; height:@(row.Height)px; width:@(GutterWidth - 8)px; padding-left:@(8 + row.Depth * 16)px"
                         data-nornis-tip="@(LaneTitle(lane) + (CanEdit ? "\nDrag onto another storyline's row to nest it" : ""))"
                         data-storyline-id="@(CanEdit ? lane.StorylineId.ToString() : null)"
                         @onclick="@(() => Nav.NavigateTo($"{ArtifactLinkBase}/{lane.StorylineId}"))">
                        <span class="nornis-graph-dot" style="background:@StatusColor(lane.Status)"></span>
                        <span class="nornis-timeline-label-text">@lane.Name</span>
                        @if ((lane.Campaigns?.Count ?? 0) >= 2)
                        {
                            <span class="nornis-timeline-span" data-nornis-tip="@SpanTitle(lane)">@lane.Campaigns!.Count</span>
                        }
                    </div>
                }
            }
        </div>
    </div>

    @if (UndatedCount > 0)
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
            @UndatedCount storyline@(UndatedCount == 1 ? " has" : "s have") no dated activity yet and @(UndatedCount == 1 ? "is" : "are") not shown.
        </MudText>
    }
}

@code {
    [Parameter, EditorRequired] public StorylineTimelineDto Data { get; set; } = new([], [], []);

    /// <summary>Statuses to include; null shows everything.</summary>
    [Parameter] public string? StatusFilter { get; set; }

    /// <summary>Enables drag-to-nest on lane labels (GM only).</summary>
    [Parameter] public bool CanEdit { get; set; }

    /// <summary>Route prefixes for point/lane clicks; the public /w/{slug} pages override these.</summary>
    [Parameter] public string SourceLinkBase { get; set; } = "/sources";
    [Parameter] public string ArtifactLinkBase { get; set; } = "/artifacts";

    /// <summary>Raised when a lane is dropped onto another: (child, new parent).</summary>
    [Parameter] public EventCallback<(TimelineLaneDto Child, TimelineLaneDto Parent)> ReparentRequested { get; set; }

    private const int GutterWidth = 230;
    private const int RowHeight = 36;
    private const int BandHeight = 30;
    private const int PlotTop = 10;
    private const int AxisHeight = 48;
    private const int PadDays = 10;
    private const double MinPxPerDay = 2.2;
    private const int MinPlotWidth = 720;
    private const string NoCampaign = "No campaign";

    // Lane sort keys: when the arc opened, and when it last moved. Both index Points
    // directly — every caller runs over the Points.Count > 0 set Rows filters to.
    private static DateTimeOffset Opened(TimelineLaneDto lane) => lane.Points[0].OccurredAt;

    private static DateTimeOffset Closed(TimelineLaneDto lane) => lane.Points[^1].OccurredAt;

    private static readonly (string Status, string Color)[] StatusColors =
    [
        ("Active", "#4E9A6B"), ("Dormant", "#C08A2E"), ("Resolved", "#3F6079"),
    ];

    private readonly string _elementId = $"nornis-timeline-{Guid.NewGuid():N}";
    private DotNetObjectReference<StorylineTimelineChart>? _selfRef;
    private bool _dragInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // The wrap div only exists once there are rows, so init on the first render
        // that actually drew it rather than strictly on firstRender.
        if (CanEdit && !_dragInitialized && Rows.Count > 0)
        {
            _dragInitialized = true;
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("nornisTimeline.init", _elementId, _selfRef);
        }
    }

    [JSInvokable]
    public async Task OnJsReparent(string childId, string parentId)
    {
        if (!CanEdit || !Guid.TryParse(childId, out var child) || !Guid.TryParse(parentId, out var parent) || child == parent)
        {
            return;
        }

        var childLane = Data.Lanes.FirstOrDefault(l => l.StorylineId == child);
        var parentLane = Data.Lanes.FirstOrDefault(l => l.StorylineId == parent);
        if (childLane is not null && parentLane is not null)
        {
            await InvokeAsync(() => ReparentRequested.InvokeAsync((childLane, parentLane)));
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_dragInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("nornisTimeline.destroy", _elementId);
            }
            catch (JSDisconnectedException)
            {
                // Circuit already gone — the browser cleaned up with the page.
            }
        }
        _selfRef?.Dispose();
    }

    // ------------------------------------------------------------------ Layout --

    private sealed record Row(string? BandName, TimelineLaneDto? Lane, int Depth, int Top, int Height);

    private IReadOnlyList<Row> Rows
    {
        get
        {
            var visible = Data.Lanes
                .Where(l => l.Points.Count > 0)
                .Where(l => StatusFilter is null || l.Status == StatusFilter)
                .ToList();
            var visibleIds = visible.Select(l => l.StorylineId).ToHashSet();

            // Children attach only when their parent is also visible; otherwise they
            // stand as roots so the filter never hides a lane entirely. Siblings — and
            // roots — order by when their arc opened, then by when it closed, so two
            // storylines picked up in the same session read shortest-arc-first.
            var childrenByParent = visible
                .Where(l => l.ParentStorylineId is { } p && visibleIds.Contains(p))
                .GroupBy(l => l.ParentStorylineId!.Value)
                .ToDictionary(g => g.Key, g => g.OrderBy(Opened).ThenBy(Closed).ToList());
            var roots = visible
                .Where(l => l.ParentStorylineId is not { } p || !visibleIds.Contains(p))
                .OrderBy(Opened).ThenBy(Closed)
                .ToList();

            IEnumerable<TimelineLaneDto> Family(TimelineLaneDto lane)
            {
                yield return lane;
                if (childrenByParent.TryGetValue(lane.StorylineId, out var children))
                {
                    foreach (var descendant in children.SelectMany(Family))
                    {
                        yield return descendant;
                    }
                }
            }

            // Families live in the band of their root's campaign, and bands run in the
            // order the campaigns did — by the GM's declared start date, falling back to
            // the band's earliest activity when a campaign was never dated. A child can
            // open before its root, so the fallback spans whole families, not just roots.
            var bands = roots
                .GroupBy(r => r.CampaignName ?? NoCampaign)
                .Select(g =>
                {
                    var declared = g.Select(r => r.CampaignStartedAt).OfType<DateTimeOffset>().ToList();
                    return (
                        Name: g.Key,
                        Roots: (IEnumerable<TimelineLaneDto>)g,
                        Start: declared.Count > 0 ? declared.Min() : g.SelectMany(Family).Min(Opened));
                })
                .OrderBy(b => b.Start)
                .ThenBy(b => b.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();

            var rows = new List<Row>();
            var top = PlotTop;

            void AddFamily(TimelineLaneDto lane, int depth)
            {
                rows.Add(new Row(null, lane, depth, top, RowHeight));
                top += RowHeight;
                if (childrenByParent.TryGetValue(lane.StorylineId, out var children))
                {
                    foreach (var childLane in children)
                    {
                        AddFamily(childLane, depth + 1);
                    }
                }
            }

            foreach (var band in bands)
            {
                if (bands.Count > 1 || band.Name != NoCampaign)
                {
                    rows.Add(new Row(band.Name, null, 0, top, BandHeight));
                    top += BandHeight;
                }
                foreach (var root in band.Roots)
                {
                    AddFamily(root, 0);
                }
            }

            return rows;
        }
    }

    private int UndatedCount =>
        Data.Lanes.Count(l => l.Points.Count == 0 && (StatusFilter is null || l.Status == StatusFilter));

    private DateTimeOffset MinDate =>
        (Data.Sessions.Count > 0 ? Data.Sessions[0].OccurredAt : DateTimeOffset.UtcNow).AddDays(-PadDays);

    private DateTimeOffset MaxDate =>
        (Data.Sessions.Count > 0 ? Data.Sessions[^1].OccurredAt : DateTimeOffset.UtcNow).AddDays(PadDays);

    private double SpanDays => Math.Max(1, (MaxDate - MinDate).TotalDays);

    private double PxPerDay => Math.Max(MinPxPerDay, MinPlotWidth / SpanDays);

    private int TotalWidth => GutterWidth + (int)(SpanDays * PxPerDay) + 30;

    private int LaneBottom => (Rows.Count > 0 ? Rows[^1].Top + Rows[^1].Height : PlotTop) + 8;

    private int TotalHeight => LaneBottom + AxisHeight;

    private int X(DateTimeOffset date) =>
        GutterWidth + (int)((date - MinDate).TotalDays * PxPerDay);

    private static int RowCenterY(Row row) => row.Top + row.Height / 2;

    private IEnumerable<DateTimeOffset> MonthTicks
    {
        get
        {
            var tick = new DateTimeOffset(MinDate.Year, MinDate.Month, 1, 0, 0, 0, MinDate.Offset).AddMonths(1);
            while (tick <= MaxDate)
            {
                yield return tick;
                tick = tick.AddMonths(1);
            }
        }
    }

    private string StatusColor(string status) =>
        StatusColors.FirstOrDefault(s => s.Status == status).Color ?? "#9AA5B1";

    private static string Truncate(string text, int max) =>
        text.Length <= max ? text : text[..(max - 1)] + "…";

    // Razor reserves the <text> tag, so SVG text elements are emitted as raw markup.
    private static MarkupString SvgText(int x, int y, int fontSize, string fill, string content) =>
        new($"<text x=\"{x}\" y=\"{y}\" font-size=\"{fontSize}\" fill=\"{fill}\">{System.Net.WebUtility.HtmlEncode(content)}</text>");

    private static string LaneTitle(TimelineLaneDto lane) => $"{lane.Name} ({lane.Status})";

    private static string CampaignNameFor(TimelineLaneDto lane, Guid campaignId) =>
        (lane.Campaigns ?? []).FirstOrDefault(c => c.CampaignId == campaignId)?.Name ?? "another campaign";

    // A small diamond centred above the lane, marking a campaign crossing.
    private static string DiamondAbove(int x, int y)
    {
        var top = y - 10;
        const int s = 4;
        return $"M {x} {top - s} L {x + s} {top} L {x} {top + s} L {x - s} {top} Z";
    }

    private static string SpanTitle(TimelineLaneDto lane)
    {
        var lines = (lane.Campaigns ?? []).Select(c =>
            "• " + c.Name + (c.Declared ? (c.Derived ? " (declared)" : " (declared, no sessions yet)") : ""));
        return "Spans campaigns:\n" + string.Join("\n", lines);
    }

    private static string SessionTitle(TimelineSessionDto s) =>
        $"{s.Title} — {s.OccurredAt.ToString("MMM d, yyyy", CultureInfo.InvariantCulture)}"
        + (s.StorylineCount >= 2 ? $"\nAdvances {s.StorylineCount} storylines" : "");

    private string PointTitle(TimelineLaneDto lane, TimelinePointDto point)
    {
        var session = Data.Sessions.FirstOrDefault(s => s.SourceId == point.SourceId);
        var header = $"{session?.Title ?? "Session"} — {point.OccurredAt.ToString("MMM d, yyyy", CultureInfo.InvariantCulture)}";
        var lines = point.Developments.Take(6)
            .Select(d => $"• {(d.IsOpenQuestion ? "Open question — " : "")}{Truncate(d.Text, 110)}");
        var more = point.Developments.Count > 6 ? $"\n…and {point.Developments.Count - 6} more" : "";
        return $"{header}\n{string.Join("\n", lines)}{more}\n(click to open the session)";
    }

    // ------------------------------------------------------------- Connectors --

    private sealed record Connector(string Path, string Color, string Title);

    /// <summary>
    /// Git-style hierarchy connectors: a fork from the parent lane where the child's
    /// first session sits, and a merge back into the parent where a Resolved child ends.
    /// </summary>
    private IReadOnlyList<Connector> Connectors
    {
        get
        {
            var rows = Rows;
            var rowByLane = rows.Where(r => r.Lane is not null).ToDictionary(r => r.Lane!.StorylineId);
            var result = new List<Connector>();

            foreach (var row in rows)
            {
                var lane = row.Lane;
                if (lane?.ParentStorylineId is not { } parentId || !rowByLane.TryGetValue(parentId, out var parentRow))
                {
                    continue;
                }

                var yChild = RowCenterY(row);
                var yParent = RowCenterY(parentRow);
                var color = StatusColor(lane.Status);
                var parentName = parentRow.Lane!.Name;

                var xStart = X(lane.Points[0].OccurredAt);
                result.Add(new Connector(
                    $"M {xStart - 18} {yParent} C {xStart} {yParent}, {xStart - 18} {yChild}, {xStart} {yChild}",
                    color,
                    $"{lane.Name} branches from {parentName}"));

                if (lane.Status == "Resolved")
                {
                    var xEnd = X(lane.Points[^1].OccurredAt);
                    result.Add(new Connector(
                        $"M {xEnd} {yChild} C {xEnd + 18} {yChild}, {xEnd} {yParent}, {xEnd + 18} {yParent}",
                        color,
                        $"{lane.Name} resolves back into {parentName}"));
                }
            }

            return result;
        }
    }

    private sealed record DrawableLink(string Path, string Title);

    private IReadOnlyList<DrawableLink> DrawableLinks
    {
        get
        {
            var rows = Rows;
            var rowByLane = rows.Where(r => r.Lane is not null).ToDictionary(r => r.Lane!.StorylineId);
            var result = new List<DrawableLink>();

            foreach (var link in Data.Links)
            {
                if (!rowByLane.TryGetValue(link.FromStorylineId, out var rowA)
                    || !rowByLane.TryGetValue(link.ToStorylineId, out var rowB))
                {
                    continue;
                }

                var laneA = rowA.Lane!;
                var laneB = rowB.Lane!;

                var shared = laneA.Points.Select(p => p.SourceId)
                    .Intersect(laneB.Points.Select(p => p.SourceId))
                    .ToHashSet();
                var anchor = shared.Count > 0
                    ? laneA.Points.First(p => shared.Contains(p.SourceId)).OccurredAt
                    : new[] { laneA.Points[0].OccurredAt, laneB.Points[0].OccurredAt }.Max();

                var x = X(anchor);
                var y1 = Math.Min(RowCenterY(rowA), RowCenterY(rowB));
                var y2 = Math.Max(RowCenterY(rowA), RowCenterY(rowB));
                var bulge = x + 18;

                result.Add(new DrawableLink(
                    $"M {x} {y1} C {bulge} {y1}, {bulge} {y2}, {x} {y2}",
                    $"{laneA.Name} — {link.Type} — {laneB.Name}"));
            }

            return result;
        }
    }
}
