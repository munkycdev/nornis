@inject NornisApiClient Api
@inject ISnackbar Snackbar
@inject IJSRuntime JS

@* GM-only session wrap-up. Renders nothing unless there is work to do, so it stays out of
   the way on quiet days and appears at the natural cadence after a session lands. *@
@if (_view is { HasWork: true })
{
    <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
        <div class="nornis-card-header">
            <span class="nornis-card-title">Session Wrap-Up</span>
            <MudTooltip Text="What moved, what went quiet, and what could be organized — since your last session.">
                <MudIcon Icon="@Icons.Material.Outlined.Checklist" Color="Color.Tertiary" Size="Size.Small" />
            </MudTooltip>
        </div>

        @if (_view.LatestSession is { } latest)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                Since “@latest.Title”
            </MudText>
        }

        @if (_view.GoneQuiet.Count > 0)
        {
            <div class="nornis-wrapup-section">
                <div class="nornis-wrapup-heading">Gone quiet</div>
                @foreach (var q in _view.GoneQuiet)
                {
                    <div class="nornis-list-row">
                        <div class="nornis-list-body">
                            <div class="nornis-list-title">@q.Name</div>
                            <div class="nornis-list-sub">
                                @q.SessionsSinceLastDevelopment session@(q.SessionsSinceLastDevelopment == 1 ? "" : "s") quiet@(q.OpenQuestionCount > 0 ? $" · {q.OpenQuestionCount} open" : "")
                            </div>
                        </div>
                        <MudButtonGroup Size="Size.Small" Variant="Variant.Outlined">
                            <MudButton Color='@(ClosureIs(q.StorylineId, "Dormant") ? Color.Warning : Color.Default)'
                                       OnClick='() => SetClosure(q.StorylineId, "Dormant")'>Dormant</MudButton>
                            <MudButton Color='@(ClosureIs(q.StorylineId, "Resolved") ? Color.Success : Color.Default)'
                                       OnClick='() => SetClosure(q.StorylineId, "Resolved")'>Resolved</MudButton>
                            <MudButton OnClick="() => DismissQuietAsync(q.StorylineId)">Still active</MudButton>
                        </MudButtonGroup>
                    </div>
                }
            </div>
        }

        @if (_view.CouldNest.Count > 0)
        {
            <div class="nornis-wrapup-section">
                <div class="nornis-wrapup-heading">Could nest</div>
                @foreach (var n in _view.CouldNest)
                {
                    <div class="nornis-list-row">
                        <div class="nornis-list-body">
                            <div class="nornis-list-title">@n.ChildName → @n.ParentName</div>
                            <div class="nornis-list-sub">@n.Rationale</div>
                        </div>
                        <MudButtonGroup Size="Size.Small" Variant="Variant.Outlined">
                            <MudButton Color="@(_accept.Contains(n.ProposalId) ? Color.Success : Color.Default)"
                                       OnClick="() => Accept(n.ProposalId)">Nest</MudButton>
                            <MudButton Color="@(_reject.Contains(n.ProposalId) ? Color.Error : Color.Default)"
                                       OnClick="() => Reject(n.ProposalId)">Skip</MudButton>
                        </MudButtonGroup>
                    </div>
                }
            </div>
        }

        @if (_view.UnparentedArcs.Count > 0)
        {
            <div class="nornis-wrapup-section">
                <div class="nornis-wrapup-heading">New arcs — assign a parent?</div>
                @foreach (var arc in _view.UnparentedArcs)
                {
                    <div class="nornis-list-row">
                        <div class="nornis-list-body">
                            <div class="nornis-list-title">@arc.Name</div>
                        </div>
                        <MudSelect T="Guid?" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                                   Value="@GetParent(arc.StorylineId)" ValueChanged="v => SetParent(arc.StorylineId, v)"
                                   Placeholder="No parent" Style="min-width: 160px;">
                            <MudSelectItem T="Guid?" Value="@((Guid?)null)">No parent</MudSelectItem>
                            @foreach (var opt in _view.ParentOptions.Where(o => o.StorylineId != arc.StorylineId))
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)opt.StorylineId)">@opt.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </div>
                }
            </div>
        }

        @if (_view.Advanced.Count > 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-2">
                Advanced recently: @string.Join(", ", _view.Advanced.Select(a => a.Name))
            </MudText>
        }

        <div class="nornis-card-foot d-flex justify-space-between align-center">
            <MudText Typo="Typo.caption" Color="Color.Secondary">@PendingSummary()</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Check"
                       Disabled="_applying || !HasPending" OnClick="ApplyAsync">
                @(_applying ? "Applying…" : "Apply")
            </MudButton>
        </div>
    </MudPaper>
}

@code {
    [Parameter] public Guid WorldId { get; set; }

    private WrapUpDto? _view;
    private Guid _loadedWorldId;
    private bool _applying;

    // Pending decisions, collected client-side until Apply.
    private readonly Dictionary<Guid, string> _closures = new();   // storylineId → "Dormant"|"Resolved"
    private readonly HashSet<Guid> _accept = new();                // nest proposal ids
    private readonly HashSet<Guid> _reject = new();
    private readonly Dictionary<Guid, Guid> _parents = new();      // childId → parentId

    private bool HasPending =>
        _closures.Count > 0 || _accept.Count > 0 || _reject.Count > 0 || _parents.Count > 0;

    protected override async Task OnParametersSetAsync()
    {
        if (WorldId != _loadedWorldId)
        {
            _loadedWorldId = WorldId;
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _closures.Clear();
        _accept.Clear();
        _reject.Clear();
        _parents.Clear();

        if (WorldId == Guid.Empty)
        {
            _view = null;
            return;
        }

        var result = await Api.GetWrapUpAsync(WorldId);
        if (!result.IsSuccess || result.Value is null)
        {
            _view = null;
            return;
        }

        // The snooze lives in localStorage, reachable only once the component is interactive.
        // During static prerender (RendererInfo.IsInteractive == false) a JS interop call throws
        // ("JavaScript interop calls cannot be issued at this time") and 500s the page — so skip it
        // and show the unfiltered view; the interactive render re-runs LoadAsync and applies snooze.
        _view = RendererInfo.IsInteractive
            ? await ApplySnoozeAsync(result.Value)
            : result.Value;
        StateHasChanged();
    }

    // Client-persisted snooze: a quiet storyline the GM marked "still active" stays hidden
    // until a newer session arrives (the latest-session id is part of the key).
    private async Task<WrapUpDto> ApplySnoozeAsync(WrapUpDto view)
    {
        var latest = view.LatestSession?.SourceId ?? Guid.Empty;
        var snoozed = await GetSnoozedStorylineIdsAsync(latest);
        if (snoozed.Count == 0)
        {
            return view;
        }

        var kept = view.GoneQuiet.Where(q => !snoozed.Contains(q.StorylineId)).ToList();
        var filtered = view with { GoneQuiet = kept };
        return filtered with { HasWork = filtered.GoneQuiet.Count > 0 || filtered.CouldNest.Count > 0 || filtered.UnparentedArcs.Count > 0 };
    }

    private static string SnoozeKeyFor(Guid storylineId, Guid latestSessionId) =>
        $"{storylineId}:{latestSessionId}";

    private string SnoozeStorageKey => $"nornis-wrapup-snooze-{WorldId}";

    private async Task<HashSet<Guid>> GetSnoozedStorylineIdsAsync(Guid latestSessionId)
    {
        // Snooze entries are "storylineId:latestSessionId"; a storyline is snoozed only while
        // the latest session it was snoozed against is still the latest one.
        var raw = await JS.InvokeAsync<string?>("localStorage.getItem", SnoozeStorageKey);
        if (string.IsNullOrWhiteSpace(raw))
        {
            return new HashSet<Guid>();
        }

        var suffix = $":{latestSessionId}";
        var set = new HashSet<Guid>();
        foreach (var entry in raw.Split(',', StringSplitOptions.RemoveEmptyEntries))
        {
            var colon = entry.IndexOf(':');
            if (colon > 0
                && entry.EndsWith(suffix, StringComparison.Ordinal)
                && Guid.TryParse(entry[..colon], out var id))
            {
                set.Add(id);
            }
        }
        return set;
    }

    private async Task DismissQuietAsync(Guid storylineId)
    {
        // Persist against the current latest session so it re-surfaces after a newer one.
        var latest = _view?.LatestSession?.SourceId ?? Guid.Empty;
        var raw = await JS.InvokeAsync<string?>("localStorage.getItem", SnoozeStorageKey) ?? string.Empty;
        var entries = raw.Split(',', StringSplitOptions.RemoveEmptyEntries).ToHashSet();
        entries.Add(SnoozeKeyFor(storylineId, latest));
        await JS.InvokeVoidAsync("localStorage.setItem", SnoozeStorageKey, string.Join(',', entries));

        _closures.Remove(storylineId);
        if (_view is not null)
        {
            var kept = _view.GoneQuiet.Where(q => q.StorylineId != storylineId).ToList();
            _view = _view with { GoneQuiet = kept };
            _view = _view with { HasWork = _view.GoneQuiet.Count > 0 || _view.CouldNest.Count > 0 || _view.UnparentedArcs.Count > 0 };
        }
        StateHasChanged();
    }

    private bool ClosureIs(Guid storylineId, string status) =>
        _closures.TryGetValue(storylineId, out var s) && s == status;

    private void SetClosure(Guid storylineId, string status)
    {
        if (ClosureIs(storylineId, status))
        {
            _closures.Remove(storylineId); // toggle off
        }
        else
        {
            _closures[storylineId] = status;
        }
    }

    private void Accept(Guid proposalId)
    {
        _reject.Remove(proposalId);
        if (!_accept.Add(proposalId)) _accept.Remove(proposalId);
    }

    private void Reject(Guid proposalId)
    {
        _accept.Remove(proposalId);
        if (!_reject.Add(proposalId)) _reject.Remove(proposalId);
    }

    private Guid? GetParent(Guid childId) => _parents.TryGetValue(childId, out var p) ? p : null;

    private void SetParent(Guid childId, Guid? parentId)
    {
        if (parentId is { } p)
        {
            _parents[childId] = p;
        }
        else
        {
            _parents.Remove(childId);
        }
    }

    private string PendingSummary()
    {
        var parts = new List<string>();
        if (_closures.Count > 0) parts.Add($"{_closures.Count} to close");
        if (_accept.Count > 0) parts.Add($"{_accept.Count} to nest");
        if (_reject.Count > 0) parts.Add($"{_reject.Count} to skip");
        if (_parents.Count > 0) parts.Add($"{_parents.Count} to parent");
        return parts.Count == 0 ? "No changes selected" : string.Join(" · ", parts);
    }

    private async Task ApplyAsync()
    {
        if (_applying || !HasPending)
        {
            return;
        }

        _applying = true;
        StateHasChanged();

        var body = new WrapUpDecisionsBody(
            _closures.Select(kv => new WrapUpClosureBody(kv.Key, kv.Value)).ToList(),
            _accept.ToList(),
            _reject.ToList(),
            _parents.Select(kv => new WrapUpParentBody(kv.Key, kv.Value)).ToList());

        var result = await Api.ApplyWrapUpAsync(WorldId, body);
        _applying = false;

        if (result.IsSuccess)
        {
            var v = result.Value!;
            Snackbar.Add($"Wrap-up applied: {v.Closed} closed, {v.Nested} nested, {v.Parented} parented.", Severity.Success);
            _loadedWorldId = Guid.Empty; // force a fresh reload
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Wrap-up failed.", Severity.Error);
            StateHasChanged();
        }
    }
}
