@inject NornisApiClient Api
@inject ISnackbar Snackbar
@inject IJSRuntime JS

@* GM-only session wrap-up. Renders nothing unless there is work to do, so it stays out of
   the way on quiet days and appears at the natural cadence after a session lands.

   Every decision here saves the moment it is made and the row leaves the list. The card can
   run to thousands of pixels on a busy world, so anything staged behind a footer button is
   feedback the GM never sees — acting in place is the only signal that reads at that height. *@
@if (_view is { HasWork: true })
{
    <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
        <div class="nornis-card-header">
            <span class="nornis-card-title">Session Wrap-Up</span>
            <MudTooltip Text="What moved, what went quiet, and what could be organized — since your last session.">
                <MudIcon Icon="@Icons.Material.Outlined.Checklist" Color="Color.Tertiary" Size="Size.Small" />
            </MudTooltip>
        </div>

        @if (_view.LatestSession is { } latest)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                Since “@latest.Title”
            </MudText>
        }

        @if (_view.GoneQuiet.Count > 0)
        {
            <div class="nornis-wrapup-section">
                <div class="nornis-wrapup-heading">Gone quiet</div>
                @foreach (var q in _view.GoneQuiet)
                {
                    <div class="nornis-list-row nornis-wrapup-row">
                        <div class="nornis-list-body">
                            <div class="nornis-list-title">@q.Name</div>
                            <div class="nornis-list-sub">
                                @q.SessionsSinceLastDevelopment session@(q.SessionsSinceLastDevelopment == 1 ? "" : "s") quiet@(q.OpenQuestionCount > 0 ? $" · {q.OpenQuestionCount} open" : "")
                            </div>
                        </div>
                        <MudButtonGroup Size="Size.Small" Variant="Variant.Outlined" Class="nornis-wrapup-actions">
                            <MudButton Disabled="@IsBusy(q.StorylineId)"
                                       OnClick='() => CloseQuietAsync(q, "Dormant")'>Dormant</MudButton>
                            <MudButton Disabled="@IsBusy(q.StorylineId)"
                                       OnClick='() => CloseQuietAsync(q, "Resolved")'>Resolved</MudButton>
                            <MudButton Disabled="@IsBusy(q.StorylineId)"
                                       OnClick="() => DismissQuietAsync(q)">Still active</MudButton>
                        </MudButtonGroup>
                    </div>
                }
            </div>
        }

        @if (_view.CouldNest.Count > 0)
        {
            <div class="nornis-wrapup-section">
                <div class="nornis-wrapup-heading">Could nest</div>
                @foreach (var n in _view.CouldNest)
                {
                    <div class="nornis-list-row nornis-wrapup-row">
                        <div class="nornis-list-body">
                            <div class="nornis-list-title">@n.ChildName → @n.ParentName</div>
                            <div class="nornis-list-sub">@n.Rationale</div>
                        </div>
                        <MudButtonGroup Size="Size.Small" Variant="Variant.Outlined" Class="nornis-wrapup-actions">
                            <MudButton Disabled="@IsBusy(n.ProposalId)"
                                       OnClick="() => ResolveNestAsync(n, accept: true)">Nest</MudButton>
                            <MudButton Disabled="@IsBusy(n.ProposalId)"
                                       OnClick="() => ResolveNestAsync(n, accept: false)">Skip</MudButton>
                        </MudButtonGroup>
                    </div>
                }
            </div>
        }

        @if (_view.UnparentedArcs.Count > 0)
        {
            <div class="nornis-wrapup-section">
                <div class="nornis-wrapup-heading">New arcs — assign a parent?</div>
                @foreach (var arc in _view.UnparentedArcs)
                {
                    <div class="nornis-list-row nornis-wrapup-row">
                        <div class="nornis-list-body">
                            <div class="nornis-list-title">@arc.Name</div>
                        </div>
                        <MudSelect T="Guid?" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                                   Value="@((Guid?)null)" ValueChanged="v => AssignParentAsync(arc, v)"
                                   Disabled="@IsBusy(arc.StorylineId)"
                                   Placeholder="No parent" Class="nornis-wrapup-actions" Style="min-width: 160px;">
                            <MudSelectItem T="Guid?" Value="@((Guid?)null)">No parent</MudSelectItem>
                            @foreach (var opt in _view.ParentOptions.Where(o => o.StorylineId != arc.StorylineId))
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)opt.StorylineId)">@opt.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </div>
                }
            </div>
        }

        @if (_view.Advanced.Count > 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-2">
                Advanced recently: @string.Join(", ", _view.Advanced.Select(a => a.Name))
            </MudText>
        }

        <div class="nornis-card-foot">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Each choice saves as you make it.</MudText>
        </div>
    </MudPaper>
}

@code {
    [Parameter] public Guid WorldId { get; set; }

    private WrapUpDto? _view;
    private Guid _loadedWorldId;

    // Rows with a request in flight, keyed by storyline or proposal id. Guards against a
    // double-click firing the same irreversible accept/reject twice.
    private readonly HashSet<Guid> _busy = new();

    private bool IsBusy(Guid id) => _busy.Contains(id);

    protected override async Task OnParametersSetAsync()
    {
        if (WorldId != _loadedWorldId)
        {
            _loadedWorldId = WorldId;
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _busy.Clear();

        if (WorldId == Guid.Empty)
        {
            _view = null;
            return;
        }

        var result = await Api.GetWrapUpAsync(WorldId);
        if (!result.IsSuccess || result.Value is null)
        {
            _view = null;
            return;
        }

        // The snooze lives in localStorage, reachable only once the component is interactive.
        // During static prerender (RendererInfo.IsInteractive == false) a JS interop call throws
        // ("JavaScript interop calls cannot be issued at this time") and 500s the page — so skip it
        // and show the unfiltered view; the interactive render re-runs LoadAsync and applies snooze.
        _view = RendererInfo.IsInteractive
            ? await ApplySnoozeAsync(result.Value)
            : result.Value;
        StateHasChanged();
    }

    // ------------------------------------------------------------------ Decisions --

    // Closures go straight at the artifact's status rather than through the wrap-up endpoint:
    // that endpoint mints a synthetic GMNote source + review batch per call, which is sized for
    // one batched apply, not for one write per click. The cost is that nothing records *why* the
    // storyline closed — so the snackbar carries an Undo, which the status route can honour
    // (the wrap-up endpoint deliberately refuses to reopen anything).
    private async Task CloseQuietAsync(QuietStorylineDto q, string status)
    {
        if (!_busy.Add(q.StorylineId))
        {
            return;
        }

        var result = await Api.SetArtifactStatusAsync(WorldId, q.StorylineId, status);
        _busy.Remove(q.StorylineId);

        if (!result.IsSuccess)
        {
            Snackbar.Add(result.Error?.Message ?? $"Could not mark “{q.Name}” {status.ToLowerInvariant()}.", Severity.Error);
            StateHasChanged();
            return;
        }

        DropQuiet(q.StorylineId);
        Snackbar.Add($"“{q.Name}” marked {status.ToLowerInvariant()}.", Severity.Success, config =>
        {
            config.Action = "Undo";
            config.ActionColor = Color.Inherit;
            config.VisibleStateDuration = 10000;
            config.Onclick = _ => UndoCloseAsync(q);
        });
    }

    // Restores the status the row was showing before it was closed, then reloads so the card
    // reflects the server rather than a locally patched view.
    private async Task UndoCloseAsync(QuietStorylineDto q)
    {
        var result = await Api.SetArtifactStatusAsync(WorldId, q.StorylineId, q.Status);
        if (!result.IsSuccess)
        {
            Snackbar.Add(result.Error?.Message ?? $"Could not restore “{q.Name}”.", Severity.Error);
            return;
        }

        Snackbar.Add($"“{q.Name}” restored to {q.Status.ToLowerInvariant()}.", Severity.Info);
        _loadedWorldId = Guid.Empty;
        await LoadAsync();
    }

    // Accept/reject route through the wrap-up endpoint, which delegates to the review service.
    // With no closures in the payload it writes no synthetic source or batch, so one call per
    // decision costs nothing extra.
    private async Task ResolveNestAsync(WrapUpNestSuggestionDto n, bool accept)
    {
        if (!_busy.Add(n.ProposalId))
        {
            return;
        }

        var body = new WrapUpDecisionsBody(
            null,
            accept ? [n.ProposalId] : [],
            accept ? [] : [n.ProposalId],
            null);

        var result = await Api.ApplyWrapUpAsync(WorldId, body);
        _busy.Remove(n.ProposalId);

        if (!result.IsSuccess)
        {
            Snackbar.Add(result.Error?.Message ?? "Could not apply that change.", Severity.Error);
            StateHasChanged();
            return;
        }

        if (_view is not null)
        {
            _view = _view with { CouldNest = _view.CouldNest.Where(x => x.ProposalId != n.ProposalId).ToList() };
            RecomputeHasWork();
        }

        Snackbar.Add(accept
            ? $"“{n.ChildName}” nested under “{n.ParentName}”."
            : $"Skipped nesting “{n.ChildName}”.", Severity.Success);
        StateHasChanged();
    }

    private async Task AssignParentAsync(WrapUpUnparentedDto arc, Guid? parentId)
    {
        if (parentId is not { } parent || !_busy.Add(arc.StorylineId))
        {
            return; // "No parent" is the resting state, so selecting it is a no-op.
        }

        var body = new WrapUpDecisionsBody(null, [], [], [new WrapUpParentBody(arc.StorylineId, parent)]);

        var result = await Api.ApplyWrapUpAsync(WorldId, body);
        _busy.Remove(arc.StorylineId);

        if (!result.IsSuccess)
        {
            Snackbar.Add(result.Error?.Message ?? $"Could not assign a parent to “{arc.Name}”.", Severity.Error);
            StateHasChanged();
            return;
        }

        var parentName = _view?.ParentOptions.FirstOrDefault(o => o.StorylineId == parent)?.Name ?? "its parent";
        if (_view is not null)
        {
            _view = _view with { UnparentedArcs = _view.UnparentedArcs.Where(x => x.StorylineId != arc.StorylineId).ToList() };
            RecomputeHasWork();
        }

        Snackbar.Add($"“{arc.Name}” nested under “{parentName}”.", Severity.Success);
        StateHasChanged();
    }

    // ---------------------------------------------------------------------- Snooze --

    // Client-persisted snooze: a quiet storyline the GM marked "still active" stays hidden
    // until a newer session arrives (the latest-session id is part of the key).
    private async Task<WrapUpDto> ApplySnoozeAsync(WrapUpDto view)
    {
        var latest = view.LatestSession?.SourceId ?? Guid.Empty;
        var snoozed = await GetSnoozedStorylineIdsAsync(latest);
        if (snoozed.Count == 0)
        {
            return view;
        }

        var kept = view.GoneQuiet.Where(q => !snoozed.Contains(q.StorylineId)).ToList();
        var filtered = view with { GoneQuiet = kept };
        return filtered with { HasWork = filtered.GoneQuiet.Count > 0 || filtered.CouldNest.Count > 0 || filtered.UnparentedArcs.Count > 0 };
    }

    private static string SnoozeKeyFor(Guid storylineId, Guid latestSessionId) =>
        $"{storylineId}:{latestSessionId}";

    private string SnoozeStorageKey => $"nornis-wrapup-snooze-{WorldId}";

    private async Task<HashSet<Guid>> GetSnoozedStorylineIdsAsync(Guid latestSessionId)
    {
        // Snooze entries are "storylineId:latestSessionId"; a storyline is snoozed only while
        // the latest session it was snoozed against is still the latest one.
        var raw = await JS.InvokeAsync<string?>("localStorage.getItem", SnoozeStorageKey);
        if (string.IsNullOrWhiteSpace(raw))
        {
            return new HashSet<Guid>();
        }

        var suffix = $":{latestSessionId}";
        var set = new HashSet<Guid>();
        foreach (var entry in raw.Split(',', StringSplitOptions.RemoveEmptyEntries))
        {
            var colon = entry.IndexOf(':');
            if (colon > 0
                && entry.EndsWith(suffix, StringComparison.Ordinal)
                && Guid.TryParse(entry[..colon], out var id))
            {
                set.Add(id);
            }
        }
        return set;
    }

    private async Task DismissQuietAsync(QuietStorylineDto q)
    {
        if (!_busy.Add(q.StorylineId))
        {
            return;
        }

        // Persist against the current latest session so it re-surfaces after a newer one.
        var latest = _view?.LatestSession?.SourceId ?? Guid.Empty;
        var raw = await JS.InvokeAsync<string?>("localStorage.getItem", SnoozeStorageKey) ?? string.Empty;
        var entries = raw.Split(',', StringSplitOptions.RemoveEmptyEntries).ToHashSet();
        entries.Add(SnoozeKeyFor(q.StorylineId, latest));
        await JS.InvokeVoidAsync("localStorage.setItem", SnoozeStorageKey, string.Join(',', entries));

        _busy.Remove(q.StorylineId);
        DropQuiet(q.StorylineId);
        Snackbar.Add($"“{q.Name}” kept active until your next session.", Severity.Info);
    }

    // ---------------------------------------------------------------------- Shared --

    private void DropQuiet(Guid storylineId)
    {
        if (_view is null)
        {
            return;
        }

        _view = _view with { GoneQuiet = _view.GoneQuiet.Where(x => x.StorylineId != storylineId).ToList() };
        RecomputeHasWork();
        StateHasChanged();
    }

    private void RecomputeHasWork()
    {
        if (_view is null)
        {
            return;
        }

        _view = _view with
        {
            HasWork = _view.GoneQuiet.Count > 0 || _view.CouldNest.Count > 0 || _view.UnparentedArcs.Count > 0
        };
    }
}
