@using System.Globalization
@implements IDisposable
@inject WorldState Worlds
@inject NornisApiClient Api

@* Token and dollar usage. Formerly the /costs page; now a tab on the GM-only Admin page. *@

<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Token and estimated dollar usage.</MudText>

@if (Worlds.Current is null)
{
    <NoWorld />
}
else if (_loading)
{
    <LoadingRows Rows="3" />
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    <div class="nornis-cost-cards">
        @foreach (var (label, summary) in _periods)
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-cost-card">
                <span class="nornis-cost-label">@label</span>
                <span class="nornis-cost-amount">@Money(summary.TotalEstimatedCostUsd)</span>
                <span class="nornis-cost-sub">@Tokens(summary.TotalTokens) tokens · @summary.OperationCount ops</span>
                <span class="nornis-cost-sub">@TokenSplit(summary)</span>
                @if (label == "Today" && _dailyBudgetUsd is { } budget)
                {
                    <MudProgressLinear Value="@BudgetPercent(summary, budget)"
                                       Color="@(BudgetPercent(summary, budget) >= 100 ? Color.Error : Color.Secondary)"
                                       Class="nornis-cost-budget-bar" aria-label="Daily AI budget used" />
                    <span class="nornis-cost-sub">of @Money(budget) daily AI budget</span>
                }
            </MudPaper>
        }
    </div>

    <div class="nornis-cost-range mt-4">
        <span class="nornis-cost-range-label">Breakdown period</span>
        <MudDatePicker Date="_from" DateChanged="OnFromChangedAsync"
                       Label="From" Placeholder="Any" MaxDate="_to"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Class="nornis-cost-range-picker" />
        <MudDatePicker Date="_to" DateChanged="OnToChangedAsync"
                       Label="To" Placeholder="Any" MinDate="_from"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Class="nornis-cost-range-picker" />
        @if (HasRange)
        {
            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="ClearRangeAsync" Disabled="_loadingBreakdowns">
                Clear
            </MudButton>
        }
    </div>

    @if (_loadingBreakdowns)
    {
        <LoadingRows Rows="3" />
    }
    else if (_breakdownError is not null)
    {
        <MudAlert Severity="Severity.Error">@_breakdownError</MudAlert>
    }
    else
    {
        <div class="nornis-triptych">
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
                <div class="nornis-detail-section-title">By operation</div>
                @if (_byOperation.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@EmptyText</MudText>
                }
                @foreach (var o in _byOperation)
                {
                    <div class="nornis-cost-row">
                        <span class="nornis-cost-row-name">@Humanize(o.OperationType)</span>
                        <span class="nornis-list-meta">@TokenSplit(o.Summary)</span>
                        <span class="nornis-cost-row-amount">@Money(o.Summary.TotalEstimatedCostUsd)</span>
                    </div>
                }
            </MudPaper>

            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
                <div class="nornis-detail-section-title">By model</div>
                @if (_byModel.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@EmptyText</MudText>
                }
                @foreach (var m in _byModel)
                {
                    <div class="nornis-cost-row">
                        <span class="nornis-cost-row-name">@m.Model</span>
                        <span class="nornis-list-meta">@TokenSplit(m.Summary)</span>
                        <span class="nornis-cost-row-amount">@Money(m.Summary.TotalEstimatedCostUsd)</span>
                    </div>
                }
            </MudPaper>

            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
                <div class="nornis-detail-section-title">By user</div>
                @if (_byUser.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@EmptyText</MudText>
                }
                @foreach (var u in _byUser)
                {
                    <div class="nornis-cost-row">
                        <span class="nornis-cost-row-name">@u.Username</span>
                        <span class="nornis-list-meta">@TokenSplit(u.Summary)</span>
                        <span class="nornis-cost-row-amount">@Money(u.Summary.TotalEstimatedCostUsd)</span>
                    </div>
                }
            </MudPaper>
        </div>
    }

    @if (_byWorld.Count > 0)
    {
        <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
            <div class="nornis-detail-section-title">Across your worlds</div>
            @foreach (var c in _byWorld)
            {
                <div class="nornis-cost-row">
                    <span class="nornis-cost-row-name">@c.WorldName</span>
                    <span class="nornis-list-meta">@TokenSplit(c.Summary)</span>
                    <span class="nornis-cost-row-amount">@Money(c.Summary.TotalEstimatedCostUsd)</span>
                </div>
            }
        </MudPaper>
    }
}

@code {
    private static readonly CultureInfo Usd = CultureInfo.GetCultureInfo("en-US");

    private bool _loading;
    private bool _loadingBreakdowns;
    private string? _error;
    private string? _breakdownError;

    private (string Label, CostSummary Summary)[] _periods = [];
    private decimal? _dailyBudgetUsd;
    private IReadOnlyList<OperationTypeCost> _byOperation = [];
    private IReadOnlyList<ModelCost> _byModel = [];
    private IReadOnlyList<UserCost> _byUser = [];

    // Cross-world totals (GM-only, all-time). Loaded once with the summary; the by-world
    // endpoint takes no date range. Empty when there are no GM worlds or the call fails, in
    // which case the section is hidden silently.
    private IReadOnlyList<WorldCost> _byWorld = [];

    // Breakdown date range. Null on both ends means all time. The summary cards above
    // always cover their own fixed periods and ignore this.
    private DateTime? _from;
    private DateTime? _to;

    private bool HasRange => _from is not null || _to is not null;

    private string EmptyText => HasRange ? "No usage in this period." : "No usage yet.";

    private DateTimeOffset? FromOffset => _from is { } d ? new DateTimeOffset(d.Date, TimeSpan.Zero) : null;

    // The picked "to" day is inclusive, so extend it to the last tick of that day.
    private DateTimeOffset? ToOffset => _to is { } d ? new DateTimeOffset(d.Date.AddDays(1).AddTicks(-1), TimeSpan.Zero) : null;

    protected override async Task OnInitializedAsync()
    {
        Worlds.Changed += OnWorldChanged;
        await Worlds.EnsureLoadedAsync();
        await LoadAsync();
    }

    private void OnWorldChanged() => InvokeAsync(LoadAsync);

    private async Task OnFromChangedAsync(DateTime? date)
    {
        _from = date;
        await LoadBreakdownsAsync();
    }

    private async Task OnToChangedAsync(DateTime? date)
    {
        _to = date;
        await LoadBreakdownsAsync();
    }

    private async Task ClearRangeAsync()
    {
        _from = null;
        _to = null;
        await LoadBreakdownsAsync();
    }

    private async Task LoadAsync()
    {
        if (Worlds.Current is null)
        {
            _periods = [];
            _error = null;
            StateHasChanged();
            return;
        }

        _loading = true;
        _error = null;
        StateHasChanged();

        var summary = await Api.GetCostSummaryAsync(Worlds.Current.Id);

        _loading = false;

        if (!summary.IsSuccess)
        {
            _error = summary.Error!.Message;
            StateHasChanged();
            return;
        }

        var s = summary.Value!;
        _dailyBudgetUsd = s.DailyBudgetUsd;
        _periods =
        [
            ("Today", s.Today),
            ("This week", s.ThisWeek),
            ("This month", s.ThisMonth),
            ("All time", s.AllTime),
        ];

        // Cross-world totals are not scoped to this world and take no date range, so load
        // them once here. Any failure (including 403 for non-GMs) leaves the list empty and hides
        // the section.
        var byWorld = await Api.GetCostsByWorldAsync();
        _byWorld = byWorld.IsSuccess ? byWorld.Value! : [];

        await LoadBreakdownsAsync();
    }

    private async Task LoadBreakdownsAsync()
    {
        if (Worlds.Current is null)
        {
            return;
        }

        var id = Worlds.Current.Id;
        var (from, to) = (FromOffset, ToOffset);

        _loadingBreakdowns = true;
        _breakdownError = null;
        StateHasChanged();

        // Separate HTTP requests, each with its own server-side DbContext scope — safe to parallelize.
        var operationTask = Api.GetCostsByOperationAsync(id, from, to);
        var modelTask = Api.GetCostsByModelAsync(id, from, to);
        var userTask = Api.GetCostsByUserAsync(id, from, to);
        await Task.WhenAll(operationTask, modelTask, userTask);

        _loadingBreakdowns = false;

        var failure = new[] { operationTask.Result.Error, modelTask.Result.Error, userTask.Result.Error }
            .FirstOrDefault(e => e is not null);
        if (failure is not null)
        {
            _breakdownError = failure.Message;
            StateHasChanged();
            return;
        }

        _byOperation = operationTask.Result.Value ?? [];
        _byModel = modelTask.Result.Value ?? [];
        _byUser = userTask.Result.Value ?? [];

        StateHasChanged();
    }

    private static double BudgetPercent(CostSummary today, decimal budget) =>
        budget <= 0 ? 0 : Math.Min(100, (double)(today.TotalEstimatedCostUsd / budget * 100));

    private static string Money(decimal c) =>
        (c >= 1 ? c.ToString("C2", Usd) : c.ToString("C4", Usd));

    private static string Tokens(long t) => t.ToString("N0", Usd);

    private static string TokenSplit(CostSummary s) =>
        $"{Tokens(s.TotalInputTokens)} in · {Tokens(s.TotalOutputTokens)} out";

    private static string Humanize(string pascal) =>
        string.Concat(pascal.Select((c, i) => i > 0 && char.IsUpper(c) ? " " + c : c.ToString()));

    public void Dispose() => Worlds.Changed -= OnWorldChanged;
}
