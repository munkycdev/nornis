@using System.Globalization
@implements IAsyncDisposable
@inject IJSRuntime JS

@* The Journey: a world map above, a timeline of the party's sessions and imported notes pinned
   to the bottom of the viewport. Two ways in, both projections of this one read model:
     • pick a session on the timeline → the map lights up the places that session visited, and the
       panel on the right lists that session's artifacts alone (never the ones before it);
     • click a place on the map → the panel becomes a tree of the dated notes that visited it, each
       expanding to its artifacts.
   Artifact rows carry the same hover summary tooltip (ArtifactTip) used everywhere else. *@

<div class="nornis-journey">
    <div class="nornis-journey-stage">
        <div class="nornis-journey-map">
            <img src="@Data.ImageUrl" alt="World map" />

            @foreach (var loc in Data.Locations)
            {
                <button type="button" class="nornis-journey-pin @PinClass(loc.ArtifactId)"
                        style="left:@Css(loc.X * 100m)%; top:@Css(loc.Y * 100m)%"
                        data-nornis-tip="@PinTip(loc)"
                        @onclick="() => OnPinClick(loc.ArtifactId)">
                    <span class="nornis-journey-pin-dot"></span>
                    <span class="nornis-journey-pin-label">@PinName(loc)</span>
                </button>
            }
        </div>

        <aside class="nornis-journey-ledger">
            @if (SelectedLocation is { } city)
            {
                @* ---- place mode: a tree of the dated notes that visited this place ---- *@
                <div class="nornis-journey-ledger-eye">
                    Place
                    <button type="button" class="nornis-journey-close" @onclick="ClearLocation"
                            aria-label="Back to the timeline" title="Back to the timeline">&times;</button>
                </div>
                <div class="nornis-journey-ledger-title nornis-serif">@city.Name</div>

                @if (SelectedNotes.Count == 0)
                {
                    <div class="nornis-journey-ledger-empty">No dated note has visited @city.Name yet.</div>
                }
                else
                {
                    <div class="nornis-journey-ledger-meta">
                        <b>@SelectedNotes.Count</b> dated note@(SelectedNotes.Count == 1 ? "" : "s") visited this place
                    </div>
                    <ul class="nornis-journey-tree">
                        @foreach (var note in SelectedNotes)
                        {
                            <li class="nornis-journey-tree-note">
                                <button type="button" class="nornis-journey-tree-head"
                                        @onclick="() => ToggleNote(note.SourceId)">
                                    <span class="nornis-journey-tree-caret @(IsExpanded(note.SourceId) ? "is-open" : "")">&#9656;</span>
                                    <span class="nornis-journey-tree-title">@note.Title</span>
                                    <span class="nornis-journey-tree-date">@note.OccurredAt.ToString("MMM d, yyyy", CultureInfo.InvariantCulture)</span>
                                </button>

                                @if (IsExpanded(note.SourceId))
                                {
                                    @if (note.Highlights.Count == 0)
                                    {
                                        <div class="nornis-journey-tree-empty">No artifacts recorded for this note.</div>
                                    }
                                    else
                                    {
                                        <ul class="nornis-journey-tree-arts">
                                            @foreach (var h in note.Highlights)
                                            {
                                                <li><JourneyArtifactRow Highlight="h" LinkBase="@ArtifactLinkBase" ShowNote="false" /></li>
                                            }
                                        </ul>
                                    }
                                }
                            </li>
                        }
                    </ul>
                }
            }
            else if (CurrentStop is { } stop)
            {
                @* ---- session mode: this stop's artifacts alone ---- *@
                <div class="nornis-journey-ledger-eye">@(_stopIndex + 1) <span>of @Data.Stops.Count</span></div>
                <a class="nornis-journey-ledger-title nornis-serif" href="@($"{SourceLinkBase}/{stop.SourceId}")">@stop.Title</a>
                <div class="nornis-journey-ledger-meta">
                    <b>@stop.OccurredAt.ToString("MMM d, yyyy", CultureInfo.InvariantCulture)</b>
                    @if (VisitedNames(stop) is { Length: > 0 } names)
                    {
                        <span> · @names</span>
                    }
                </div>

                @if (stop.Highlights.Count == 0)
                {
                    <div class="nornis-journey-ledger-empty">No artifacts were recorded for this entry.</div>
                }
                else
                {
                    <ul class="nornis-journey-hl">
                        @foreach (var h in stop.Highlights)
                        {
                            <li><JourneyArtifactRow Highlight="h" LinkBase="@ArtifactLinkBase" ShowNote="true" /></li>
                        }
                    </ul>
                }
            }
            else
            {
                <div class="nornis-journey-ledger-eye">The timeline</div>
                <div class="nornis-journey-ledger-empty">
                    No dated session or imported note yet. Give one an "occurred at" date to place it
                    on the timeline.
                </div>
            }
        </aside>
    </div>

    @if (Data.Stops.Count > 0)
    {
        <div class="nornis-journey-scrub">
            <div class="nornis-journey-scrub-head">
                <span class="nornis-journey-scrub-label">Sessions &amp; imported notes · @RangeLabel</span>
                <span class="nornis-journey-scrub-hint">click an entry, drag the marker, or use ← →</span>
            </div>

            <div id="@_railId" class="nornis-journey-rail">
                <div class="nornis-journey-rail-track"></div>

                @foreach (var month in MonthTicks)
                {
                    <span class="nornis-journey-month" style="left:@Css(Pct(month))%">
                        @month.ToString(month.Month == 1 ? "MMM yy" : "MMM", CultureInfo.InvariantCulture)
                    </span>
                }

                @for (var i = 0; i < Data.Stops.Count; i++)
                {
                    var idx = i;
                    var node = Data.Stops[idx];
                    <button type="button" class="nornis-journey-node @NodeClass(idx)"
                            style="left:@Css(Pct(node.OccurredAt))%"
                            data-nornis-tip="@StopTip(node, idx)"
                            @onclick="() => SetStop(idx)"></button>
                }

                @if (_selectedLocationId is null)
                {
                    <div class="nornis-journey-playhead" style="left:@Css(CurrentPct)%">
                        <div class="nornis-journey-playhead-line"></div>
                        <div class="nornis-journey-handle" tabindex="0" role="slider"
                             aria-label="Timeline marker"
                             aria-valuemin="1" aria-valuemax="@Data.Stops.Count" aria-valuenow="@(_stopIndex + 1)"
                             aria-valuetext="@(CurrentStop?.Title)"
                             @onkeydown="OnHandleKey"></div>
                    </div>
                }
            </div>

            <div class="nornis-journey-foot">
                @if (SelectedLocation is { } place)
                {
                    <span class="nornis-journey-legend">Highlighted entries visited <b>@place.Name</b> — pick one to leave this place.</span>
                }
                else
                {
                    <span class="nornis-journey-legend">Showing entry <b>@(_stopIndex + 1)</b> of @Data.Stops.Count.</span>
                }
                @if (Data.UndatedSessionCount > 0)
                {
                    <span class="nornis-journey-note">
                        @Data.UndatedSessionCount undated @(Data.UndatedSessionCount == 1 ? "entry is" : "entries are") not placed on the timeline
                    </span>
                }
            </div>
        </div>
    }
    else if (Data.UndatedSessionCount > 0)
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
            @Data.UndatedSessionCount @(Data.UndatedSessionCount == 1 ? "entry has" : "entries have") no "occurred at" date and cannot be placed on the timeline.
        </MudText>
    }
</div>

@code {
    [Parameter, EditorRequired] public JourneyDto Data { get; set; } = default!;

    /// <summary>Route prefixes for links; the public pages could override these.</summary>
    [Parameter] public string ArtifactLinkBase { get; set; } = "/artifacts";
    [Parameter] public string SourceLinkBase { get; set; } = "/sources";

    private readonly string _railId = $"nornis-journey-{Guid.NewGuid():N}";
    private DotNetObjectReference<JourneyMap>? _selfRef;
    private bool _jsInitialized;

    // The two mutually-exclusive selections. _stopIndex is the timeline entry in focus; a non-null
    // _selectedLocationId switches the right panel to that place's tree of notes.
    private int _stopIndex;
    private bool _stopInitialized;
    private Guid? _selectedLocationId;
    private readonly HashSet<Guid> _collapsedNotes = new();

    private JourneyStopDto? CurrentStop => Data.Stops.Count > 0 ? Data.Stops[_stopIndex] : null;

    private JourneyLocationDto? SelectedLocation =>
        _selectedLocationId is { } id ? Data.Locations.FirstOrDefault(l => l.ArtifactId == id) : null;

    protected override void OnParametersSet()
    {
        if (_stopIndex > Data.Stops.Count - 1)
        {
            _stopIndex = Math.Max(0, Data.Stops.Count - 1);
        }
        // Open on the most recent entry — "where the party is now" — but only once, so a data
        // refresh doesn't yank the user's current selection.
        if (!_stopInitialized && Data.Stops.Count > 0)
        {
            _stopIndex = Data.Stops.Count - 1;
            _stopInitialized = true;
        }
        // A place that is no longer a visible pin (data changed under us) drops its selection.
        if (_selectedLocationId is { } sel && Data.Locations.All(l => l.ArtifactId != sel))
        {
            _selectedLocationId = null;
        }
    }

    // ------------------------------------------------------------- timeline --

    private void SetStop(int index)
    {
        var clamped = Math.Clamp(index, 0, Math.Max(0, Data.Stops.Count - 1));
        var changed = clamped != _stopIndex || _selectedLocationId is not null;
        _stopIndex = clamped;
        _selectedLocationId = null; // choosing an entry leaves place mode
        if (changed)
        {
            StateHasChanged();
        }
    }

    [JSInvokable]
    public Task OnScrubFraction(double fraction)
    {
        if (Data.Stops.Count == 0)
        {
            return Task.CompletedTask;
        }

        // Snap the drag position to the nearest dated stop.
        var targetPct = Math.Clamp(fraction, 0, 1) * 100.0;
        var nearest = 0;
        var bestGap = double.MaxValue;
        for (var i = 0; i < Data.Stops.Count; i++)
        {
            var gap = Math.Abs(Pct(Data.Stops[i].OccurredAt) - targetPct);
            if (gap < bestGap)
            {
                bestGap = gap;
                nearest = i;
            }
        }
        return InvokeAsync(() => SetStop(nearest));
    }

    private void OnHandleKey(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowRight" or "ArrowUp": SetStop(_stopIndex + 1); break;
            case "ArrowLeft" or "ArrowDown": SetStop(_stopIndex - 1); break;
            case "Home": SetStop(0); break;
            case "End": SetStop(Data.Stops.Count - 1); break;
        }
    }

    // ------------------------------------------------------------- place mode --

    private void OnPinClick(Guid artifactId)
    {
        // Toggle: clicking the open place closes it back to the timeline.
        if (_selectedLocationId == artifactId)
        {
            _selectedLocationId = null;
        }
        else
        {
            _selectedLocationId = artifactId;
            _collapsedNotes.Clear(); // a fresh place opens with every note expanded
        }
        StateHasChanged();
    }

    private void ClearLocation()
    {
        _selectedLocationId = null;
        StateHasChanged();
    }

    /// <summary>The dated notes that visited a place, oldest first — the place's own story.</summary>
    private IReadOnlyList<JourneyStopDto> NotesForLocation(Guid locationId) =>
        Data.Stops.Where(s => s.VisitedLocationIds.Contains(locationId)).ToList();

    /// <summary>The notes for the place currently open in the panel (empty when none is).</summary>
    private IReadOnlyList<JourneyStopDto> SelectedNotes =>
        SelectedLocation is { } c ? NotesForLocation(c.ArtifactId) : [];

    private bool IsExpanded(Guid sourceId) => !_collapsedNotes.Contains(sourceId);

    private void ToggleNote(Guid sourceId)
    {
        if (!_collapsedNotes.Add(sourceId))
        {
            _collapsedNotes.Remove(sourceId);
        }
    }

    // ------------------------------------------------------------- pins & nodes --

    private string PinClass(Guid artifactId)
    {
        if (_selectedLocationId == artifactId)
        {
            return "is-selected";
        }
        if (_selectedLocationId is null && CurrentStop?.VisitedLocationIds.Contains(artifactId) == true)
        {
            return "is-visited";
        }
        return string.Empty;
    }

    private string NodeClass(int idx)
    {
        if (_selectedLocationId is { } locId)
        {
            return Data.Stops[idx].VisitedLocationIds.Contains(locId) ? "is-visited" : string.Empty;
        }
        return idx == _stopIndex ? "is-current" : string.Empty;
    }

    private static string PinName(JourneyLocationDto loc) =>
        string.IsNullOrWhiteSpace(loc.Label) ? loc.Name : loc.Label;

    private string PinTip(JourneyLocationDto loc) => $"{loc.Name}\nClick for the notes that visited it";

    private string StopTip(JourneyStopDto stop, int idx) =>
        $"{idx + 1}. {stop.Title}\n{stop.OccurredAt.ToString("MMM d, yyyy", CultureInfo.InvariantCulture)}";

    // ------------------------------------------------------------- ledger bits --

    private string? VisitedNames(JourneyStopDto stop)
    {
        var byId = Data.Locations.ToDictionary(l => l.ArtifactId, l => l.Name);
        var names = stop.VisitedLocationIds
            .Where(byId.ContainsKey)
            .Select(id => byId[id])
            .ToList();
        return names.Count > 0 ? string.Join(" · ", names) : null;
    }

    // ------------------------------------------------------------- JS lifecycle --

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_jsInitialized && Data.Stops.Count > 0)
        {
            _jsInitialized = true;
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("nornisJourney.init", _railId, _selfRef);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("nornisJourney.destroy", _railId);
            }
            catch (JSDisconnectedException)
            {
                // Circuit already gone — the browser cleaned up with the page.
            }
        }
        _selfRef?.Dispose();
    }

    // ------------------------------------------------------------- axis --

    private DateTimeOffset MinDate => Data.Stops[0].OccurredAt - PadSpan;

    private DateTimeOffset MaxDate => Data.Stops[^1].OccurredAt + PadSpan;

    // A little breathing room at each end so the first/last ticks aren't on the edge.
    private TimeSpan PadSpan
    {
        get
        {
            var span = Data.Stops[^1].OccurredAt - Data.Stops[0].OccurredAt;
            var days = Math.Max(3, span.TotalDays * 0.06);
            return TimeSpan.FromDays(days);
        }
    }

    private double Pct(DateTimeOffset date)
    {
        var total = (MaxDate - MinDate).TotalDays;
        if (total <= 0)
        {
            return 50;
        }
        return Math.Clamp((date - MinDate).TotalDays / total * 100.0, 0, 100);
    }

    private double CurrentPct => CurrentStop is { } s ? Pct(s.OccurredAt) : 0;

    private IEnumerable<DateTimeOffset> MonthTicks
    {
        get
        {
            var tick = new DateTimeOffset(MinDate.Year, MinDate.Month, 1, 0, 0, 0, MinDate.Offset).AddMonths(1);
            while (tick <= MaxDate)
            {
                yield return tick;
                tick = tick.AddMonths(1);
            }
        }
    }

    private string RangeLabel =>
        $"{Data.Stops[0].OccurredAt.ToString("MMM yyyy", CultureInfo.InvariantCulture)} – {Data.Stops[^1].OccurredAt.ToString("MMM yyyy", CultureInfo.InvariantCulture)}";

    // Invariant culture matters: a comma decimal separator breaks inline CSS.
    private static string Css(decimal v) => v.ToString("0.####", CultureInfo.InvariantCulture);
    private static string Css(double v) => v.ToString("0.####", CultureInfo.InvariantCulture);
}
