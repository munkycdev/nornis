@inject NornisApiClient Api

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_name"
                      Label="Artifact name"
                      Required="true"
                      Immediate="true"
                      MaxLength="200"
                      Variant="Variant.Outlined" />
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="Submit" Disabled="_busy">
            Rename
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private MudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public Guid WorldId { get; set; }
    [Parameter] public Guid ArtifactId { get; set; }
    [Parameter] public string CurrentName { get; set; } = string.Empty;

    private string _name = string.Empty;
    private bool _busy;
    private string? _error;

    protected override void OnInitialized() => _name = CurrentName;

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _error = "Artifact name is required.";
            return;
        }

        _busy = true;
        _error = null;

        var result = await Api.RenameArtifactAsync(WorldId, ArtifactId, _name.Trim());

        _busy = false;

        if (!result.IsSuccess)
        {
            _error = result.Error!.Message;
            return;
        }

        MudDialog.Close(DialogResult.Ok(result.Value!));
    }

    private void Cancel() => MudDialog.Cancel();
}
