@page "/"
@using System.Text.Json
@implements IDisposable
@inject CampaignState Campaigns
@inject NornisApiClient Api

<PageTitle>Ask the Loremaster — Nornis</PageTitle>

@if (Campaigns.Current is null)
{
    <NoCampaign />
}
else
{
    <div class="nornis-dashboard">
        <div class="nornis-dashboard-main">

            <MudPaper Elevation="0" Class="nornis-card nornis-hero">
                <div class="nornis-hero-mark">N</div>
                <div class="nornis-hero-title">Ask the Loremaster</div>
                <div class="nornis-hero-sub">Your campaign. Remembered. Understood.</div>

                <div class="nornis-ask">
                    <MudTextField T="string"
                                  Class="nornis-ask-input"
                                  Placeholder="What should I remember before tonight?"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   aria-label="Ask" />
                </div>

                <div class="nornis-suggestions">
                    @foreach (var s in _suggestions)
                    {
                        <button type="button" class="nornis-suggestion">
                            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Secondary" Size="Size.Small" />
                            <span>@s</span>
                        </button>
                    }
                </div>
            </MudPaper>

            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
                <div class="nornis-capture-head">
                    <div class="nornis-capture-icon">
                        <MudIcon Icon="@Icons.Material.Outlined.Create" />
                    </div>
                    <div>
                        <div class="nornis-card-title">Tell Nornis what happened</div>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Add session notes, transcripts, images, or links. Nornis will do the rest.
                        </MudText>
                    </div>
                </div>

                <div class="nornis-capture-tiles">
                    @foreach (var tile in _captureTiles)
                    {
                        <a href="/capture" class="nornis-tile">
                            <span class="nornis-tile-title">
                                <MudIcon Icon="@tile.Icon" Color="Color.Primary" Size="Size.Small" />
                                @tile.Title
                            </span>
                            <span class="nornis-tile-sub">@tile.Subtitle</span>
                        </a>
                    }
                </div>

                <div class="nornis-capture-foot">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" />
                    All inputs are private to your campaign
                </div>
            </MudPaper>

            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Secondary" />
            }
            else
            {
                <div class="nornis-triptych">
                    <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
                        <div class="nornis-card-header">
                            <span class="nornis-card-title">Active Storylines</span>
                            <a href="/storylines" class="nornis-viewall">View all <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" /></a>
                        </div>
                        @if (_storylines.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">No storylines yet.</MudText>
                        }
                        @foreach (var item in _storylines)
                        {
                            <div class="nornis-list-row">
                                <div class="nornis-list-thumb"><MudIcon Icon="@Icons.Material.Outlined.Hub" Size="Size.Small" /></div>
                                <div class="nornis-list-body">
                                    <div class="nornis-list-title">@item.Name</div>
                                    <div class="nornis-list-sub">@item.Status</div>
                                </div>
                                @if (item.Status == "Dormant")
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Color="Color.Warning" Size="Size.Small" />
                                }
                            </div>
                        }
                    </MudPaper>

                    <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
                        <div class="nornis-card-header">
                            <span class="nornis-card-title">Canon Updates</span>
                            <a href="/canon" class="nornis-viewall">View all <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" /></a>
                        </div>
                        @if (_canonFacts.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">No canon yet.</MudText>
                        }
                        @foreach (var fact in _canonFacts)
                        {
                            <div class="nornis-list-row">
                                <div class="nornis-list-thumb"><MudIcon Icon="@Icons.Material.Outlined.Article" Size="Size.Small" /></div>
                                <div class="nornis-list-body">
                                    <div class="nornis-list-title">@fact.ArtifactName</div>
                                    <div class="nornis-list-sub">@fact.Label@(fact.Detail is null ? "" : $": {fact.Detail}")</div>
                                </div>
                                <span class="nornis-list-meta">@Ago(fact.UpdatedAt)</span>
                            </div>
                        }
                    </MudPaper>

                    <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
                        <div class="nornis-card-header">
                            <span class="nornis-card-title">Recently Active Artifacts</span>
                            <a href="/artifacts" class="nornis-viewall">View all <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" /></a>
                        </div>
                        @if (_recentArtifacts.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">No artifacts yet.</MudText>
                        }
                        @foreach (var item in _recentArtifacts)
                        {
                            <div class="nornis-list-row">
                                <div class="nornis-list-thumb"><MudIcon Icon="@TypeIcon(item.Type)" Size="Size.Small" /></div>
                                <div class="nornis-list-body">
                                    <div class="nornis-list-title">@item.Name</div>
                                    <div class="nornis-list-sub">@item.Type · updated @Ago(item.UpdatedAt)</div>
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Color="Color.Tertiary" aria-label="More" />
                            </div>
                        }
                    </MudPaper>
                </div>
            }
        </div>

        <div class="nornis-rail">
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
                <div class="nornis-card-header">
                    <span class="nornis-card-title">Continuity Health</span>
                    <MudTooltip Text="Preview — not yet computed from live data.">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Color="Color.Tertiary" Size="Size.Small" />
                    </MudTooltip>
                </div>
                <div class="nornis-health-row">
                    <div class="nornis-ring">
                        <MudProgressCircular Value="87" Min="0" Max="100" Color="Color.Success" Size="Size.Large" StrokeWidth="5" />
                        <div class="nornis-ring-value">
                            <div class="nornis-health-figure">
                                <span class="nornis-health-pct">87%</span>
                                <span class="nornis-health-state">Strong</span>
                            </div>
                        </div>
                    </div>
                    <div class="flex-grow-1">
                        @foreach (var m in _healthMetrics)
                        {
                            <div class="nornis-metric">
                                <span class="nornis-metric-label">@m.Label</span>
                                <span class="nornis-metric-value">@m.Value%</span>
                            </div>
                        }
                    </div>
                </div>
            </MudPaper>

            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
                <div class="nornis-card-header">
                    <span class="nornis-card-title">Review Queue</span>
                    <span class="nornis-count-badge">@_proposals.Count</span>
                </div>
                @if (_proposals.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Nothing to review.</MudText>
                }
                @foreach (var item in _proposals)
                {
                    <div class="nornis-list-row">
                        <div class="nornis-list-thumb"><MudIcon Icon="@Icons.Material.Outlined.Description" Size="Size.Small" /></div>
                        <div class="nornis-list-body">
                            <div class="nornis-list-title">@ProposalName(item)</div>
                            <div class="nornis-list-sub">@item.Rationale</div>
                        </div>
                        <span class="nornis-dot @DotClass(item)"></span>
                    </div>
                }
                <div class="nornis-card-foot">
                    <a href="/review" class="nornis-viewall">Open Review Queue <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" /></a>
                </div>
            </MudPaper>

            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
                <div class="nornis-card-header">
                    <span class="nornis-card-title">Recent Changes</span>
                </div>
                @if (_canonRelationships.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No recent changes.</MudText>
                }
                @foreach (var rel in _canonRelationships)
                {
                    <div class="nornis-list-row">
                        <div class="nornis-list-thumb"><MudIcon Icon="@Icons.Material.Outlined.Hub" Size="Size.Small" /></div>
                        <div class="nornis-list-body">
                            <div class="nornis-list-title">@rel.ArtifactName</div>
                            <div class="nornis-list-sub">@rel.Label @rel.OtherArtifactName</div>
                        </div>
                        <span class="nornis-list-meta">@Ago(rel.UpdatedAt)</span>
                    </div>
                }
                <div class="nornis-card-foot">
                    <a href="/canon" class="nornis-viewall">View all changes <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" /></a>
                </div>
            </MudPaper>
        </div>
    </div>
}

@code {
    private bool _loading;

    private IReadOnlyList<ArtifactListItem> _storylines = [];
    private IReadOnlyList<ArtifactListItem> _recentArtifacts = [];
    private IReadOnlyList<CanonEntry> _canonFacts = [];
    private IReadOnlyList<CanonEntry> _canonRelationships = [];
    private IReadOnlyList<ReviewProposal> _proposals = [];

    private readonly string[] _suggestions =
    [
        "What changed last session?",
        "What storylines are unresolved?",
        "What does Tavrin know about Captain Voss?",
        "What should I prep next?",
    ];

    private record Tile(string Title, string Subtitle, string Icon);
    private readonly Tile[] _captureTiles =
    [
        new("Write Notes", "Start typing…", Icons.Material.Outlined.Create),
        new("Paste Transcript", "From chat or audio", Icons.Material.Outlined.ContentPaste),
        new("Upload Image", "Maps, notes, assets", Icons.Material.Outlined.Image),
        new("Handwritten Note", "Upload or scan", Icons.Material.Outlined.Gesture),
        new("Add Link", "Article, wiki, video", Icons.Material.Outlined.Link),
    ];

    // Static preview — no analytics endpoint exists yet.
    private record Metric(string Label, int Value);
    private readonly Metric[] _healthMetrics =
    [
        new("Consistency", 91),
        new("Completeness", 82),
        new("Clarity", 86),
        new("Recency", 89),
    ];

    protected override async Task OnInitializedAsync()
    {
        Campaigns.Changed += OnCampaignChanged;
        await Campaigns.EnsureLoadedAsync();
        await LoadDashboardAsync();
    }

    private void OnCampaignChanged() => InvokeAsync(LoadDashboardAsync);

    private async Task LoadDashboardAsync()
    {
        if (Campaigns.Current is null)
        {
            StateHasChanged();
            return;
        }

        var id = Campaigns.Current.Id;
        _loading = true;
        StateHasChanged();

        var storylinesTask = Api.GetStorylinesAsync(id);
        var artifactsTask = Api.GetArtifactsAsync(id);
        var canonTask = Api.GetCanonAsync(id);
        var reviewTask = Api.GetReviewQueueAsync(id);
        await Task.WhenAll(storylinesTask, artifactsTask, canonTask, reviewTask);

        _storylines = storylinesTask.Result.Value ?? [];

        _recentArtifacts = (artifactsTask.Result.Value ?? [])
            .Where(a => a.Type != "Storyline")
            .Take(4)
            .ToList();

        var canon = canonTask.Result.Value ?? [];
        _canonFacts = canon.Where(c => c.Kind == "Fact").Take(3).ToList();
        _canonRelationships = canon.Where(c => c.Kind == "Relationship").Take(3).ToList();

        _proposals = reviewTask.Result.Value?.Proposals ?? [];

        _loading = false;
        StateHasChanged();
    }

    private static string ProposalName(ReviewProposal p)
    {
        try
        {
            using var doc = JsonDocument.Parse(p.ProposedValueJson);
            if (doc.RootElement.TryGetProperty("Name", out var name) && name.ValueKind == JsonValueKind.String)
            {
                return name.GetString()!;
            }
        }
        catch (JsonException)
        {
            // Fall through to a humanized change type.
        }
        return Humanize(p.ChangeType);
    }

    private static string DotClass(ReviewProposal p) =>
        p.Rationale?.Contains("conflict", StringComparison.OrdinalIgnoreCase) == true
            ? "nornis-dot-error"
            : "nornis-dot-warning";

    private static string TypeIcon(string type) => type switch
    {
        "Character" => Icons.Material.Outlined.Person,
        "Location" => Icons.Material.Outlined.Place,
        "Item" => Icons.Material.Outlined.Diamond,
        "Faction" => Icons.Material.Outlined.Groups,
        "Event" => Icons.Material.Outlined.Event,
        "Storyline" => Icons.Material.Outlined.Hub,
        _ => Icons.Material.Outlined.Category,
    };

    private static string Ago(DateTimeOffset t)
    {
        var d = DateTimeOffset.UtcNow - t.ToUniversalTime();
        if (d.TotalMinutes < 60) return $"{Math.Max(1, (int)d.TotalMinutes)}m ago";
        if (d.TotalHours < 24) return $"{(int)d.TotalHours}h ago";
        if (d.TotalDays < 2) return "Yesterday";
        return $"{(int)d.TotalDays}d ago";
    }

    private static string Humanize(string pascal) =>
        string.Concat(pascal.Select((c, i) => i > 0 && char.IsUpper(c) ? " " + c : c.ToString()));

    public void Dispose() => Campaigns.Changed -= OnCampaignChanged;
}
