@page "/canon"
@implements IDisposable
@inject WorldState Worlds
@inject NornisApiClient Api

<PageTitle>Canon — Nornis</PageTitle>

<div class="nornis-narrow">
    <MudText Typo="Typo.h4" Class="nornis-serif">Canon</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">What is remembered, endures.</MudText>

    @if (Worlds.Current is null)
    {
        <NoWorld />
    }
    else if (_loading)
    {
        <LoadingRows Rows="3" />
    }
    else if (_error is not null)
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else if (_entries.Count == 0)
    {
        <MudPaper Elevation="0" Class="nornis-card nornis-card-pad nornis-comingsoon">
            <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Size="Size.Large" Class="nornis-comingsoon-icon" />
            <MudText Typo="Typo.h5" Class="nornis-serif">No canon yet</MudText>
            <MudText Typo="Typo.body1" Class="nornis-comingsoon-text mt-2">
                As you accept facts and relationships, they settle here as the durable truth-state of your world.
            </MudText>
        </MudPaper>
    }
    else
    {
        <MudTextField T="string" @bind-Value="_search" Immediate="true" Clearable="true"
                      Placeholder="Search canon — artifact, fact, or relationship text…"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />

        @foreach (var tier in _sections)
        {
            var entries = FilteredEntries.Where(e => e.TruthState == tier.TruthState).ToList();
            if (entries.Count > 0)
            {
                var sectionOpen = Searching || !_collapsed.Contains(tier.TruthState);
                <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                    <div class="nornis-detail-section-title nornis-tree-header" @onclick="() => ToggleSection(tier.TruthState)">
                        <MudIcon Icon="@(sectionOpen ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)" Size="Size.Small" />
                        <MudIcon Icon="@tier.Icon" Size="Size.Small" Color="@tier.Color" Class="mr-1" />
                        @tier.Title
                        <span class="nornis-list-meta ml-2">@entries.Count</span>
                    </div>
                    @if (sectionOpen)
                    {
                        @foreach (var artifactGroup in entries.GroupBy(e => (e.ArtifactId, e.ArtifactName)).OrderBy(g => g.Key.ArtifactName))
                        {
                            <div class="nornis-canon-artifact">
                                <a href="@($"/artifacts/{artifactGroup.Key.ArtifactId}")" class="nornis-link nornis-canon-artifact-name">@artifactGroup.Key.ArtifactName</a>
                                <span class="nornis-list-meta">@artifactGroup.Count()</span>
                            </div>
                            @foreach (var e in artifactGroup)
                            {
                                <div class="nornis-list-row nornis-canon-entry">
                                    <div class="nornis-list-thumb">
                                        <MudIcon Icon="@(e.Kind == "Relationship" ? Icons.Material.Outlined.Hub : Icons.Material.Outlined.Article)" Size="Size.Small" />
                                    </div>
                                    <div class="nornis-list-body">
                                        <div class="nornis-list-sub">@Statement(e)</div>
                                    </div>
                                    @if (e.Visibility == "GMOnly")
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">GM only</MudChip>
                                    }
                                    <span class="nornis-list-meta">@Ago(e.UpdatedAt)</span>
                                </div>
                            }
                        }
                    }
                </MudPaper>
            }
        }
    }
</div>

@code {
    private bool _loading;
    private string? _error;
    private string _search = string.Empty;
    private readonly HashSet<string> _collapsed = [];
    private IReadOnlyList<CanonEntry> _entries = [];

    private bool Searching => !string.IsNullOrWhiteSpace(_search);

    private IEnumerable<CanonEntry> FilteredEntries =>
        !Searching
            ? _entries
            : _entries.Where(e =>
                e.ArtifactName.Contains(_search, StringComparison.OrdinalIgnoreCase)
                || (e.OtherArtifactName?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
                || e.Label.Contains(_search, StringComparison.OrdinalIgnoreCase)
                || (e.Detail?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false));

    private void ToggleSection(string truthState)
    {
        if (!_collapsed.Remove(truthState))
        {
            _collapsed.Add(truthState);
        }
    }

    private record Section(string TruthState, string Title, string Icon, Color Color);
    private readonly Section[] _sections =
    [
        new("Confirmed", "Confirmed world state", Icons.Material.Outlined.Verified, Color.Success),
        new("Likely", "Likely", Icons.Material.Outlined.TrendingUp, Color.Info),
        new("Rumor", "Rumors", Icons.Material.Outlined.Forum, Color.Warning),
        new("Disputed", "Disputed", Icons.Material.Outlined.Gavel, Color.Error),
        new("False", "Known false", Icons.Material.Outlined.Block, Color.Error),
        new("Hidden", "Hidden — GM only", Icons.Material.Outlined.VisibilityOff, Color.Secondary),
    ];

    protected override async Task OnInitializedAsync()
    {
        Worlds.Changed += OnWorldChanged;
        await Worlds.EnsureLoadedAsync();
        await LoadAsync();
    }

    private void OnWorldChanged() => InvokeAsync(LoadAsync);

    private async Task LoadAsync()
    {
        if (Worlds.Current is null)
        {
            _entries = [];
            _error = null;
            StateHasChanged();
            return;
        }

        _loading = true;
        _error = null;
        StateHasChanged();

        var result = await Api.GetCanonAsync(Worlds.Current.Id);

        _loading = false;
        if (result.IsSuccess)
        {
            _entries = result.Value!;
        }
        else
        {
            _error = result.Error!.Message;
            _entries = [];
        }
        StateHasChanged();
    }

    private static string Statement(CanonEntry e) =>
        e.Kind == "Relationship"
            ? $"{e.Label} {e.OtherArtifactName}".Trim()
            : e.Detail is null ? e.Label : $"{e.Label}: {e.Detail}";

    private static string Ago(DateTimeOffset t)
    {
        var d = DateTimeOffset.UtcNow - t.ToUniversalTime();
        if (d.TotalMinutes < 60) return $"{Math.Max(1, (int)d.TotalMinutes)}m ago";
        if (d.TotalHours < 24) return $"{(int)d.TotalHours}h ago";
        if (d.TotalDays < 2) return "Yesterday";
        return $"{(int)d.TotalDays}d ago";
    }

    public void Dispose() => Worlds.Changed -= OnWorldChanged;
}
