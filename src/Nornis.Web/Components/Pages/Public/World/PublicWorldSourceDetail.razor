@page "/w/{Slug}/sources/{SourceId:guid}"
@layout PublicLayout
@inject NornisApiClient Api

<PageTitle>@(_source?.Title ?? "Session") — Nornis</PageTitle>

<PublicWorldFrame Slug="@Slug" Active="sources">
    <ChildContent Context="world">
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
                   Color="Color.Default" Href="@($"/w/{Slug}/sources")" Class="mb-3">Sessions</MudButton>

        @if (_loading)
        {
            <LoadingRows Rows="3" />
        }
        else if (_source is null)
        {
            <MudAlert Severity="Severity.Warning">This chronicle doesn't exist or isn't public.</MudAlert>
        }
        else
        {
            <div class="nornis-detail-head">
                <div class="nornis-list-thumb"><MudIcon Icon="@Icons.Material.Outlined.Description" /></div>
                <div class="flex-grow-1">
                    <MudText Typo="Typo.h4" Class="nornis-serif">@_source.Title</MudText>
                    <div class="nornis-detail-chips">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">@SourceTypeDisplay.Label(_source.Type)</MudChip>
                        @if (_source.OccurredAt is not null)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">@_source.OccurredAt.Value.LocalDateTime.ToString("d MMM yyyy")</MudChip>
                        }
                        @if (_source.CampaignName is not null)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Tertiary">@_source.CampaignName</MudChip>
                        }
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_source.Body))
            {
                <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                    <NotesEditor @key="_source.Id" ReadOnly="true"
                                 InitialHtml="@Nornis.Web.Services.MarkdownRenderer.ToHtml(_source.Body).Value" />
                </MudPaper>
            }
            @if (!string.IsNullOrWhiteSpace(_source.Uri))
            {
                <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                    <a href="@_source.Uri" target="_blank" rel="noopener noreferrer" class="nornis-link">@_source.Uri</a>
                </MudPaper>
            }

            @if (_locations.Count > 0)
            {
                <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                    <div class="nornis-detail-section-title">Locations</div>
                    <div class="nornis-detail-chips">
                        @foreach (var loc in _locations)
                        {
                            <ArtifactTip Name="@loc.Name" Summary="@loc.Summary">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Tertiary"
                                         Icon="@Icons.Material.Outlined.Place"
                                         Href="@($"/w/{Slug}/artifacts/{loc.ArtifactId}")">@loc.Name</MudChip>
                            </ArtifactTip>
                        }
                    </div>
                </MudPaper>
            }

            @if (_source.ProcessingStatus == "Processed" && _source.ExtractionEnabled)
            {
                <SourceKnowledgePanel Knowledge="_knowledge"
                                      CanRemoveFacts="false"
                                      ArtifactLinkBase="@($"/w/{Slug}/artifacts")" />
            }
        }
    </ChildContent>
</PublicWorldFrame>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
    [Parameter] public Guid SourceId { get; set; }

    private bool _loading = true;
    private SourceDetailDto? _source;
    private SourceKnowledgeDto? _knowledge;
    private IReadOnlyList<LinkedLocationDto> _locations = [];
    private (string Slug, Guid Id)? _loadedKey;

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedKey == (Slug, SourceId))
        {
            return;
        }
        _loadedKey = (Slug, SourceId);
        _loading = true;
        _knowledge = null;
        _locations = [];
        var result = await Api.GetPublicSourceAsync(Slug, SourceId);
        _source = result.IsSuccess ? result.Value : null;
        _loading = false;

        if (_source is not null)
        {
            StateHasChanged();
            var locations = await Api.GetPublicSourceLocationsAsync(Slug, SourceId);
            _locations = locations.IsSuccess ? locations.Value! : [];

            if (_source.ProcessingStatus == "Processed" && _source.ExtractionEnabled)
            {
                var knowledge = await Api.GetPublicSourceKnowledgeAsync(Slug, SourceId);
                _knowledge = knowledge.IsSuccess ? knowledge.Value : new SourceKnowledgeDto([], [], []);
            }
        }
    }

}
