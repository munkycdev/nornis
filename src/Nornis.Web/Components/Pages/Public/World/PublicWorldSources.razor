@page "/w/{Slug}/sources"
@layout PublicLayout
@inject NornisApiClient Api

<PageTitle>Sessions — Nornis</PageTitle>

<PublicWorldFrame Slug="@Slug" Active="sources">
    <ChildContent Context="world">
        @if (_sources is null)
        {
            <LoadingRows Rows="3" />
        }
        else if (_sources.Count == 0)
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad nornis-comingsoon">
                <MudIcon Icon="@Icons.Material.Outlined.Layers" Size="Size.Large" Class="nornis-comingsoon-icon" />
                <MudText Typo="Typo.h5" Class="nornis-serif">No chronicles yet</MudText>
                <MudText Typo="Typo.body1" Class="nornis-comingsoon-text mt-2">
                    Session notes and journals will appear here as the game master shares them.
                </MudText>
            </MudPaper>
        }
        else
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
                @foreach (var source in _sources)
                {
                    <a href="@($"/w/{Slug}/sources/{source.Id}")" class="nornis-list-row nornis-list-link">
                        <div class="nornis-list-thumb">
                            <MudIcon Icon="@Icons.Material.Outlined.Description" Size="Size.Small" />
                        </div>
                        <div class="nornis-list-body">
                            <div class="nornis-list-title">@source.Title</div>
                            <div class="nornis-list-sub">@SourceTypeDisplay.Label(source.Type) · @((source.OccurredAt ?? source.CreatedAt).LocalDateTime.ToString("d MMM yyyy"))</div>
                        </div>
                        @if (source.CampaignName is not null)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Tertiary">@source.CampaignName</MudChip>
                        }
                    </a>
                }
            </MudPaper>
        }
    </ChildContent>
</PublicWorldFrame>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private IReadOnlyList<SourceListItem>? _sources;
    private string? _loadedSlug;

    protected override async Task OnParametersSetAsync()
    {
        if (Slug == _loadedSlug)
        {
            return;
        }
        _loadedSlug = Slug;
        var result = await Api.GetPublicSourcesAsync(Slug);
        _sources = result.IsSuccess ? result.Value : [];
    }

}
