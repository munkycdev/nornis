@page "/w/{Slug}/timeline"
@layout PublicLayout
@inject NornisApiClient Api

<PageTitle>Timeline — Nornis</PageTitle>

@* Two views of the same span of play: the storyline chart and the journey map. The
   toggle mirrors the members' Timeline page, minus the status chips and drag-to-nest. *@

<PublicWorldFrame Slug="@Slug" Active="timeline">
    <ChildContent Context="world">
        @if (_timeline is null)
        {
            <LoadingRows Rows="3" />
        }
        else
        {
            <div class="d-flex justify-end mb-4">
                <MudToggleGroup T="string" Value="_view" ValueChanged="OnViewChangedAsync"
                                SelectionMode="SelectionMode.SingleSelection"
                                Color="Color.Secondary" Size="Size.Small">
                    <MudToggleItem Value="@("timeline")">
                        <MudIcon Icon="@Icons.Material.Outlined.Route" Size="Size.Small" />
                    </MudToggleItem>
                    <MudToggleItem Value="@("journey")">
                        <MudIcon Icon="@Icons.Material.Outlined.Map" Size="Size.Small" />
                    </MudToggleItem>
                </MudToggleGroup>
            </div>

            @if (_view == "journey")
            {
                @if (_journeyNoMap)
                {
                    <MudPaper Elevation="0" Class="nornis-card nornis-card-pad nornis-comingsoon">
                        <MudIcon Icon="@Icons.Material.Outlined.Map" Size="Size.Large" Class="nornis-comingsoon-icon" />
                        <MudText Typo="Typo.h5" Class="nornis-serif">No map charted yet</MudText>
                        <MudText Typo="Typo.body1" Class="nornis-comingsoon-text mt-2">
                            Once a map is pinned to this world, the party's course across it appears here.
                        </MudText>
                    </MudPaper>
                }
                else if (_journeyError is not null)
                {
                    <MudAlert Severity="Severity.Error">@_journeyError</MudAlert>
                }
                else if (_journey is null)
                {
                    <LoadingRows Rows="3" />
                }
                else
                {
                    <JourneyMap Data="_journey"
                                SourceLinkBase="@($"/w/{Slug}/sources")"
                                ArtifactLinkBase="@($"/w/{Slug}/artifacts")" />
                }
            }
            else if (_timeline.Lanes.Count == 0)
            {
                <MudPaper Elevation="0" Class="nornis-card nornis-card-pad nornis-comingsoon">
                    <MudIcon Icon="@Icons.Material.Outlined.Route" Size="Size.Large" Class="nornis-comingsoon-icon" />
                    <MudText Typo="Typo.h5" Class="nornis-serif">No storylines yet</MudText>
                    <MudText Typo="Typo.body1" Class="nornis-comingsoon-text mt-2">
                        As the chronicle grows, the stories in motion appear here.
                    </MudText>
                </MudPaper>
            }
            else
            {
                <StorylineTimelineChart Data="_timeline" CanEdit="false"
                                        SourceLinkBase="@($"/w/{Slug}/sources")"
                                        ArtifactLinkBase="@($"/w/{Slug}/artifacts")" />
            }
        }
    </ChildContent>
</PublicWorldFrame>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private string _view = "timeline";

    private StorylineTimelineDto? _timeline;
    private string? _loadedSlug;

    // The journey is fetched only when the map view is asked for, and cached per slug —
    // most visitors never leave the chart, and this is anonymous, rate-limited traffic.
    // "No map" is a valid loaded state (nothing pinned yet), distinct from an error.
    private JourneyDto? _journey;
    private string? _journeyLoadedSlug;
    private string? _journeyError;
    private bool _journeyNoMap;

    protected override async Task OnParametersSetAsync()
    {
        if (Slug == _loadedSlug)
        {
            return;
        }

        _loadedSlug = Slug;
        var result = await Api.GetPublicTimelineAsync(Slug);
        _timeline = result.IsSuccess ? result.Value : new StorylineTimelineDto([], [], []);

        if (_view == "journey" && _journeyLoadedSlug != Slug)
        {
            await LoadJourneyAsync();
        }
    }

    private async Task OnViewChangedAsync(string view)
    {
        _view = view;
        if (view == "journey" && _journeyLoadedSlug != Slug)
        {
            await LoadJourneyAsync();
        }
    }

    private async Task LoadJourneyAsync()
    {
        _journey = null;
        _journeyError = null;
        _journeyNoMap = false;
        StateHasChanged();

        var result = await Api.GetPublicJourneyAsync(Slug);
        if (result.IsSuccess)
        {
            _journey = result.Value!;
            _journeyLoadedSlug = Slug;
        }
        else if (result.Error!.Code == "no_map")
        {
            _journeyNoMap = true;
            _journeyLoadedSlug = Slug;
        }
        else
        {
            _journeyError = result.Error!.Message;
        }
        StateHasChanged();
    }
}
