@page "/licenses"
@layout PublicLayout

<PageTitle>Licenses — Nornis</PageTitle>

<article class="nornis-public-page">
    <div class="nornis-eyebrow">Licenses</div>
    <h1>Standing on good shoulders</h1>
    <p>Nornis is built with open-source software. The load-bearing pieces:</p>

    <div class="nornis-license-list">
        <div class="nornis-license-row">
            <div>
                <strong>.NET / ASP.NET Core / Blazor</strong>
                <span>Microsoft and contributors</span>
            </div>
            <span class="nornis-license-tag">MIT</span>
        </div>
        <div class="nornis-license-row">
            <div>
                <strong>MudBlazor</strong>
                <span>Blazor component library</span>
            </div>
            <span class="nornis-license-tag">MIT</span>
        </div>
        <div class="nornis-license-row">
            <div>
                <strong>Entity Framework Core</strong>
                <span>Data access</span>
            </div>
            <span class="nornis-license-tag">MIT</span>
        </div>
        <div class="nornis-license-row">
            <div>
                <strong>OpenAI .NET SDK</strong>
                <span>AI client library</span>
            </div>
            <span class="nornis-license-tag">MIT</span>
        </div>
        <div class="nornis-license-row">
            <div>
                <strong>NUnit, NSubstitute, FsCheck</strong>
                <span>Test tooling</span>
            </div>
            <span class="nornis-license-tag">MIT / BSD</span>
        </div>
        <div class="nornis-license-row">
            <div>
                <strong>Cormorant Garamond &amp; Inter</strong>
                <span>Typefaces, via Google Fonts</span>
            </div>
            <span class="nornis-license-tag">OFL</span>
        </div>
        <div class="nornis-license-row">
            <div>
                <strong>Material Icons</strong>
                <span>Iconography</span>
            </div>
            <span class="nornis-license-tag">Apache 2.0</span>
        </div>
    </div>

    <p class="nornis-public-updated">
        Full license texts ship with each package; see the respective project repositories.
    </p>
</article>
