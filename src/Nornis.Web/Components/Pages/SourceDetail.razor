@page "/sources/{SourceId:guid}"
@implements IDisposable
@inject WorldState Worlds
@inject NornisApiClient Api
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav

<PageTitle>@(_source?.Title ?? "Source") — Nornis</PageTitle>

<div class="nornis-narrow">
    <MudButton Href="/sources" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mb-2">
        Sources
    </MudButton>

    @if (Worlds.Current is null)
    {
        <NoWorld />
    }
    else if (_loading)
    {
        <LoadingRows Rows="3" />
    }
    else if (_notFound)
    {
        <MudPaper Elevation="0" Class="nornis-card nornis-card-pad nornis-comingsoon">
            <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Size="Size.Large" Class="nornis-comingsoon-icon" />
            <MudText Typo="Typo.h5" Class="nornis-serif">Source not found</MudText>
            <MudText Typo="Typo.body1" Class="nornis-comingsoon-text mt-2">
                It may have been removed, or you may not have permission to see it.
            </MudText>
        </MudPaper>
    }
    else if (_error is not null)
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else if (_source is not null)
    {
        <div class="nornis-detail-head">
            <div class="nornis-list-thumb"><MudIcon Icon="@Icons.Material.Outlined.Description" /></div>
            <div class="flex-grow-1">
                <MudText Typo="Typo.h4" Class="nornis-serif">@_source.Title</MudText>
                <div class="nornis-detail-chips">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">@Humanize(_source.Type)</MudChip>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@StatusColor(_source.ProcessingStatus)">@_source.ProcessingStatus</MudChip>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@_source.Visibility</MudChip>
                    @if (_source.CampaignName is not null)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Tertiary">@_source.CampaignName</MudChip>
                    }
                </div>
            </div>
            @if (!_editing)
            {
                <div class="nornis-detail-actions">
                    @if (_source.ProcessingStatus is "Draft" or "Failed")
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.AutoAwesome"
                                   OnClick="ProcessAsync" Disabled="_processing">
                            Process
                        </MudButton>
                    }
                    @if (CanEdit)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick="BeginEdit" Disabled="_processing">
                            Edit
                        </MudButton>
                    }
                    @if (CanDelete)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                       OnClick="DeleteAsync" Disabled="_deleting" aria-label="Delete source" />
                    }
                </div>
            }
        </div>

        @if (_editing)
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                <div class="nornis-detail-section-title">Edit source</div>

                <MudTextField @bind-Value="_editTitle" Label="Title" Required="true" Immediate="true"
                              MaxLength="200" Variant="Variant.Outlined" Class="mb-3" />

                <div class="d-flex gap-3 mb-3">
                    <MudSelect @bind-Value="_editType" Label="Type" Variant="Variant.Outlined" Class="flex-grow-1">
                        @foreach (var type in _sourceTypes)
                        {
                            <MudSelectItem Value="@type">@Humanize(type)</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect @bind-Value="_editVisibility" Label="Visibility" Variant="Variant.Outlined" Class="flex-grow-1">
                        @foreach (var vis in _visibilities)
                        {
                            <MudSelectItem Value="@vis">@vis</MudSelectItem>
                        }
                    </MudSelect>
                </div>

                <MudTextField @bind-Value="_editBody" Label="Body" Lines="8"
                              Placeholder="Paste session notes, a journal entry, a transcript…"
                              Variant="Variant.Outlined" Class="mb-3" />

                <MudTextField @bind-Value="_editUri" Label="Link (optional)" Placeholder="https://…"
                              Variant="Variant.Outlined" Class="mb-3" />

                <MudDatePicker @bind-Date="_editOccurredAt" Label="When it happened (optional)"
                               Variant="Variant.Outlined" Class="mb-3" />

                @if (_campaigns.Count > 0)
                {
                    <MudSelect T="Guid?" @bind-Value="_editCampaignId" Label="Campaign (optional)"
                               Variant="Variant.Outlined" Class="mb-3">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">No campaign</MudSelectItem>
                        @foreach (var c in _campaigns)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)c.Id)">@c.Name</MudSelectItem>
                        }
                    </MudSelect>
                }

                @if (_editError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_editError</MudAlert>
                }

                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="SaveEditAsync" Disabled="_saving">
                        Save
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CancelEdit" Disabled="_saving">
                        Cancel
                    </MudButton>
                </div>
            </MudPaper>
        }
        else
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                <div class="nornis-kv">
                    <span class="nornis-kv-key">Created</span>
                    <span class="nornis-kv-value">@_source.CreatedAt.LocalDateTime.ToString("d MMM yyyy, h:mm tt")</span>
                </div>
                @if (_source.OccurredAt is not null)
                {
                    <div class="nornis-kv">
                        <span class="nornis-kv-key">Occurred</span>
                        <span class="nornis-kv-value">@_source.OccurredAt.Value.LocalDateTime.ToString("d MMM yyyy")</span>
                    </div>
                }
                @if (_source.CampaignName is not null)
                {
                    <div class="nornis-kv">
                        <span class="nornis-kv-key">Campaign</span>
                        <span class="nornis-kv-value">@_source.CampaignName</span>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_source.Uri))
                {
                    <div class="nornis-kv">
                        <span class="nornis-kv-key">Link</span>
                        <a href="@_source.Uri" target="_blank" rel="noopener" class="nornis-link">@_source.Uri</a>
                    </div>
                }
            </MudPaper>

            @if (!string.IsNullOrWhiteSpace(_source.Body))
            {
                <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                    <div class="nornis-detail-section-title">Content</div>
                    @* Bodies are markdown (capture editor) or legacy plain text — both render
                       safely here: raw HTML is disabled and single newlines become breaks. *@
                    <div class="nornis-source-body nornis-markdown">@Nornis.Web.Services.MarkdownRenderer.ToHtml(_source.Body)</div>
                </MudPaper>
            }
        }
    }
</div>

@code {
    [Parameter] public Guid SourceId { get; set; }

    private bool _loading;
    private bool _notFound;
    private bool _processing;
    private string? _error;
    private SourceDetailDto? _source;
    private Guid _loadedId;

    // Inline edit form. Mirrors the Capture page's option lists so the two stay in sync.
    private readonly string[] _sourceTypes =
    [
        "SessionNote", "JournalEntry", "Transcript", "GMNote", "WebLink",
        "Image", "HandwrittenNotes", "Upload", "ImportedNote",
    ];
    private readonly string[] _visibilities = ["PartyVisible", "GMOnly", "Private"];

    private bool _editing;
    private bool _saving;
    private bool _deleting;
    private string? _editError;
    private string _editTitle = string.Empty;
    private string _editType = "SessionNote";
    private string _editVisibility = "PartyVisible";
    private string? _editBody;
    private string? _editUri;
    private DateTime? _editOccurredAt;
    private Guid? _editCampaignId;
    private IReadOnlyList<CampaignDto> _campaigns = [];

    // Edits are rejected server-side once the source is Queued/Processing/Processed.
    private bool CanEdit => _source?.ProcessingStatus is "Draft" or "Ready" or "Failed";

    // Deletes are rejected server-side while Queued/Processing.
    private bool CanDelete => _source is not null && _source.ProcessingStatus is not ("Queued" or "Processing");

    protected override void OnInitialized() => Worlds.Changed += OnWorldChanged;

    protected override async Task OnParametersSetAsync()
    {
        if (SourceId != _loadedId)
        {
            await Worlds.EnsureLoadedAsync();
            await LoadAsync();
            _ = PollWhileProcessingAsync();
        }
    }

    // Extraction runs out-of-process; poll while this source is mid-pipeline so its
    // status chip moves Queued -> Processing -> Processed without a manual refresh.
    private static readonly string[] ActiveStatuses = ["Ready", "Queued", "Processing"];
    private readonly CancellationTokenSource _pollCts = new();
    private bool _polling;

    private async Task PollWhileProcessingAsync()
    {
        if (_polling)
            return;
        _polling = true;

        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(4));
            while (await timer.WaitForNextTickAsync(_pollCts.Token))
            {
                if (Worlds.Current is null || _source is null || !ActiveStatuses.Contains(_source.ProcessingStatus))
                    continue;

                var result = await Api.GetSourceAsync(Worlds.Current.Id, SourceId, _pollCts.Token);
                if (result.IsSuccess)
                {
                    _source = result.Value!;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Page disposed.
        }
        finally
        {
            _polling = false;
        }
    }

    private void OnWorldChanged() => InvokeAsync(LoadAsync);

    private async Task LoadAsync()
    {
        if (Worlds.Current is null)
        {
            _source = null;
            StateHasChanged();
            return;
        }

        _loading = true;
        _notFound = false;
        _error = null;
        _loadedId = SourceId;
        StateHasChanged();

        var campaignsResult = await Api.GetCampaignsAsync(Worlds.Current.Id);
        _campaigns = campaignsResult.IsSuccess ? campaignsResult.Value! : [];

        var result = await Api.GetSourceAsync(Worlds.Current.Id, SourceId);

        _loading = false;
        if (result.IsSuccess)
        {
            _source = result.Value!;
        }
        else if (result.Error!.Code == "not_found")
        {
            _notFound = true;
            _source = null;
        }
        else
        {
            _error = result.Error!.Message;
            _source = null;
        }
        StateHasChanged();
    }

    private async Task ProcessAsync()
    {
        if (Worlds.Current is null || _source is null)
        {
            return;
        }

        _processing = true;
        var result = await Api.MarkSourceReadyAsync(Worlds.Current.Id, _source.Id);
        _processing = false;

        if (result.IsSuccess)
        {
            _source = result.Value!;
            Snackbar.Add("Source queued for processing.", Severity.Success);
        }
        else
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
        }
        StateHasChanged();
    }

    private void BeginEdit()
    {
        if (_source is null)
        {
            return;
        }

        _editTitle = _source.Title;
        _editType = _source.Type;
        _editVisibility = _source.Visibility;
        _editBody = _source.Body;
        _editUri = _source.Uri;
        _editOccurredAt = _source.OccurredAt?.LocalDateTime;
        _editCampaignId = _source.CampaignId;
        _editError = null;
        _editing = true;
    }

    private void CancelEdit()
    {
        _editing = false;
        _editError = null;
    }

    private async Task SaveEditAsync()
    {
        if (Worlds.Current is null || _source is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_editTitle))
        {
            _editError = "Title is required.";
            return;
        }

        _saving = true;
        _editError = null;

        var request = new UpdateSourceRequest(
            Title: _editTitle.Trim(),
            Body: string.IsNullOrWhiteSpace(_editBody) ? null : _editBody,
            Uri: string.IsNullOrWhiteSpace(_editUri) ? null : _editUri,
            OccurredAt: _editOccurredAt.HasValue ? new DateTimeOffset(_editOccurredAt.Value, TimeSpan.Zero) : null,
            Type: _editType,
            Visibility: _editVisibility,
            CampaignId: _editCampaignId,
            ClearCampaign: _editCampaignId is null && _source.CampaignId is not null);

        var result = await Api.UpdateSourceAsync(Worlds.Current.Id, _source.Id, request);

        _saving = false;
        if (result.IsSuccess)
        {
            _source = result.Value!;
            _editing = false;
            Snackbar.Add("Source updated.", Severity.Success);
        }
        else
        {
            _editError = result.Error!.Message;
        }
        StateHasChanged();
    }

    private async Task DeleteAsync()
    {
        if (Worlds.Current is null || _source is null)
        {
            return;
        }

        var confirmed = await DialogService.ShowMessageBox(
            "Delete source?",
            "This permanently removes the source. Artifacts already accepted from it remain.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        _deleting = true;
        var result = await Api.DeleteSourceAsync(Worlds.Current.Id, _source.Id);
        _deleting = false;

        if (result.IsSuccess)
        {
            Snackbar.Add("Source deleted.", Severity.Info);
            Nav.NavigateTo("/sources");
        }
        else
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
            StateHasChanged();
        }
    }

    private static Color StatusColor(string status) => status switch
    {
        "Processed" => Color.Success,
        "Processing" or "Queued" => Color.Info,
        "Failed" => Color.Error,
        "Ready" => Color.Warning,
        _ => Color.Default,
    };

    private static string Humanize(string pascal) =>
        string.Concat(pascal.Select((c, i) => i > 0 && char.IsUpper(c) ? " " + c : c.ToString()));

    public void Dispose()
    {
        _pollCts.Cancel();
        _pollCts.Dispose();
        Worlds.Changed -= OnWorldChanged;
    }
}
