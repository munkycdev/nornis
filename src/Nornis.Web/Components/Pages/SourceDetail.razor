@page "/sources/{SourceId:guid}"
@implements IDisposable
@inject WorldState Worlds
@inject NornisApiClient Api
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav

<PageTitle>@(_source?.Title ?? "Source") — Nornis</PageTitle>

<div class="nornis-narrow">
    <MudButton Href="/sources" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mb-2">
        Sources
    </MudButton>

    @if (Worlds.Current is null)
    {
        <NoWorld />
    }
    else if (_loading)
    {
        <LoadingRows Rows="3" />
    }
    else if (_notFound)
    {
        <MudPaper Elevation="0" Class="nornis-card nornis-card-pad nornis-comingsoon">
            <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Size="Size.Large" Class="nornis-comingsoon-icon" />
            <MudText Typo="Typo.h5" Class="nornis-serif">Source not found</MudText>
            <MudText Typo="Typo.body1" Class="nornis-comingsoon-text mt-2">
                It may have been removed, or you may not have permission to see it.
            </MudText>
        </MudPaper>
    }
    else if (_error is not null)
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else if (_source is not null)
    {
        <div class="nornis-detail-head">
            <div class="nornis-list-thumb"><MudIcon Icon="@Icons.Material.Outlined.Description" /></div>
            <div class="flex-grow-1">
                <MudText Typo="Typo.h4" Class="nornis-serif">@_source.Title</MudText>
                <div class="nornis-detail-chips">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">@Humanize(_source.Type)</MudChip>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@StatusColor(_source.ProcessingStatus)">@_source.ProcessingStatus</MudChip>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@_source.Visibility</MudChip>
                    @if (_source.CampaignName is not null)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Tertiary">@_source.CampaignName</MudChip>
                    }
                </div>
            </div>
            @if (!_editing)
            {
                <div class="nornis-detail-actions">
                    @if (_source.ProcessingStatus is "Draft" or "Failed")
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.AutoAwesome"
                                   OnClick="ProcessAsync" Disabled="_processing">
                            Process
                        </MudButton>
                    }
                    @if (CanEdit)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick="BeginEdit" Disabled="_processing">
                            Edit
                        </MudButton>
                    }
                    @if (CanDelete)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                       OnClick="DeleteAsync" Disabled="_deleting" aria-label="Delete source" />
                    }
                </div>
            }
        </div>

        @if (_editing)
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                <div class="nornis-detail-section-title">Edit source</div>

                <MudTextField @bind-Value="_editTitle" Label="Title" Required="true" Immediate="true"
                              MaxLength="200" Variant="Variant.Outlined" Class="mb-3" />

                <div class="d-flex gap-3 mb-3">
                    <MudSelect @bind-Value="_editType" Label="Type" Variant="Variant.Outlined" Class="flex-grow-1">
                        @foreach (var type in _sourceTypes)
                        {
                            <MudSelectItem Value="@type">@Humanize(type)</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect @bind-Value="_editVisibility" Label="Visibility" Variant="Variant.Outlined" Class="flex-grow-1"
                               Disabled="IsProcessed"
                               HelperText="@(IsProcessed ? "Locked after processing — derived knowledge keeps its scope." : null)">
                        @foreach (var vis in _visibilities)
                        {
                            <MudSelectItem Value="@vis">@vis</MudSelectItem>
                        }
                    </MudSelect>
                </div>

                <div class="mb-3">
                    <NotesEditor @ref="_bodyEditor" InitialMarkdown="@_editBody"
                                 Placeholder="Paste session notes, a journal entry, a transcript…" />
                </div>

                <MudTextField @bind-Value="_editUri" Label="Link (optional)" Placeholder="https://…"
                              Variant="Variant.Outlined" Class="mb-3" />

                <MudDatePicker @bind-Date="_editOccurredAt" Label="When it happened (optional)"
                               Variant="Variant.Outlined" Class="mb-3" />

                @if (_campaigns.Count > 0)
                {
                    <MudSelect T="Guid?" @bind-Value="_editCampaignId" Label="Campaign (optional)"
                               Variant="Variant.Outlined" Class="mb-3">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">No campaign</MudSelectItem>
                        @foreach (var c in _campaigns)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)c.Id)">@c.Name</MudSelectItem>
                        }
                    </MudSelect>
                }

                @if (_editError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_editError</MudAlert>
                }

                @if (IsProcessed)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                        This note has already been processed. Changing its text will delete the knowledge
                        extracted solely from it and process the note again — you'll see exactly what gets
                        removed before anything happens.
                    </MudAlert>
                }

                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="SaveEditAsync" Disabled="_saving">
                        Save
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CancelEdit" Disabled="_saving">
                        Cancel
                    </MudButton>
                </div>
            </MudPaper>
        }
        else
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                <div class="nornis-kv">
                    <span class="nornis-kv-key">Created</span>
                    <span class="nornis-kv-value">@_source.CreatedAt.LocalDateTime.ToString("d MMM yyyy, h:mm tt")</span>
                </div>
                @if (_source.OccurredAt is not null)
                {
                    <div class="nornis-kv">
                        <span class="nornis-kv-key">Occurred</span>
                        <span class="nornis-kv-value">@_source.OccurredAt.Value.LocalDateTime.ToString("d MMM yyyy")</span>
                    </div>
                }
                @if (_source.CampaignName is not null)
                {
                    <div class="nornis-kv">
                        <span class="nornis-kv-key">Campaign</span>
                        <span class="nornis-kv-value">@_source.CampaignName</span>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_source.Uri))
                {
                    <div class="nornis-kv">
                        <span class="nornis-kv-key">Link</span>
                        <a href="@_source.Uri" target="_blank" rel="noopener" class="nornis-link">@_source.Uri</a>
                    </div>
                }
            </MudPaper>

            @if (!string.IsNullOrWhiteSpace(_source.Body))
            {
                <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                    <div class="nornis-detail-section-title">
                        @(_source.Type == "HandwrittenNotes" ? "Transcription" : "Content")
                    </div>
                    @* Markdig parses the markdown (best CommonMark fidelity, HTML-safe), and a
                       read-only TipTap instance presents it — the same surface the capture
                       editor uses, so notes look exactly as authored. @key remounts the
                       component when navigating between sources. *@
                    <NotesEditor @key="_source.Id" ReadOnly="true"
                                 InitialHtml="@Nornis.Web.Services.MarkdownRenderer.ToHtml(_source.Body).Value" />
                </MudPaper>
            }

            @if (InkDocument is not null)
            {
                <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                    <div class="d-flex align-center mb-2">
                        <div class="nornis-detail-section-title">Original ink</div>
                        <MudSpacer />
                        @if (CanEdit)
                        {
                            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Draw"
                                       Href="@($"/capture/ink/{_source.Id}")">
                                Open canvas
                            </MudButton>
                        }
                    </div>
                    <InkViewer @key="_source.Id" Url="@(InkDocument.Url ?? string.Empty)" />
                </MudPaper>
            }

            @if (PageImages.Count > 0 && InkDocument is null)
            {
                <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                    <div class="nornis-detail-section-title">Original pages</div>
                    <div class="nornis-page-grid">
                        @foreach (var pageImage in PageImages)
                        {
                            <a href="@pageImage.Url" target="_blank" rel="noopener" class="nornis-page-thumb"
                               title="@pageImage.FileName">
                                <img src="@pageImage.Url" alt="@pageImage.FileName" loading="lazy" />
                            </a>
                        }
                    </div>
                </MudPaper>
            }
        }
    }
</div>

@code {
    [Parameter] public Guid SourceId { get; set; }

    private bool _loading;
    private bool _notFound;
    private bool _processing;
    private string? _error;
    private SourceDetailDto? _source;
    private Guid _loadedId;
    private IReadOnlyList<SourceAttachmentDto> _attachments = [];

    private IReadOnlyList<SourceAttachmentDto> PageImages =>
        _attachments.Where(a => a.Kind == "PageImage" && a.Url is not null).ToList();

    // Ink-canvas sources show the ink itself as the original (the rendered page tiles
    // are just transcription intermediates, so they hide when ink exists).
    private SourceAttachmentDto? InkDocument =>
        _attachments.FirstOrDefault(a => a.Kind == "InkDocument" && a.Url is not null);

    // Inline edit form. Mirrors the Capture page's option lists so the two stay in sync.
    private readonly string[] _sourceTypes =
    [
        "SessionNote", "JournalEntry", "Transcript", "GMNote", "WebLink",
        "Image", "HandwrittenNotes", "Upload", "ImportedNote",
    ];
    private readonly string[] _visibilities = ["PartyVisible", "GMOnly", "Private"];

    private bool _editing;
    private bool _saving;
    private bool _deleting;
    private string? _editError;
    private string _editTitle = string.Empty;
    private string _editType = "SessionNote";
    private string _editVisibility = "PartyVisible";
    private string? _editBody;
    private NotesEditor? _bodyEditor;
    private string? _editUri;
    private DateTime? _editOccurredAt;
    private Guid? _editCampaignId;
    private IReadOnlyList<CampaignDto> _campaigns = [];

    // In-flight sources are locked server-side. Processed sources are editable, but a
    // body change goes through the reprocess flow (confirm → cascade delete → requeue).
    private bool CanEdit => _source?.ProcessingStatus is "Draft" or "Ready" or "Failed" or "Processed";

    private bool IsProcessed => _source?.ProcessingStatus == "Processed";

    // Deletes are rejected server-side while Queued/Processing.
    private bool CanDelete => _source is not null && _source.ProcessingStatus is not ("Queued" or "Processing");

    protected override void OnInitialized() => Worlds.Changed += OnWorldChanged;

    protected override async Task OnParametersSetAsync()
    {
        if (SourceId != _loadedId)
        {
            await Worlds.EnsureLoadedAsync();
            await LoadAsync();
            _ = PollWhileProcessingAsync();
        }
    }

    // Extraction runs out-of-process; poll while this source is mid-pipeline so its
    // status chip moves Queued -> Processing -> Processed without a manual refresh.
    private static readonly string[] ActiveStatuses = ["Ready", "Queued", "Processing"];
    private readonly CancellationTokenSource _pollCts = new();
    private bool _polling;

    private async Task PollWhileProcessingAsync()
    {
        if (_polling)
            return;
        _polling = true;

        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(4));
            while (await timer.WaitForNextTickAsync(_pollCts.Token))
            {
                if (Worlds.Current is null || _source is null || !ActiveStatuses.Contains(_source.ProcessingStatus))
                    continue;

                var result = await Api.GetSourceAsync(Worlds.Current.Id, SourceId, _pollCts.Token);
                if (result.IsSuccess)
                {
                    _source = result.Value!;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Page disposed.
        }
        finally
        {
            _polling = false;
        }
    }

    private void OnWorldChanged() => InvokeAsync(LoadAsync);

    private async Task LoadAsync()
    {
        if (Worlds.Current is null)
        {
            _source = null;
            StateHasChanged();
            return;
        }

        _loading = true;
        _notFound = false;
        _error = null;
        _loadedId = SourceId;
        StateHasChanged();

        var campaignsResult = await Api.GetCampaignsAsync(Worlds.Current.Id);
        _campaigns = campaignsResult.IsSuccess ? campaignsResult.Value! : [];

        var result = await Api.GetSourceAsync(Worlds.Current.Id, SourceId);

        _loading = false;
        if (result.IsSuccess)
        {
            _source = result.Value!;

            // Blob-backed page images (handwritten sources). URLs are short-lived SAS
            // links minted per load.
            _attachments = [];
            if (_source.Type == "HandwrittenNotes")
            {
                var attachments = await Api.GetSourceAttachmentsAsync(Worlds.Current.Id, SourceId);
                _attachments = attachments.IsSuccess ? attachments.Value! : [];
            }
        }
        else if (result.Error!.Code == "not_found")
        {
            _notFound = true;
            _source = null;
        }
        else
        {
            _error = result.Error!.Message;
            _source = null;
        }
        StateHasChanged();
    }

    private async Task ProcessAsync()
    {
        if (Worlds.Current is null || _source is null)
        {
            return;
        }

        _processing = true;
        var result = await Api.MarkSourceReadyAsync(Worlds.Current.Id, _source.Id);
        _processing = false;

        if (result.IsSuccess)
        {
            _source = result.Value!;
            Snackbar.Add("Source queued for processing.", Severity.Success);
        }
        else
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
        }
        StateHasChanged();
    }

    private void BeginEdit()
    {
        if (_source is null)
        {
            return;
        }

        _editTitle = _source.Title;
        _editType = _source.Type;
        _editVisibility = _source.Visibility;
        _editBody = _source.Body;
        _editUri = _source.Uri;
        _editOccurredAt = _source.OccurredAt?.LocalDateTime;
        _editCampaignId = _source.CampaignId;
        _editError = null;
        _editing = true;
    }

    private void CancelEdit()
    {
        _editing = false;
        _editError = null;
    }

    private async Task SaveEditAsync()
    {
        if (Worlds.Current is null || _source is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_editTitle))
        {
            _editError = "Title is required.";
            return;
        }

        _saving = true;
        _editError = null;

        // The body lives in the TipTap editor; pull it as markdown once at save.
        var body = _bodyEditor is null ? _editBody : await _bodyEditor.GetMarkdownAsync();
        var normalizedBody = string.IsNullOrWhiteSpace(body) ? null : body;

        var occurredAt = _editOccurredAt.HasValue
            ? new DateTimeOffset(DateTime.SpecifyKind(_editOccurredAt.Value, DateTimeKind.Utc), TimeSpan.Zero)
            : (DateTimeOffset?)null;

        ApiResult<SourceDetailDto> result;
        var reprocessed = false;

        // TipTap's markdown round-trip is not byte-stable, so compare trimmed text —
        // an untouched body must not trigger the reprocess flow.
        var bodyChanged = (normalizedBody ?? string.Empty).Trim() != (_source.Body ?? string.Empty).Trim();

        if (IsProcessed && bodyChanged)
        {
            result = await ReprocessWithConfirmationAsync(normalizedBody, occurredAt);
            if (result.Error?.Code == "canceled")
            {
                _saving = false;
                StateHasChanged();
                return; // user backed out of the confirmation — stay in the editor
            }
            reprocessed = result.IsSuccess;
        }
        else if (IsProcessed)
        {
            // Metadata-only: never send body or visibility for a processed source.
            result = await Api.UpdateSourceAsync(Worlds.Current.Id, _source.Id, new UpdateSourceRequest(
                Title: _editTitle.Trim(),
                Uri: string.IsNullOrWhiteSpace(_editUri) ? null : _editUri,
                OccurredAt: occurredAt,
                Type: _editType,
                CampaignId: _editCampaignId,
                ClearCampaign: _editCampaignId is null && _source.CampaignId is not null));
        }
        else
        {
            result = await Api.UpdateSourceAsync(Worlds.Current.Id, _source.Id, new UpdateSourceRequest(
                Title: _editTitle.Trim(),
                Body: normalizedBody,
                Uri: string.IsNullOrWhiteSpace(_editUri) ? null : _editUri,
                OccurredAt: occurredAt,
                Type: _editType,
                Visibility: _editVisibility,
                CampaignId: _editCampaignId,
                ClearCampaign: _editCampaignId is null && _source.CampaignId is not null));
        }

        _saving = false;
        if (result.IsSuccess)
        {
            _source = result.Value!;
            _editing = false;
            Snackbar.Add(reprocessed
                ? "Note updated — old knowledge removed, reprocessing queued."
                : "Source updated.", Severity.Success);
        }
        else
        {
            _editError = result.Error!.Message;
        }
        StateHasChanged();
    }

    /// <summary>
    /// The reprocess path: fetch the cascade preview, confirm with the user, apply any
    /// metadata changes while the source is still editable, then reprocess. Returns a
    /// synthetic "canceled" error when the user backs out.
    /// </summary>
    private async Task<ApiResult<SourceDetailDto>> ReprocessWithConfirmationAsync(
        string? body, DateTimeOffset? occurredAt)
    {
        var preview = await Api.GetReprocessPreviewAsync(Worlds.Current!.Id, _source!.Id);
        if (!preview.IsSuccess)
        {
            return ApiResult<SourceDetailDto>.Fail(preview.Error!);
        }

        var confirmed = await DialogService.ShowMessageBox(
            "Reprocess this note?",
            BuildReprocessSummary(preview.Value!),
            yesText: "Delete & Reprocess", cancelText: "Cancel");
        if (confirmed != true)
        {
            return ApiResult<SourceDetailDto>.Fail(new ApiError("canceled", "Canceled."));
        }

        // Type/campaign changes ride the regular update while the source is still
        // Processed — after the reprocess it is Queued and locked.
        if (_editType != _source.Type || _editCampaignId != _source.CampaignId)
        {
            var metadata = await Api.UpdateSourceAsync(Worlds.Current.Id, _source.Id, new UpdateSourceRequest(
                Type: _editType,
                CampaignId: _editCampaignId,
                ClearCampaign: _editCampaignId is null && _source.CampaignId is not null));
            if (!metadata.IsSuccess)
            {
                return metadata;
            }
        }

        return await Api.ReprocessSourceAsync(Worlds.Current.Id, _source.Id, new ReprocessSourceRequest(
            Title: _editTitle.Trim(),
            Body: body,
            Uri: string.IsNullOrWhiteSpace(_editUri) ? null : _editUri,
            OccurredAt: occurredAt));
    }

    private static MarkupString BuildReprocessSummary(ReprocessPreviewDto preview)
    {
        var sb = new System.Text.StringBuilder();
        sb.Append("Saving this text change permanently deletes what was learned solely from this note:");
        sb.Append("<ul style=\"margin: 0.75em 0; padding-left: 1.4em;\">");

        if (preview.ArtifactNamesToDelete.Count > 0)
        {
            var names = string.Join(", ", preview.ArtifactNamesToDelete.Take(8).Select(System.Net.WebUtility.HtmlEncode));
            var more = preview.ArtifactNamesToDelete.Count > 8 ? $" and {preview.ArtifactNamesToDelete.Count - 8} more" : "";
            sb.Append($"<li><b>{preview.ArtifactNamesToDelete.Count}</b> artifact(s): {names}{more}</li>");
        }
        if (preview.FactsToDelete > 0)
        {
            sb.Append($"<li><b>{preview.FactsToDelete}</b> fact(s)</li>");
        }
        if (preview.RelationshipsToDelete > 0)
        {
            sb.Append($"<li><b>{preview.RelationshipsToDelete}</b> relationship(s)</li>");
        }
        if (preview.PendingProposalsToDiscard > 0)
        {
            sb.Append($"<li><b>{preview.PendingProposalsToDiscard}</b> unreviewed proposal(s) will be discarded</li>");
        }
        if (preview.ArtifactNamesToDelete.Count == 0 && preview.FactsToDelete == 0
            && preview.RelationshipsToDelete == 0 && preview.PendingProposalsToDiscard == 0)
        {
            sb.Append("<li>Nothing — no accepted knowledge traces back only to this note.</li>");
        }
        sb.Append("</ul>");

        if (preview.ArtifactNamesToKeep.Count > 0)
        {
            var kept = string.Join(", ", preview.ArtifactNamesToKeep.Take(8).Select(System.Net.WebUtility.HtmlEncode));
            sb.Append($"<p style=\"margin: 0.5em 0;\">Kept (other sources build on them): {kept}.</p>");
        }

        sb.Append("<p style=\"margin: 0.5em 0 0;\">The note is then processed again and new proposals will appear in the review queue.</p>");
        return new MarkupString(sb.ToString());
    }

    private async Task DeleteAsync()
    {
        if (Worlds.Current is null || _source is null)
        {
            return;
        }

        var confirmed = await DialogService.ShowMessageBox(
            "Delete source?",
            "This permanently removes the source. Artifacts already accepted from it remain.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        _deleting = true;
        var result = await Api.DeleteSourceAsync(Worlds.Current.Id, _source.Id);
        _deleting = false;

        if (result.IsSuccess)
        {
            Snackbar.Add("Source deleted.", Severity.Info);
            Nav.NavigateTo("/sources");
        }
        else
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
            StateHasChanged();
        }
    }

    private static Color StatusColor(string status) => status switch
    {
        "Processed" => Color.Success,
        "Processing" or "Queued" => Color.Info,
        "Failed" => Color.Error,
        "Ready" => Color.Warning,
        _ => Color.Default,
    };

    private static string Humanize(string pascal) =>
        string.Concat(pascal.Select((c, i) => i > 0 && char.IsUpper(c) ? " " + c : c.ToString()));

    public void Dispose()
    {
        _pollCts.Cancel();
        _pollCts.Dispose();
        Worlds.Changed -= OnWorldChanged;
    }
}
