@page "/locations"
@implements IDisposable
@inject WorldState Worlds
@inject NornisApiClient Api

@* Locations — the place-first view over the world map (see LocationsMapExplorer for the
   explorer itself). This page owns the fetch and the world-scoped empty/error states;
   it reuses the /journey read model verbatim. *@

<PageTitle>Locations — Nornis</PageTitle>

<div class="d-flex align-center justify-space-between mb-4">
    <div>
        <MudText Typo="Typo.h4" Class="nornis-serif">Locations</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Every place your party has been.</MudText>
    </div>
</div>

@if (Worlds.Current is null)
{
    <NoWorld />
}
else if (_noMap)
{
    <MudPaper Elevation="0" Class="nornis-card nornis-card-pad nornis-comingsoon">
        <MudIcon Icon="@Icons.Material.Outlined.Place" Size="Size.Large" Class="nornis-comingsoon-icon" />
        <MudText Typo="Typo.h5" Class="nornis-serif">No places to explore yet</MudText>
        <MudText Typo="Typo.body1" Class="nornis-comingsoon-text mt-2">
            Upload a map source and pin a few locations, and each place will open here to show the
            sessions that visited it.
        </MudText>
    </MudPaper>
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_journey is null)
{
    <LoadingRows Rows="3" />
}
else
{
    <LocationsMapExplorer Journey="_journey" />
}

@code {
    private JourneyDto? _journey;
    private bool _noMap;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        Worlds.Changed += OnWorldChanged;
        await Worlds.EnsureLoadedAsync();
        await LoadAsync();
    }

    private void OnWorldChanged() => InvokeAsync(LoadAsync);

    private async Task LoadAsync()
    {
        if (Worlds.Current is null)
        {
            _journey = null;
            _error = null;
            _noMap = false;
            StateHasChanged();
            return;
        }

        _journey = null;
        _error = null;
        _noMap = false;
        StateHasChanged();

        var result = await Api.GetJourneyAsync(Worlds.Current.Id);
        if (result.IsSuccess)
        {
            _journey = result.Value!;
        }
        else if (result.Error!.Code == "no_map")
        {
            _noMap = true;
        }
        else
        {
            _error = result.Error!.Message;
        }
        StateHasChanged();
    }

    public void Dispose() => Worlds.Changed -= OnWorldChanged;
}
