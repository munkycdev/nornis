@page "/sources"
@implements IDisposable
@inject WorldState Worlds
@inject NornisApiClient Api

<PageTitle>Sources — Nornis</PageTitle>

<div class="d-flex align-center justify-space-between mb-4">
    <div>
        <MudText Typo="Typo.h4" Class="nornis-serif">Sources</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">The layers beneath your epic.</MudText>
    </div>
    <div class="d-flex gap-3 align-center">
        @if (_campaigns.Count > 0)
        {
            <MudSelect T="string" Value="_campaignFilter" ValueChanged="OnCampaignFilterChanged"
                       Dense="true" Variant="Variant.Outlined" Class="nornis-role-select">
                <MudSelectItem T="string" Value="@("")">All campaigns</MudSelectItem>
                <MudSelectItem T="string" Value="@("none")">No campaign</MudSelectItem>
                @foreach (var c in _campaigns)
                {
                    <MudSelectItem T="string" Value="@c.Id.ToString()">@c.Name</MudSelectItem>
                }
            </MudSelect>
        }
        <MudButton Variant="Variant.Filled"
                   Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/capture"
                   Disabled="@(Worlds.Current is null)">
            Capture source
        </MudButton>
    </div>
</div>

@if (Worlds.Current is null)
{
    <NoWorld />
}
else if (_loading)
{
    <LoadingRows Rows="3" />
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_sources.Count == 0)
{
    @* No status chips here: an empty world has nothing to filter. *@
    <MudPaper Elevation="0" Class="nornis-card nornis-card-pad nornis-comingsoon">
        <MudIcon Icon="@Icons.Material.Outlined.Layers" Size="Size.Large" Class="nornis-comingsoon-icon" />
        <MudText Typo="Typo.h5" Class="nornis-serif">No sources yet</MudText>
        <MudText Typo="Typo.body1" Class="nornis-comingsoon-text mt-2">
            Capture your first session note, journal, or link and Nornis will start building the record.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Add"
                   Href="/capture" Class="mt-4">
            Capture source
        </MudButton>
    </MudPaper>
}
else
{
    <div class="nornis-filter-row mb-3">
        <MudChip T="string"
                 Variant="@(_statusFilter is null ? Variant.Filled : Variant.Outlined)"
                 Color="@(_statusFilter is null ? Color.Secondary : Color.Default)"
                 OnClick="() => _statusFilter = null">All</MudChip>
        @foreach (var status in StatusFilters)
        {
            var s = status;
            <MudChip T="string" Size="Size.Small"
                     Variant="@(_statusFilter == s ? Variant.Filled : Variant.Outlined)"
                     Color="@(_statusFilter == s ? StatusColor(s) : Color.Default)"
                     OnClick="() => _statusFilter = s">@s</MudChip>
        }
    </div>

    @if (FilteredSources.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No sources are @_statusFilter.</MudText>
    }
    <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
        @foreach (var source in FilteredSources)
        {
            <a href="@($"/sources/{source.Id}")" class="nornis-list-row nornis-list-link">
                <div class="nornis-list-thumb">
                    <MudIcon Icon="@Icons.Material.Outlined.Description" Size="Size.Small" />
                </div>
                <div class="nornis-list-body">
                    <div class="nornis-list-title">@source.Title</div>
                    <div class="nornis-list-sub">@SourceTypeDisplay.Label(source.Type) · @source.CreatedAt.LocalDateTime.ToString("d MMM yyyy")</div>
                </div>
                @if (source.CampaignName is not null)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Tertiary">@source.CampaignName</MudChip>
                }
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">@source.Visibility</MudChip>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@StatusColor(source.ProcessingStatus)">
                    @source.ProcessingStatus
                </MudChip>
            </a>
        }
    </MudPaper>
}

@code {
    private bool _loading;
    private string? _error;
    private IReadOnlyList<SourceListItem> _sources = [];
    private IReadOnlyList<CampaignDto> _campaigns = [];
    private string _campaignFilter = string.Empty;
    private string? _statusFilter;

    private static readonly string[] StatusFilters = ["Draft", "Ready", "Queued", "Processing", "Processed", "Failed"];

    private IReadOnlyList<SourceListItem> FilteredSources =>
        _statusFilter is null
            ? _sources
            : _sources.Where(s => s.ProcessingStatus == _statusFilter).ToList();

    // Extraction runs out-of-process; poll while any source is mid-pipeline so the
    // list moves Queued -> Processing -> Processed without a manual refresh.
    private static readonly string[] ActiveStatuses = ["Ready", "Queued", "Processing"];
    private readonly CancellationTokenSource _pollCts = new();

    protected override async Task OnInitializedAsync()
    {
        Worlds.Changed += OnWorldChanged;
        await Worlds.EnsureLoadedAsync();
        await LoadCampaignsAsync();
        await LoadSourcesAsync();
        _ = PollWhileProcessingAsync();
    }

    private void OnWorldChanged() => InvokeAsync(async () =>
    {
        _campaignFilter = string.Empty;
        await LoadCampaignsAsync();
        await LoadSourcesAsync();
    });

    private async Task LoadCampaignsAsync()
    {
        if (Worlds.Current is null)
        {
            _campaigns = [];
            return;
        }

        var result = await Api.GetCampaignsAsync(Worlds.Current.Id);
        _campaigns = result.IsSuccess ? result.Value! : [];
    }

    private async Task OnCampaignFilterChanged(string value)
    {
        _campaignFilter = value;
        await LoadSourcesAsync();
    }

    private async Task PollWhileProcessingAsync()
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(4));
            while (await timer.WaitForNextTickAsync(_pollCts.Token))
            {
                if (Worlds.Current is null || !_sources.Any(x => ActiveStatuses.Contains(x.ProcessingStatus)))
                    continue;

                // Quiet refresh: no loading state, just swap the data in place.
                var result = await Api.GetSourcesAsync(Worlds.Current.Id, CampaignFilterOrNull, _pollCts.Token);
                if (result.IsSuccess)
                {
                    _sources = result.Value!;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Page disposed.
        }
    }

    private async Task LoadSourcesAsync()
    {
        if (Worlds.Current is null)
        {
            _sources = [];
            _error = null;
            StateHasChanged();
            return;
        }

        _loading = true;
        _error = null;
        StateHasChanged();

        var result = await Api.GetSourcesAsync(Worlds.Current.Id, CampaignFilterOrNull);

        _loading = false;
        if (result.IsSuccess)
        {
            _sources = result.Value!;
        }
        else
        {
            _error = result.Error!.Message;
            _sources = [];
        }
        StateHasChanged();
    }

    private string? CampaignFilterOrNull => string.IsNullOrEmpty(_campaignFilter) ? null : _campaignFilter;

    private static Color StatusColor(string status) => status switch
    {
        "Processed" => Color.Success,
        "Processing" or "Queued" => Color.Info,
        "Failed" => Color.Error,
        "Ready" => Color.Warning,
        _ => Color.Default,
    };


    public void Dispose()
    {
        _pollCts.Cancel();
        _pollCts.Dispose();
        Worlds.Changed -= OnWorldChanged;
    }
}
