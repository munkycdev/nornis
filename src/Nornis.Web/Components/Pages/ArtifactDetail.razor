@page "/artifacts/{ArtifactId:guid}"
@implements IDisposable
@inject WorldState Worlds
@inject NornisApiClient Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IDialogService DialogService

<PageTitle>@(_detail?.Name ?? "Artifact") — Nornis</PageTitle>

<div class="nornis-narrow">
    <MudButton Href="/artifacts" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mb-2">
        Codex
    </MudButton>

    @if (Worlds.Current is null)
    {
        <NoWorld />
    }
    else if (_loading)
    {
        <LoadingRows Rows="3" />
    }
    else if (_notFound)
    {
        <MudPaper Elevation="0" Class="nornis-card nornis-card-pad nornis-comingsoon">
            <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Size="Size.Large" Class="nornis-comingsoon-icon" />
            <MudText Typo="Typo.h5" Class="nornis-serif">Artifact not found</MudText>
            <MudText Typo="Typo.body1" Class="nornis-comingsoon-text mt-2">
                It may have been removed, or you may not have permission to see it.
            </MudText>
        </MudPaper>
    }
    else if (_error is not null)
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else if (_detail is not null)
    {
        <div class="nornis-detail-head">
            <div class="nornis-list-thumb"><MudIcon Icon="@ArtifactTypeDisplay.Icon(_detail.Type)" /></div>
            <div>
                <div class="d-flex align-center gap-1">
                    <MudText Typo="Typo.h4" Class="nornis-serif">@_detail.Name</MudText>
                    @if (Worlds.Current?.MyRole == "GM")
                    {
                        <MudTooltip Text="Rename">
                            <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small"
                                           OnClick="RenameAsync" aria-label="Rename artifact" />
                        </MudTooltip>
                    }
                </div>
                <div class="nornis-detail-chips">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">@_detail.Type</MudChip>
                    @if (Worlds.Current?.MyRole == "GM")
                    {
                        <MudMenu Dense="true">
                            <ActivatorContent>
                                <MudTooltip Text="Change status">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@StatusColor(_detail.Status)"
                                             Icon="@Icons.Material.Filled.ArrowDropDown">@_detail.Status</MudChip>
                                </MudTooltip>
                            </ActivatorContent>
                            <ChildContent>
                                @foreach (var status in AllStatuses)
                                {
                                    <MudMenuItem OnClick="() => SetStatusAsync(status)">@status</MudMenuItem>
                                }
                            </ChildContent>
                        </MudMenu>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@StatusColor(_detail.Status)">@_detail.Status</MudChip>
                    }
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@_detail.Visibility</MudChip>
                    @if (_detail.PlayedBy is { Count: > 0 } players)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Tertiary"
                                 Icon="@Icons.Material.Outlined.Person">
                            Played by @string.Join(", ", players)
                        </MudChip>
                    }
                    @if (_detail.Confidence is not null)
                    {
                        <span class="nornis-list-meta">@($"{_detail.Confidence:P0}") confidence</span>
                    }
                </div>
            </div>
        </div>

        @if (Worlds.Current?.MyRole == "GM" && ArtifactFindings.Count > 0)
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                <div class="nornis-detail-section-title">
                    <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" Size="Size.Small" Color="Color.Tertiary" Class="mr-1" />
                    Continuity findings
                </div>
                @foreach (var finding in ArtifactFindings)
                {
                    <div class="nornis-list-row">
                        <div class="nornis-list-body">
                            <div class="nornis-list-title">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@FindingSeverityColor(finding.Severity)">@finding.Severity</MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">@Humanize(finding.Category)</MudChip>
                            </div>
                            <div class="nornis-list-sub mt-1">@finding.Summary</div>
                            @if (!string.IsNullOrWhiteSpace(finding.SuggestedAction))
                            {
                                <div class="nornis-list-meta mt-1">Suggested: @finding.SuggestedAction</div>
                            }
                        </div>
                        <MudTooltip Text="Dismiss — gives its penalty points back">
                            <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small"
                                           OnClick="() => DismissFindingAsync(finding)" aria-label="Dismiss finding" />
                        </MudTooltip>
                    </div>
                }
            </MudPaper>
        }

        @if (!string.IsNullOrWhiteSpace(_detail.Summary))
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                <MudText Typo="Typo.body1">@_detail.Summary</MudText>
            </MudPaper>
        }

        <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
            @if (OpenQuestions.Count > 0)
            {
                <div class="nornis-detail-section-title">Open questions</div>
                <div class="nornis-open-questions">
                    @foreach (var q in OpenQuestions)
                    {
                        <div class="nornis-open-question">
                            <MudIcon Icon="@Icons.Material.Outlined.HelpOutline" Size="Size.Small" Color="Color.Secondary" />
                            <span>@q.Value</span>
                        </div>
                    }
                </div>
            }

            <div class="nornis-detail-section-title">Facts</div>
            @if (RegularFacts.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No facts recorded.</MudText>
            }
            @foreach (var f in RegularFacts)
            {
                <div class="nornis-fact-row">
                    <div class="nornis-fact-body">
                        <span class="nornis-fact-predicate">@f.Predicate</span>
                        <span class="nornis-fact-value">@f.Value</span>
                    </div>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@TruthColor(f.TruthState)">@f.TruthState</MudChip>
                    @if (f.Visibility != "PartyVisible")
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@f.Visibility</MudChip>
                    }
                </div>
            }
        </MudPaper>

        <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
            <div class="nornis-detail-section-title">Relationships</div>
            @if (_detail.Relationships.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No relationships yet.</MudText>
            }
            @foreach (var r in _detail.Relationships)
            {
                var other = OtherArtifact(r);
                <div class="nornis-fact-row">
                    <div class="nornis-fact-body">
                        <span class="nornis-fact-predicate">@r.Type</span>
                        @if (other is not null)
                        {
                            <ArtifactTip Name="@other.Name" Summary="@other.Summary">
                                <a href="@($"/artifacts/{other.Id}")" class="nornis-link">@other.Name</a>
                            </ArtifactTip>
                        }
                        else
                        {
                            <span class="nornis-fact-value">@r.Description</span>
                        }
                    </div>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@TruthColor(r.TruthState)">@r.TruthState</MudChip>
                </div>
            }
        </MudPaper>

        @if (_detail.Type == "Storyline" && Worlds.Current?.MyRole == "GM")
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                <div class="nornis-detail-section-title">Part of</div>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Nest this storyline beneath a parent arc — the Timeline draws it as a branch
                    and merges it back when it resolves.
                </MudText>
                @if (CurrentParent is { } parent)
                {
                    <div class="d-flex align-center gap-2 mb-3">
                        <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Size="Size.Small" />
                        <a href="@($"/artifacts/{parent.Id}")" class="nornis-link">@parent.Name</a>
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ClearParentAsync" Disabled="_parentBusy">
                            Detach
                        </MudButton>
                    </div>
                }
                <div class="nornis-add-member">
                    <MudAutocomplete T="ArtifactListItem" @bind-Value="_parentTarget"
                                     SearchFunc="SearchParentTargetsAsync" ToStringFunc="@(a => a?.Name)"
                                     Label="Parent storyline" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                                     Clearable="true" ResetValueOnEmptyText="true" Class="flex-grow-1" />
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               OnClick="SetParentAsync" Disabled="_parentBusy || _parentTarget is null">
                        @(CurrentParent is null ? "Set parent" : "Move")
                    </MudButton>
                </div>
                @if (_parentError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_parentError</MudAlert>
                }
            </MudPaper>
        }

        @if (_detail.Relationships.Count > 0 && _graph is not null)
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                <div class="d-flex align-center justify-space-between mb-2">
                    <div class="nornis-detail-section-title">Connections</div>
                    <MudToggleGroup T="int" @bind-Value="_graphDepth" SelectionMode="SelectionMode.SingleSelection"
                                    Color="Color.Secondary" Size="Size.Small">
                        <MudToggleItem Value="1">1 hop</MudToggleItem>
                        <MudToggleItem Value="2">2 hops</MudToggleItem>
                    </MudToggleGroup>
                </div>
                <ArtifactGraph Nodes="_graph.Nodes" Edges="_graph.Edges" FocusId="_detail.Id" Depth="_graphDepth"
                               CanvasClass="nornis-graph-canvas-sm" ShowLegend="false"
                               NodeSelected="OnConnectionSelected" />
            </MudPaper>
        }

        @if (_detail.SourceReferences.Count > 0)
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                <div class="nornis-detail-section-title">Source references</div>
                @foreach (var s in _detail.SourceReferences)
                {
                    <div class="nornis-source-ref">
                        <MudIcon Icon="@Icons.Material.Outlined.FormatQuote" Size="Size.Small" Color="Color.Tertiary" />
                        <div>
                            @if (!string.IsNullOrWhiteSpace(s.Quote))
                            {
                                <span class="nornis-source-quote">“@s.Quote”</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(s.Notes))
                            {
                                <span class="nornis-list-sub">@s.Notes</span>
                            }
                            @if (s.SourceTitle is not null)
                            {
                                <a href="@($"/sources/{s.SourceId}")" class="nornis-link nornis-list-sub">@s.SourceTitle</a>
                            }
                        </div>
                    </div>
                }
            </MudPaper>
        }

        @if (Worlds.Current?.MyRole == "GM")
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                <div class="nornis-detail-section-title">Merge duplicate</div>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                    Is @_detail.Name a duplicate? Merge it into the real artifact: its facts and
                    relationships move there, and this artifact is archived.
                </MudText>
                <div class="d-flex gap-3 align-center">
                    <MudAutocomplete T="ArtifactListItem" @bind-Value="_mergeTarget"
                                     SearchFunc="SearchMergeTargetsAsync"
                                     ToStringFunc="@(a => a?.Name)"
                                     Label="Merge into…" Variant="Variant.Outlined" Dense="true"
                                     Class="flex-grow-1" Clearable="true" />
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.CallMerge"
                               OnClick="MergeAsync" Disabled="@(_mergeBusy || _mergeTarget is null)">
                        Merge
                    </MudButton>
                </div>
                @if (_mergeError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_mergeError</MudAlert>
                }
            </MudPaper>

            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                <div class="nornis-detail-section-title">Remove from canon</div>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                    Was @_detail.Name never real, or extracted by mistake? Remove it and the knowledge
                    attached to it — its facts, the relationships touching it, and any map pins. Other
                    artifacts are untouched. This can't be undone.
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.DeleteForever"
                           OnClick="RemoveFromCanonAsync" Disabled="_removeBusy">
                    Remove from canon
                </MudButton>
                @if (_removeError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_removeError</MudAlert>
                }
            </MudPaper>
        }

        @if (Worlds.Current?.MyRole == "GM" && HasGmOnlyContent)
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                <div class="nornis-detail-section-title">Reveal to the party</div>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                    Promote the GM-only parts of @_detail.Name to the party — they'll appear in the
                    players' record with provenance. Pick exactly what to disclose; whatever you leave
                    hidden stays yours. This can't be undone.
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.Visibility"
                           OnClick="RevealAsync">
                    Reveal to the party…
                </MudButton>
            </MudPaper>
        }

        @if (Worlds.Current?.MyRole != "Observer")
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad mt-4">
                <div class="nornis-detail-section-title">Add to the record</div>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                    Know something about @_detail.Name that isn't captured here? Write it down —
                    Nornis will read it and propose updates for review.
                </MudText>
                <MudTextField @bind-Value="_quickAddText" Lines="4" Immediate="true"
                              Placeholder="@($"e.g. {_detail.Name} was last seen…")"
                              Variant="Variant.Outlined" Class="mb-2" />
                <div class="d-flex gap-3 align-center">
                    <MudSelect T="string" @bind-Value="_quickAddVisibility" Dense="true" Label="Visibility"
                               Variant="Variant.Outlined" Class="nornis-role-select">
                        <MudSelectItem Value="@("PartyVisible")">PartyVisible</MudSelectItem>
                        <MudSelectItem Value="@("GMOnly")">GMOnly</MudSelectItem>
                        <MudSelectItem Value="@("Private")">Private</MudSelectItem>
                    </MudSelect>
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.AutoAwesome"
                               OnClick="QuickAddAsync"
                               Disabled="@(_quickAddBusy || string.IsNullOrWhiteSpace(_quickAddText))">
                        Add to record
                    </MudButton>
                </div>
                @if (_quickAddError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_quickAddError</MudAlert>
                }
            </MudPaper>
        }
    }
</div>

@code {
    [Parameter] public Guid ArtifactId { get; set; }

    private bool _loading;
    private bool _notFound;
    private string? _error;
    private ArtifactDetailDto? _detail;
    private Guid _loadedId;

    // Merge duplicate (GM): folds this artifact into a chosen target.
    private ArtifactListItem? _mergeTarget;
    private bool _mergeBusy;
    private string? _mergeError;

    private async Task<IEnumerable<ArtifactListItem>> SearchMergeTargetsAsync(string value, CancellationToken ct)
    {
        if (Worlds.Current is null)
        {
            return [];
        }

        var result = await Api.GetArtifactsAsync(Worlds.Current.Id, ct: ct);
        if (!result.IsSuccess)
        {
            return [];
        }

        return result.Value!
            .Where(a => a.Id != ArtifactId)
            .Where(a => string.IsNullOrWhiteSpace(value) || a.Name.Contains(value, StringComparison.OrdinalIgnoreCase))
            .OrderBy(a => a.Name)
            .Take(15);
    }

    private async Task MergeAsync()
    {
        if (Worlds.Current is null || _detail is null || _mergeTarget is null)
        {
            return;
        }

        var confirmed = await DialogService.ShowMessageBox(
            "Merge artifacts?",
            $"Move all facts and relationships from \"{_detail.Name}\" to \"{_mergeTarget.Name}\" and archive \"{_detail.Name}\"? This cannot be undone from the UI.",
            yesText: "Merge", cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        _mergeBusy = true;
        _mergeError = null;

        var result = await Api.MergeArtifactAsync(Worlds.Current.Id, _mergeTarget.Id, _detail.Id);
        _mergeBusy = false;

        if (!result.IsSuccess)
        {
            _mergeError = result.Error!.Message;
            StateHasChanged();
            return;
        }

        Snackbar.Add($"Merged into {_mergeTarget.Name}.", Severity.Success);
        Nav.NavigateTo($"/artifacts/{result.Value!.TargetArtifactId}");
    }

    // Remove from canon (GM): deletes this artifact and the knowledge attached to it.
    private bool _removeBusy;
    private string? _removeError;

    private async Task RemoveFromCanonAsync()
    {
        if (Worlds.Current is null || _detail is null)
        {
            return;
        }

        _removeBusy = true;
        _removeError = null;
        StateHasChanged();

        var preview = await Api.GetArtifactRemovalPreviewAsync(Worlds.Current.Id, _detail.Id);
        if (!preview.IsSuccess)
        {
            _removeBusy = false;
            _removeError = preview.Error!.Message;
            StateHasChanged();
            return;
        }

        var p = preview.Value!;
        var parts = new List<string>();
        if (p.FactCount > 0) parts.Add($"{p.FactCount} fact{(p.FactCount == 1 ? "" : "s")}");
        if (p.Relationships.Count > 0) parts.Add($"{p.Relationships.Count} relationship{(p.Relationships.Count == 1 ? "" : "s")}");
        if (p.MapPinCount > 0) parts.Add($"{p.MapPinCount} map pin{(p.MapPinCount == 1 ? "" : "s")}");
        if (p.CharacterLinksToClear > 0) parts.Add($"{p.CharacterLinksToClear} character link{(p.CharacterLinksToClear == 1 ? "" : "s")} cleared");
        var detail = parts.Count > 0 ? $"This also removes {string.Join(", ", parts)}. " : "";

        var confirmed = await DialogService.ShowMessageBox(
            "Remove from canon?",
            $"Permanently remove \"{p.ArtifactName}\" from the Codex. {detail}Other artifacts are not affected. This cannot be undone.",
            yesText: "Remove", cancelText: "Cancel");

        if (confirmed != true)
        {
            _removeBusy = false;
            StateHasChanged();
            return;
        }

        var result = await Api.RemoveArtifactAsync(Worlds.Current.Id, _detail.Id);
        _removeBusy = false;

        if (!result.IsSuccess)
        {
            _removeError = result.Error!.Message;
            StateHasChanged();
            return;
        }

        Snackbar.Add($"Removed \"{p.ArtifactName}\" from canon.", Severity.Info);
        Nav.NavigateTo("/artifacts");
    }

    // Reveal to the party (GM): promotes chosen GM-only parts of this artifact to PartyVisible.
    private bool HasGmOnlyContent =>
        _detail is not null
        && (_detail.Visibility == "GMOnly"
            || _detail.Facts.Any(f => f.Visibility == "GMOnly")
            || _detail.Relationships.Any(r => r.Visibility == "GMOnly"));

    private async Task RevealAsync()
    {
        if (Worlds.Current is null || _detail is null)
        {
            return;
        }

        var parameters = new DialogParameters<RevealDialog>
        {
            { d => d.Detail, _detail },
        };

        var dialog = await DialogService.ShowAsync<RevealDialog>("Reveal to the party", parameters);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is RevealOutcome outcome)
        {
            var parts = new List<string>();
            if (outcome.RevealedArtifacts > 0) parts.Add($"{outcome.RevealedArtifacts} artifact{(outcome.RevealedArtifacts == 1 ? "" : "s")}");
            if (outcome.RevealedFacts > 0) parts.Add($"{outcome.RevealedFacts} fact{(outcome.RevealedFacts == 1 ? "" : "s")}");
            if (outcome.RevealedRelationships > 0) parts.Add($"{outcome.RevealedRelationships} relationship{(outcome.RevealedRelationships == 1 ? "" : "s")}");
            Snackbar.Add(parts.Count > 0 ? $"Revealed {string.Join(", ", parts)} to the party." : "Nothing to reveal.", Severity.Success);
            await LoadAsync();
        }
    }

    private static readonly string[] AllStatuses = ["Active", "Dormant", "Resolved", "Archived"];

    private async Task SetStatusAsync(string status)
    {
        if (Worlds.Current is null || _detail is null || status == _detail.Status)
        {
            return;
        }

        var result = await Api.SetArtifactStatusAsync(Worlds.Current.Id, _detail.Id, status);
        if (result.IsSuccess)
        {
            _detail = _detail with { Status = result.Value!.Status, UpdatedAt = result.Value.UpdatedAt };
            Snackbar.Add($"Status set to {result.Value.Status}.", Severity.Success);
        }
        else
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
        }
        StateHasChanged();
    }

    // Part-of editor (storylines, GM). The current parent is read straight from the
    // loaded relationships: the PartOf edge where this artifact is the child.
    private ArtifactListItem? _parentTarget;
    private bool _parentBusy;
    private string? _parentError;

    private ConnectedArtifact? CurrentParent =>
        _detail?.Relationships
            .Where(r => r.Type == "PartOf" && r.ArtifactAId == _detail.Id)
            .Select(r => _detail.ConnectedArtifacts.FirstOrDefault(c => c.Id == r.ArtifactBId))
            .FirstOrDefault(c => c is not null);

    private async Task<IEnumerable<ArtifactListItem>> SearchParentTargetsAsync(string value, CancellationToken ct)
    {
        if (Worlds.Current is null)
        {
            return [];
        }

        var result = await Api.GetArtifactsAsync(Worlds.Current.Id, "Storyline", ct: ct);
        if (!result.IsSuccess)
        {
            return [];
        }

        return result.Value!
            .Where(a => a.Id != ArtifactId)
            .Where(a => string.IsNullOrWhiteSpace(value) || a.Name.Contains(value, StringComparison.OrdinalIgnoreCase))
            .OrderBy(a => a.Name)
            .Take(15);
    }

    private async Task SetParentAsync()
    {
        if (Worlds.Current is null || _detail is null || _parentTarget is null)
        {
            return;
        }

        _parentBusy = true;
        _parentError = null;

        var result = await Api.SetStorylineParentAsync(Worlds.Current.Id, _detail.Id, _parentTarget.Id);

        _parentBusy = false;
        if (result.IsSuccess)
        {
            Snackbar.Add($"Now part of \"{_parentTarget.Name}\".", Severity.Success);
            _parentTarget = null;
            await LoadAsync();
        }
        else
        {
            _parentError = result.Error!.Message;
            StateHasChanged();
        }
    }

    private async Task ClearParentAsync()
    {
        if (Worlds.Current is null || _detail is null)
        {
            return;
        }

        _parentBusy = true;
        _parentError = null;

        var result = await Api.SetStorylineParentAsync(Worlds.Current.Id, _detail.Id, null);

        _parentBusy = false;
        if (result.IsSuccess)
        {
            Snackbar.Add("Detached from its parent.", Severity.Info);
            await LoadAsync();
        }
        else
        {
            _parentError = result.Error!.Message;
            StateHasChanged();
        }
    }

    private async Task RenameAsync()
    {
        if (Worlds.Current is null || _detail is null)
        {
            return;
        }

        var parameters = new DialogParameters<RenameArtifactDialog>
        {
            { d => d.WorldId, Worlds.Current.Id },
            { d => d.ArtifactId, _detail.Id },
            { d => d.CurrentName, _detail.Name },
        };

        var dialog = await DialogService.ShowAsync<RenameArtifactDialog>("Rename artifact", parameters);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is ArtifactListItem renamed)
        {
            _detail = _detail with { Name = renamed.Name, UpdatedAt = renamed.UpdatedAt };
            Snackbar.Add("Artifact renamed.", Severity.Success);
        }
    }

    // Quick-add: the note becomes an ordinary source; prefixing the artifact's name
    // pulls it into extraction context via name matching.
    private string _quickAddText = string.Empty;
    private string _quickAddVisibility = "PartyVisible";
    private bool _quickAddBusy;
    private string? _quickAddError;

    private async Task QuickAddAsync()
    {
        if (Worlds.Current is null || _detail is null || string.IsNullOrWhiteSpace(_quickAddText))
        {
            return;
        }

        _quickAddBusy = true;
        _quickAddError = null;

        var isGm = Worlds.Current.MyRole == "GM";
        var request = new CreateSourceRequest(
            Title: $"Note on {_detail.Name} — {DateTime.Now:yyyy-MM-dd}",
            Type: isGm ? "GMNote" : "SessionNote",
            Visibility: _quickAddVisibility,
            Body: $"Regarding {_detail.Name}: {_quickAddText.Trim()}",
            Uri: null,
            OccurredAt: null);

        var created = await Api.CreateSourceAsync(Worlds.Current.Id, request);
        if (!created.IsSuccess)
        {
            _quickAddBusy = false;
            _quickAddError = created.Error!.Message;
            return;
        }

        var ready = await Api.MarkSourceReadyAsync(Worlds.Current.Id, created.Value!.Id);
        _quickAddBusy = false;

        if (!ready.IsSuccess)
        {
            _quickAddError = $"Saved as draft, but could not queue it: {ready.Error!.Message}";
            return;
        }

        _quickAddText = string.Empty;
        Snackbar.Add("Noted — proposals will appear in the review queue shortly.", Severity.Success);
        StateHasChanged();
    }

    protected override void OnInitialized() => Worlds.Changed += OnWorldChanged;

    protected override async Task OnParametersSetAsync()
    {
        if (ArtifactId != _loadedId)
        {
            await Worlds.EnsureLoadedAsync();
            await LoadAsync();
        }
    }

    private void OnWorldChanged() => InvokeAsync(LoadAsync);

    private async Task LoadAsync()
    {
        if (Worlds.Current is null)
        {
            _detail = null;
            StateHasChanged();
            return;
        }

        _loading = true;
        _notFound = false;
        _error = null;
        _loadedId = ArtifactId;
        StateHasChanged();

        var result = await Api.GetArtifactAsync(Worlds.Current.Id, ArtifactId);

        _loading = false;
        if (result.IsSuccess)
        {
            _detail = result.Value!;
        }
        else if (result.Error!.Code == "not_found")
        {
            _notFound = true;
            _detail = null;
        }
        else
        {
            _error = result.Error!.Message;
            _detail = null;
        }
        StateHasChanged();

        await LoadConnectionsGraphAsync();
    }

    // Whole-world graph for the Connections neighborhood; the BFS trim to FocusId/depth
    // happens in JS. Loaded per world and kept across in-world navigation.
    private ArtifactGraphDto? _graph;
    private Guid _graphWorldId;
    private int _graphDepth = 1;

    private async Task LoadConnectionsGraphAsync()
    {
        if (Worlds.Current is null || _detail is null || _detail.Relationships.Count == 0)
        {
            return;
        }

        if (_graph is not null && _graphWorldId == Worlds.Current.Id)
        {
            return;
        }

        var result = await Api.GetArtifactGraphAsync(Worlds.Current.Id);
        if (result.IsSuccess)
        {
            _graph = result.Value!;
            _graphWorldId = Worlds.Current.Id;
            StateHasChanged();
        }
    }

    private void OnConnectionSelected(GraphNode node)
    {
        if (node.Id != _detail?.Id)
        {
            Nav.NavigateTo($"/artifacts/{node.Id}");
        }
    }

    private ConnectedArtifact? OtherArtifact(ArtifactRelationshipDto r)
    {
        var otherId = r.ArtifactAId == ArtifactId ? r.ArtifactBId : r.ArtifactAId;
        return _detail?.ConnectedArtifacts.FirstOrDefault(c => c.Id == otherId);
    }

    private static Color StatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Dormant" => Color.Warning,
        "Resolved" => Color.Info,
        _ => Color.Default,
    };

    // Convention over schema: unresolved tensions live as facts with the exact predicate
    // "open question" (extraction emits them; answering one flips its truth state to False).
    private const string OpenQuestionPredicate = "open question";

    private IReadOnlyList<ArtifactFactDto> OpenQuestions =>
        _detail is null
            ? []
            : _detail.Facts
                .Where(f => string.Equals(f.Predicate, OpenQuestionPredicate, StringComparison.OrdinalIgnoreCase)
                            && f.TruthState != "False")
                .ToList();

    private IReadOnlyList<ArtifactFactDto> RegularFacts =>
        _detail is null
            ? []
            : _detail.Facts
                .Where(f => !string.Equals(f.Predicate, OpenQuestionPredicate, StringComparison.OrdinalIgnoreCase))
                .ToList();

    // Open continuity findings pointing at this artifact, from the assessment the circuit
    // already holds — no extra fetch. GM-only by data: non-GMs have no Continuity loaded.
    private IReadOnlyList<ContinuityFinding> ArtifactFindings =>
        Worlds.Continuity is { HasData: true } c
            ? c.Findings.Where(f => f.Status == "Open" && f.ArtifactId == ArtifactId).ToList()
            : [];

    private async Task DismissFindingAsync(ContinuityFinding finding)
    {
        if (Worlds.Current is null)
        {
            return;
        }

        var result = await Api.DismissFindingAsync(Worlds.Current.Id, finding.Id);
        if (result.IsSuccess)
        {
            // Refetch so the effective score is recomputed server-side; the sidebar ring
            // and this card both follow WorldState.
            await Worlds.LoadContinuityAsync();
            Snackbar.Add("Finding dismissed — its penalty points are back.", Severity.Info);
        }
        else
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
        }
    }

    private static Color FindingSeverityColor(string severity) => severity switch
    {
        "High" => Color.Error,
        "Medium" => Color.Warning,
        _ => Color.Default,
    };

    private static string Humanize(string pascal) =>
        string.Concat(pascal.Select((c, i) => i > 0 && char.IsUpper(c) ? " " + c : c.ToString()));

    private static Color TruthColor(string truth) => truth switch
    {
        "Confirmed" => Color.Success,
        "Likely" => Color.Info,
        "Rumor" => Color.Warning,
        "Disputed" or "False" => Color.Error,
        "Hidden" => Color.Secondary,
        _ => Color.Default,
    };

    public void Dispose() => Worlds.Changed -= OnWorldChanged;
}
