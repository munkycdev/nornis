@page "/graph"
@page "/graph/{FocusId:guid}"
@inject NavigationManager Nav

@* The standalone graph page moved into the Artifacts browse page (graph view) and the
   artifact detail Connections section. This stub keeps old bookmarks working. *@

@code {
    [Parameter] public Guid? FocusId { get; set; }

    protected override void OnInitialized() =>
        Nav.NavigateTo(FocusId is { } id ? $"/artifacts/{id}" : "/artifacts", replace: true);
}
