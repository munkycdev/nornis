@page "/capture"
@inject WorldState Worlds
@inject NornisApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Capture — Nornis</PageTitle>

<MudText Typo="Typo.h4" Class="nornis-serif">Tell Nornis what happened</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Add a source. Nornis reads it and proposes updates to your world record.
</MudText>

@if (Worlds.Current is null)
{
    <NoWorld />
}
else
{
    <div class="nornis-dashboard">
        <div class="nornis-dashboard-main">
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
                <MudTextField @bind-Value="_title"
                              Label="Title"
                              Required="true"
                              Immediate="true"
                              MaxLength="200"
                              Variant="Variant.Outlined"
                              Class="mb-3" />

                <div class="d-flex gap-3 mb-3">
                    <MudSelect @bind-Value="_type" Label="Type" Variant="Variant.Outlined" Class="flex-grow-1">
                        @foreach (var type in _sourceTypes)
                        {
                            <MudSelectItem Value="@type">@Humanize(type)</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect @bind-Value="_visibility" Label="Visibility" Variant="Variant.Outlined" Class="flex-grow-1">
                        @foreach (var vis in _visibilities)
                        {
                            <MudSelectItem Value="@vis">@vis</MudSelectItem>
                        }
                    </MudSelect>
                </div>

                <div class="mb-3">
                    <NotesEditor @ref="_editor"
                                 Placeholder="Paste session notes, a journal entry, a transcript… Type # for a heading, - for a list, **bold**." />
                </div>

                <MudTextField @bind-Value="_uri"
                              Label="Link (optional)"
                              Placeholder="https://…"
                              Variant="Variant.Outlined"
                              Class="mb-3" />

                <MudDatePicker @bind-Date="_occurredAt"
                               Label="When it happened (optional)"
                               Variant="Variant.Outlined"
                               Class="mb-3" />

                @if (_campaigns.Count > 0)
                {
                    <MudSelect T="Guid?" @bind-Value="_campaignId" Label="Campaign (optional)"
                               Variant="Variant.Outlined" Class="mb-3"
                               HelperText="Which campaign these events happened in. Leave empty for world lore or prep.">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">No campaign</MudSelectItem>
                        @foreach (var c in _campaigns)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)c.Id)">@c.Name</MudSelectItem>
                        }
                    </MudSelect>
                }

                @if (_error is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_error</MudAlert>
                }

                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               OnClick="() => SaveAsync(process: false)"
                               Disabled="_busy">
                        Save draft
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.AutoAwesome"
                               OnClick="() => SaveAsync(process: true)"
                               Disabled="_busy">
                        Save &amp; process
                    </MudButton>
                </div>
            </MudPaper>
        </div>

        <div class="nornis-rail nornis-capture-rail">
            <LoremasterPanel />
        </div>
    </div>
}

@code {
    private readonly string[] _sourceTypes =
    [
        "SessionNote", "JournalEntry", "Transcript", "GMNote", "WebLink",
        "Image", "HandwrittenNotes", "Upload", "ImportedNote",
    ];

    private readonly string[] _visibilities = ["PartyVisible", "GMOnly", "Private"];

    // Set from the dashboard capture tiles, e.g. /capture?type=WebLink.
    [Parameter, SupplyParameterFromQuery]
    public string? Type { get; set; }

    private string _title = string.Empty;
    private string _type = "SessionNote";
    private string _visibility = "PartyVisible";
    private NotesEditor? _editor;
    private string? _uri;
    // Defaults to today — most captures describe the session just played.
    private DateTime? _occurredAt = DateTime.Today;
    private Guid? _campaignId;
    private IReadOnlyList<CampaignDto> _campaigns = [];
    private bool _busy;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(Type) && _sourceTypes.Contains(Type))
        {
            _type = Type;
        }
        await Worlds.EnsureLoadedAsync();

        if (Worlds.Current is not null)
        {
            var campaigns = await Api.GetCampaignsAsync(Worlds.Current.Id);
            if (campaigns.IsSuccess)
            {
                _campaigns = campaigns.Value!;
                // Preselect when exactly one campaign is active — the common case.
                var active = _campaigns.Where(c => c.Status == "Active").ToList();
                if (active.Count == 1)
                {
                    _campaignId = active[0].Id;
                }
            }
        }
    }

    private async Task SaveAsync(bool process)
    {
        if (Worlds.Current is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_title))
        {
            _error = "Title is required.";
            return;
        }

        _busy = true;
        _error = null;

        var body = _editor is null ? null : await _editor.GetMarkdownAsync();

        var request = new CreateSourceRequest(
            _title.Trim(),
            _type,
            _visibility,
            body,
            string.IsNullOrWhiteSpace(_uri) ? null : _uri,
            _occurredAt.HasValue ? new DateTimeOffset(_occurredAt.Value, TimeSpan.Zero) : null,
            _campaignId);

        var created = await Api.CreateSourceAsync(Worlds.Current.Id, request);

        if (!created.IsSuccess)
        {
            _busy = false;
            _error = created.Error!.Message;
            return;
        }

        if (process)
        {
            var ready = await Api.MarkSourceReadyAsync(Worlds.Current.Id, created.Value!.Id);
            if (!ready.IsSuccess)
            {
                _busy = false;
                _error = $"Source saved, but could not queue it for processing: {ready.Error!.Message}";
                return;
            }
        }

        _busy = false;
        Snackbar.Add(process ? "Source saved and queued for processing." : "Draft saved.", Severity.Success);
        Nav.NavigateTo("/sources");
    }

    private static string Humanize(string pascal) =>
        string.Concat(pascal.Select((c, i) => i > 0 && char.IsUpper(c) ? " " + c : c.ToString()));
}
