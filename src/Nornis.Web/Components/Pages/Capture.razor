@page "/capture"
@inject WorldState Worlds
@inject NornisApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Capture — Nornis</PageTitle>

<MudText Typo="Typo.h4" Class="nornis-serif">Tell Nornis what happened</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Add a source. Nornis reads it and proposes updates to your world record.
</MudText>

@if (Worlds.Current is null)
{
    <NoWorld />
}
else
{
    <div class="nornis-dashboard">
        <div class="nornis-dashboard-main">
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
                <MudTextField @bind-Value="_title"
                              Label="Title"
                              Required="true"
                              Immediate="true"
                              MaxLength="200"
                              Variant="Variant.Outlined"
                              Class="mb-3" />

                <div class="d-flex gap-3 mb-3">
                    <MudSelect @bind-Value="_type" Label="Type" Variant="Variant.Outlined" Class="flex-grow-1">
                        @foreach (var (value, label) in SourceTypeDisplay.CaptureOptions)
                        {
                            <MudSelectItem Value="@value">@label</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect @bind-Value="_visibility" Label="Visibility" Variant="Variant.Outlined" Class="flex-grow-1">
                        @foreach (var vis in _visibilities)
                        {
                            <MudSelectItem Value="@vis">@vis</MudSelectItem>
                        }
                    </MudSelect>
                </div>

                @if (_type == "HandwrittenNotes")
                {
                    @* Page images go straight to blob via the SAS handshake; the worker
                       vision-transcribes them into the body, then extraction runs. *@
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Class="mb-3"
                               StartIcon="@Icons.Material.Filled.Draw" Href="/capture/ink">
                        Open ink canvas
                    </MudButton>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Write directly in Nornis with the canvas above — or add photos / page
                        exports of notes written elsewhere, in reading order. Either way, Nornis
                        transcribes the handwriting and pulls artifacts from the transcription.
                    </MudText>
                    <InputFile id="@_pagesInputId" OnChange="OnPagesSelected" multiple
                               class="nornis-upload-input mb-2" accept=".png,.jpg,.jpeg,.webp" />
                    @if (_pageFiles.Count > 0)
                    {
                        <div class="mb-3">
                            @for (var i = 0; i < _pageFiles.Count; i++)
                            {
                                @* Local copies: MudText's child content renders after the
                                   loop finishes, so referencing i directly is off-by-N. *@
                                var pageNumber = i + 1;
                                var page = _pageFiles[i];
                                <MudText Typo="Typo.body2">@($"Page {pageNumber}: {page.Name} ({FormatSize(page.Size)})")</MudText>
                            }
                        </div>
                    }
                    @if (_busy && _pageFiles.Count > 0)
                    {
                        <MudProgressLinear Value="@_uploadProgress" Color="Color.Primary" Class="mb-2" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                            Uploading page @(_uploadingIndex + 1) of @_pageFiles.Count…
                        </MudText>
                    }
                }
                else
                {
                    <div class="mb-3">
                        <NotesEditor @ref="_editor"
                                     Placeholder="Paste session notes, a journal entry, a transcript… Type # for a heading, - for a list, **bold**." />
                    </div>
                }

                <MudTextField @bind-Value="_uri"
                              Label="Link (optional)"
                              Placeholder="https://…"
                              Variant="Variant.Outlined"
                              Class="mb-3" />

                <MudDatePicker @bind-Date="_occurredAt"
                               Label="When it happened (optional)"
                               Variant="Variant.Outlined"
                               Class="mb-3" />

                @if (_campaigns.Count > 0)
                {
                    <MudSelect T="Guid?" @bind-Value="_campaignId" Label="Campaign (optional)"
                               Variant="Variant.Outlined" Class="mb-3"
                               HelperText="Which campaign these events happened in. Leave empty for world lore or prep.">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">No campaign</MudSelectItem>
                        @foreach (var c in _campaigns)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)c.Id)">@c.Name</MudSelectItem>
                        }
                    </MudSelect>
                }

                <MudCheckBox T="bool" @bind-Value="_extractionEnabled" Color="Color.Secondary" Dense="true" Class="mb-1"
                             Label="Extract knowledge from this source" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
                    @(_extractionEnabled
                        ? "Nornis will read it and propose artifacts, facts, and relationships for review."
                        : "Stored in the record as-is — no proposals, no changes to canon.")
                </MudText>

                @if (_error is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_error</MudAlert>
                }

                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               OnClick="() => SaveAsync(process: false)"
                               Disabled="_busy">
                        Save draft
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Secondary"
                               StartIcon="@(_extractionEnabled ? Icons.Material.Filled.AutoAwesome : Icons.Material.Filled.Inventory2)"
                               OnClick="() => SaveAsync(process: true)"
                               Disabled="_busy">
                        @(_extractionEnabled ? "Save & process" : "Save to record")
                    </MudButton>
                </div>
            </MudPaper>
        </div>

        <div class="nornis-rail nornis-capture-rail">
            <LoremasterPanel />
        </div>
    </div>
}

@code {

    private readonly string[] _visibilities = ["PartyVisible", "GMOnly", "Private"];

    // Set from the dashboard capture tiles, e.g. /capture?type=WebLink.
    [Parameter, SupplyParameterFromQuery]
    public string? Type { get; set; }

    private string _title = string.Empty;
    private string _type = "SessionNote";
    private string _visibility = "PartyVisible";
    private NotesEditor? _editor;
    private string? _uri;
    // Defaults to today — most captures describe the session just played.
    private DateTime? _occurredAt = DateTime.Today;
    private Guid? _campaignId;
    private IReadOnlyList<CampaignDto> _campaigns = [];
    private bool _extractionEnabled = true;
    private bool _busy;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(Type) && SourceTypeDisplay.IsCaptureOption(Type))
        {
            _type = Type;
        }
        await Worlds.EnsureLoadedAsync();

        if (Worlds.Current is not null)
        {
            var campaigns = await Api.GetCampaignsAsync(Worlds.Current.Id);
            if (campaigns.IsSuccess)
            {
                _campaigns = campaigns.Value!;
                // Preselect when exactly one campaign is active — the common case.
                var active = _campaigns.Where(c => c.Status == "Active").ToList();
                if (active.Count == 1)
                {
                    _campaignId = active[0].Id;
                }
            }
        }
    }

    // --------------------------------------------------- Handwritten page uploads --

    private sealed record PendingPage(string Name, long Size, string Type);

    private readonly string _pagesInputId = $"nornis-pages-{Guid.NewGuid():N}";
    private List<PendingPage> _pageFiles = [];
    private int _uploadingIndex;
    private int _uploadProgress;
    private DotNetObjectReference<Capture>? _selfRef;

    private void OnPagesSelected(InputFileChangeEventArgs e)
    {
        _pageFiles = e.GetMultipleFiles(50)
            .Select(f => new PendingPage(f.Name, f.Size, f.ContentType))
            .ToList();
    }

    [JSInvokable]
    public void OnUploadProgress(int percent)
    {
        _uploadProgress = percent;
        InvokeAsync(StateHasChanged);
    }

    /// <summary>Uploads each selected page via the SAS handshake. Returns null on success,
    /// or the error message for the page that failed.</summary>
    private async Task<string?> UploadPagesAsync(Guid worldId, Guid sourceId)
    {
        _selfRef ??= DotNetObjectReference.Create(this);

        for (var i = 0; i < _pageFiles.Count; i++)
        {
            _uploadingIndex = i;
            _uploadProgress = 0;
            StateHasChanged();

            var page = _pageFiles[i];
            var ticket = await Api.RequestSourceAttachmentUploadAsync(worldId, sourceId,
                new RequestSourceAttachmentUploadRequest(page.Name, page.Type, page.Size, "PageImage", Ord: i));
            if (!ticket.IsSuccess)
            {
                return ticket.Error!.Message;
            }

            var sent = await JS.InvokeAsync<bool>("nornisUpload.sendAt",
                _pagesInputId, i, ticket.Value!.UploadUrl, ticket.Value.Attachment.ContentType, _selfRef);
            if (!sent)
            {
                return $"Page {i + 1} never reached storage. Try again.";
            }

            var confirmed = await Api.ConfirmSourceAttachmentUploadAsync(worldId, sourceId, ticket.Value.Attachment.Id);
            if (!confirmed.IsSuccess)
            {
                return confirmed.Error!.Message;
            }
        }

        return null;
    }

    public void Dispose() => _selfRef?.Dispose();

    private async Task SaveAsync(bool process)
    {
        if (Worlds.Current is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_title))
        {
            _error = "Title is required.";
            return;
        }

        var isHandwritten = _type == "HandwrittenNotes";
        if (isHandwritten && _pageFiles.Count == 0)
        {
            _error = "Add at least one page image of your handwritten notes.";
            return;
        }

        _busy = true;
        _error = null;

        var body = isHandwritten || _editor is null ? null : await _editor.GetMarkdownAsync();

        var request = new CreateSourceRequest(
            _title.Trim(),
            _type,
            _visibility,
            body,
            string.IsNullOrWhiteSpace(_uri) ? null : _uri,
            // SpecifyKind: picker dates are Kind.Local, and DateTimeOffset's ctor throws
            // when the kind's implied offset disagrees with the one supplied.
            _occurredAt.HasValue ? new DateTimeOffset(DateTime.SpecifyKind(_occurredAt.Value, DateTimeKind.Utc), TimeSpan.Zero) : null,
            _campaignId,
            _extractionEnabled);

        var created = await Api.CreateSourceAsync(Worlds.Current.Id, request);

        if (!created.IsSuccess)
        {
            _busy = false;
            _error = created.Error!.Message;
            return;
        }

        if (isHandwritten)
        {
            var uploadError = await UploadPagesAsync(Worlds.Current.Id, created.Value!.Id);
            if (uploadError is not null)
            {
                _busy = false;
                _error = $"Source saved as a draft, but a page upload failed: {uploadError}";
                return;
            }
        }

        if (process)
        {
            var ready = await Api.MarkSourceReadyAsync(Worlds.Current.Id, created.Value!.Id);
            if (!ready.IsSuccess)
            {
                _busy = false;
                _error = $"Source saved, but could not queue it for processing: {ready.Error!.Message}";
                return;
            }
        }

        _busy = false;
        Snackbar.Add(
            !process ? "Draft saved."
            : _extractionEnabled ? "Source saved and queued for processing."
            : "Source stored in the record — no extraction.", Severity.Success);
        Nav.NavigateTo("/sources");
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        >= 1024 * 1024 => $"{bytes / (1024.0 * 1024):0.#} MB",
        >= 1024 => $"{bytes / 1024.0:0.#} KB",
        _ => $"{bytes} B",
    };
}
