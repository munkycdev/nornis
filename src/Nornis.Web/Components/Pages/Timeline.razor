@page "/timeline"
@page "/storylines"
@using Microsoft.AspNetCore.WebUtilities
@implements IDisposable
@inject WorldState Worlds
@inject NornisApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Timeline — Nornis</PageTitle>

<div class="d-flex align-center justify-space-between mb-4">
    <div>
        <MudText Typo="Typo.h4" Class="nornis-serif">Timeline</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">The stories in motion.</MudText>
    </div>
    @if (Worlds.Current?.MyRole == "GM")
    {
        <MudTooltip Text="AI reads each Active storyline against the record and proposes closing the finished ones — you review every proposal.">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.Checklist"
                       OnClick="RunRetrospectiveAsync" Disabled="_retroBusy">
                @(_retroBusy ? "Assessing…" : "Run retrospective")
            </MudButton>
        </MudTooltip>
    }
</div>

@if (Worlds.Current is null)
{
    <NoWorld />
}
else
{
    <div class="d-flex gap-3 align-center mb-4 flex-wrap">
        <div class="nornis-filter-row flex-grow-1">
            <MudChip T="string"
                     Variant="@(_selectedStatuses.Count == 0 ? Variant.Filled : Variant.Outlined)"
                     Color="@(_selectedStatuses.Count == 0 ? Color.Secondary : Color.Default)"
                     OnClick="ClearStatuses">
                All
            </MudChip>
            @foreach (var status in _statuses)
            {
                <MudChip T="string"
                         Variant="@(_selectedStatuses.Contains(status) ? Variant.Filled : Variant.Outlined)"
                         Color="@(_selectedStatuses.Contains(status) ? Color.Secondary : Color.Default)"
                         OnClick="() => ToggleStatus(status)">
                    @status
                </MudChip>
            }
        </div>
        <MudToggleGroup T="string" Value="_view" ValueChanged="OnViewChangedAsync" SelectionMode="SelectionMode.SingleSelection"
                        Color="Color.Secondary" Size="Size.Small">
            <MudToggleItem Value="@("cards")"><MudIcon Icon="@Icons.Material.Outlined.GridView" Size="Size.Small" /></MudToggleItem>
            <MudToggleItem Value="@("timeline")"><MudIcon Icon="@Icons.Material.Outlined.Route" Size="Size.Small" /></MudToggleItem>
            <MudToggleItem Value="@("journey")"><MudIcon Icon="@Icons.Material.Outlined.Map" Size="Size.Small" /></MudToggleItem>
        </MudToggleGroup>
    </div>

    @if (_view == "journey")
    {
        @if (_journeyNoMap)
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad nornis-comingsoon">
                <MudIcon Icon="@Icons.Material.Outlined.Map" Size="Size.Large" Class="nornis-comingsoon-icon" />
                <MudText Typo="Typo.h5" Class="nornis-serif">No map to chart yet</MudText>
                <MudText Typo="Typo.body1" Class="nornis-comingsoon-text mt-2">
                    Upload a map source and pin a few locations, and Nornis will chart how the party
                    has moved through the world.
                </MudText>
            </MudPaper>
        }
        else if (_journeyError is not null)
        {
            <MudAlert Severity="Severity.Error">@_journeyError</MudAlert>
        }
        else if (_journey is null)
        {
            <LoadingRows Rows="3" />
        }
        else
        {
            <JourneyMap Data="_journey" />
        }
    }
    else if (_view == "timeline")
    {
        @if (_timelineError is not null)
        {
            <MudAlert Severity="Severity.Error">@_timelineError</MudAlert>
        }
        else if (_timeline is null)
        {
            <LoadingRows Rows="3" />
        }
        else
        {
            <StorylineTimelineChart Data="_timeline" StatusFilter="_selectedStatuses"
                                    CanEdit="@(Worlds.Current.MyRole == "GM")"
                                    ReparentRequested="OnReparentRequestedAsync"
                                    UnnestRequested="OnUnnestRequestedAsync" />
        }
    }
    else if (_loading)
    {
        <LoadingRows Rows="3" />
    }
    else if (_error is not null)
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else if (!FilteredStorylines.Any())
    {
        <MudPaper Elevation="0" Class="nornis-card nornis-card-pad nornis-comingsoon">
            <MudIcon Icon="@Icons.Material.Outlined.Hub" Size="Size.Large" Class="nornis-comingsoon-icon" />
            <MudText Typo="Typo.h5" Class="nornis-serif">No storylines@(_selectedStatuses.Count == 0 ? "" : $" that are {string.Join(" or ", _statuses.Where(_selectedStatuses.Contains))}") yet</MudText>
            <MudText Typo="Typo.body1" Class="nornis-comingsoon-text mt-2">
                As your sources advance mysteries, quests, and rivalries, Nornis tracks them here.
            </MudText>
        </MudPaper>
    }
    else
    {
        <div class="nornis-artifact-grid">
            @foreach (var s in FilteredStorylines)
            {
                <a href="@($"/artifacts/{s.Id}")" class="nornis-card nornis-artifact-card">
                    <div class="nornis-artifact-card-head">
                        <div class="nornis-list-thumb"><MudIcon Icon="@Icons.Material.Outlined.Hub" Size="Size.Small" /></div>
                        <div class="nornis-artifact-card-title">
                            <ArtifactTip Name="@s.Name" Summary="@s.Summary" />
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(s.Summary))
                    {
                        <p class="nornis-artifact-card-summary">@s.Summary</p>
                    }
                    <div class="nornis-artifact-card-foot">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@StatusColor(s.Status)">@s.Status</MudChip>
                        @if (s.Visibility == "GMOnly")
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">GM only</MudChip>
                        }
                        <span class="nornis-list-meta ml-auto">advanced @Ago(s.UpdatedAt)</span>
                    </div>
                </a>
            }
        </div>
    }
}

@code {
    private readonly string[] _statuses = ["Active", "Dormant", "Resolved", "Archived"];
    private static readonly string[] DefaultStatuses = ["Active", "Dormant"];

    private bool _loading;
    private string? _error;
    private readonly HashSet<string> _selectedStatuses = [.. DefaultStatuses];
    private string _view = "timeline";
    private bool _retroBusy;
    private IReadOnlyList<ArtifactListItem> _storylines = [];

    // Timeline data, fetched lazily on first switch and cached per world. Status chips
    // filter it client-side, so only a world change invalidates it.
    private StorylineTimelineDto? _timeline;
    private Guid _timelineWorldId;
    private string? _timelineError;

    // Journey data (map + scrubber), lazily loaded and cached per world. "No map" is a valid
    // loaded state (the world has no pinned map yet), distinct from a genuine error.
    private JourneyDto? _journey;
    private Guid _journeyWorldId;
    private string? _journeyError;
    private bool _journeyNoMap;

    private IEnumerable<ArtifactListItem> FilteredStorylines =>
        _selectedStatuses.Count == 0 ? _storylines : _storylines.Where(s => _selectedStatuses.Contains(s.Status));

    private async Task OnViewChangedAsync(string view)
    {
        _view = view;
        SyncUrl();
        if (view == "timeline" && (_timeline is null || _timelineWorldId != Worlds.Current?.Id))
        {
            await LoadTimelineAsync();
        }
        else if (view == "journey" && _journeyWorldId != Worlds.Current?.Id)
        {
            await LoadJourneyAsync();
        }
    }

    private async Task OnReparentRequestedAsync((TimelineLaneDto Child, TimelineLaneDto Parent) drop)
    {
        if (Worlds.Current is null)
        {
            return;
        }

        var confirmed = await DialogService.ShowMessageBox(
            "Nest storyline?",
            $"Make \"{drop.Child.Name}\" part of \"{drop.Parent.Name}\"?",
            yesText: "Nest", cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        var result = await Api.SetStorylineParentAsync(Worlds.Current.Id, drop.Child.StorylineId, drop.Parent.StorylineId);
        if (result.IsSuccess)
        {
            Snackbar.Add($"\"{drop.Child.Name}\" is now part of \"{drop.Parent.Name}\".", Severity.Success);
            ApplyParentLocally(drop.Child.StorylineId, drop.Parent.StorylineId);
        }
        else
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
        }
    }

    private async Task OnUnnestRequestedAsync(TimelineLaneDto child)
    {
        if (Worlds.Current is null)
        {
            return;
        }

        var confirmed = await DialogService.ShowMessageBox(
            "Move to top level?",
            $"Detach \"{child.Name}\" from its parent storyline? It becomes a top-level arc.",
            yesText: "Detach", cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        var result = await Api.SetStorylineParentAsync(Worlds.Current.Id, child.StorylineId, null);
        if (result.IsSuccess)
        {
            Snackbar.Add($"\"{child.Name}\" is now a top-level storyline.", Severity.Success);
            ApplyParentLocally(child.StorylineId, null);
        }
        else
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
        }
    }

    // A successful nest/un-nest only moves ParentStorylineId; the chart derives rows,
    // connectors, and bands from its Data. Rewriting the lane in place re-renders the
    // chart without unmounting it — no loading skeleton, no lost scroll position.
    private void ApplyParentLocally(Guid childId, Guid? parentId)
    {
        if (_timeline is null)
        {
            return;
        }

        _timeline = _timeline with
        {
            Lanes = _timeline.Lanes
                .Select(l => l.StorylineId == childId ? l with { ParentStorylineId = parentId } : l)
                .ToList(),
        };
        StateHasChanged();
    }

    private async Task LoadTimelineAsync()
    {
        if (Worlds.Current is null)
        {
            return;
        }

        _timeline = null;
        _timelineError = null;
        StateHasChanged();

        var result = await Api.GetStorylineTimelineAsync(Worlds.Current.Id);
        if (result.IsSuccess)
        {
            _timeline = result.Value!;
            _timelineWorldId = Worlds.Current.Id;
        }
        else
        {
            _timelineError = result.Error!.Message;
        }
        StateHasChanged();
    }

    private async Task LoadJourneyAsync()
    {
        if (Worlds.Current is null)
        {
            return;
        }

        _journey = null;
        _journeyError = null;
        _journeyNoMap = false;
        StateHasChanged();

        var result = await Api.GetJourneyAsync(Worlds.Current.Id);
        if (result.IsSuccess)
        {
            _journey = result.Value!;
            _journeyWorldId = Worlds.Current.Id;
        }
        else if (result.Error!.Code == "no_map")
        {
            _journeyNoMap = true;
            _journeyWorldId = Worlds.Current.Id;
        }
        else
        {
            _journeyError = result.Error!.Message;
        }
        StateHasChanged();
    }

    private async Task RunRetrospectiveAsync()
    {
        if (Worlds.Current is null)
        {
            return;
        }

        _retroBusy = true;
        StateHasChanged();

        var result = await Api.RunStorylineRetrospectiveAsync(Worlds.Current.Id);
        _retroBusy = false;

        if (!result.IsSuccess)
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
        }
        else if (result.Value!.ProposedCount == 0)
        {
            Snackbar.Add($"Assessed {result.Value.AssessedCount} storylines — all look genuinely active.", Severity.Info);
        }
        else
        {
            Snackbar.Add($"Assessed {result.Value.AssessedCount} storylines; {result.Value.ProposedCount} closure proposals are in the review queue.", Severity.Success);
        }
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        RestoreFromQuery();
        Worlds.Changed += OnWorldChanged;
        await Worlds.EnsureLoadedAsync();
        await LoadAsync();
    }

    private void OnWorldChanged() => InvokeAsync(LoadAsync);

    private void ToggleStatus(string status)
    {
        if (!_selectedStatuses.Remove(status))
        {
            _selectedStatuses.Add(status);
        }
        SyncUrl();
    }

    private void ClearStatuses()
    {
        _selectedStatuses.Clear();
        SyncUrl();
    }

    // View and status filter round-trip through the query string so browser history
    // (back from an artifact, refresh, shared links) restores the same visualization.
    // The default filter (Active + Dormant) keeps the bare URL clean; "all" is explicit.
    private void RestoreFromQuery()
    {
        var query = QueryHelpers.ParseQuery(new Uri(Nav.Uri).Query);
        if (query.TryGetValue("view", out var view) && (view == "cards" || view == "timeline" || view == "journey"))
        {
            _view = view!;
        }
        if (query.TryGetValue("status", out var status))
        {
            _selectedStatuses.Clear();
            if (!string.Equals(status, "all", StringComparison.OrdinalIgnoreCase))
            {
                foreach (var s in status.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                {
                    var match = _statuses.FirstOrDefault(x => x.Equals(s, StringComparison.OrdinalIgnoreCase));
                    if (match is not null)
                    {
                        _selectedStatuses.Add(match);
                    }
                }
            }
        }
    }

    private void SyncUrl()
    {
        var status = _selectedStatuses.Count == 0
            ? "all"
            : _selectedStatuses.SetEquals(DefaultStatuses)
                ? null
                : string.Join(',', _statuses.Where(_selectedStatuses.Contains));
        var uri = Nav.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["view"] = _view == "timeline" ? null : _view,
            ["status"] = status,
        });
        if (uri != Nav.Uri)
        {
            Nav.NavigateTo(uri, replace: true);
        }
    }

    private async Task LoadAsync()
    {
        if (Worlds.Current is null)
        {
            _storylines = [];
            _error = null;
            StateHasChanged();
            return;
        }

        _loading = true;
        _error = null;
        StateHasChanged();

        var result = await Api.GetStorylinesAsync(Worlds.Current.Id);

        _loading = false;
        if (result.IsSuccess)
        {
            _storylines = result.Value!;
        }
        else
        {
            _error = result.Error!.Message;
            _storylines = [];
        }

        StateHasChanged();

        if (_view == "timeline" && _timelineWorldId != Worlds.Current.Id)
        {
            await LoadTimelineAsync();
        }
        else if (_view == "journey" && _journeyWorldId != Worlds.Current.Id)
        {
            await LoadJourneyAsync();
        }
    }

    private static Color StatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Dormant" => Color.Warning,
        "Resolved" => Color.Info,
        _ => Color.Default,
    };

    private static string Ago(DateTimeOffset t)
    {
        var d = DateTimeOffset.UtcNow - t.ToUniversalTime();
        if (d.TotalMinutes < 60) return $"{Math.Max(1, (int)d.TotalMinutes)}m ago";
        if (d.TotalHours < 24) return $"{(int)d.TotalHours}h ago";
        if (d.TotalDays < 2) return "Yesterday";
        return $"{(int)d.TotalDays}d ago";
    }

    public void Dispose() => Worlds.Changed -= OnWorldChanged;
}
