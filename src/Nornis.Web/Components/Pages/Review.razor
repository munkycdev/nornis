@page "/review"
@using System.Text.Json
@implements IDisposable
@inject WorldState Worlds
@inject NornisApiClient Api
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Review Queue — Nornis</PageTitle>

<div class="d-flex align-center justify-space-between mb-4">
    <div>
        <MudText Typo="Typo.h4" Class="nornis-serif">Review Queue</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Accept, edit, or reject proposed updates to your record.</MudText>
    </div>
    @if (_proposals.Count > 0)
    {
        <span class="nornis-count-badge">@_proposals.Count</span>
    }
</div>

@if (_hasMore)
{
    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
        Showing the first 200 proposals — more are waiting after these.
    </MudAlert>
}

@if (Worlds.Current is null)
{
    <NoWorld />
}
else if (_loading)
{
    <LoadingRows Rows="3" />
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_proposals.Count == 0)
{
    <MudPaper Elevation="0" Class="nornis-card nornis-card-pad nornis-comingsoon">
        <MudIcon Icon="@Icons.Material.Outlined.FactCheck" Size="Size.Large" Class="nornis-comingsoon-icon" />
        <MudText Typo="Typo.h5" Class="nornis-serif">Nothing to review</MudText>
        <MudText Typo="Typo.body1" Class="nornis-comingsoon-text mt-2">
            When Nornis processes a source, its proposed updates will appear here for you to accept.
        </MudText>
    </MudPaper>
}
else
{
    @if (PendingIds().Count > 0)
    {
        <div class="d-flex gap-2 mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.DoneAll"
                       OnClick="AcceptAllAsync" Disabled="@_batchActing">
                Accept all
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.ClearAll"
                       OnClick="RejectAllAsync" Disabled="@_batchActing">
                Reject all
            </MudButton>
        </div>
    }

    <div class="nornis-proposals">
        @foreach (var p in _proposals)
        {
            <MudPaper Elevation="0" Class="nornis-card nornis-card-pad">
                <div class="nornis-proposal-head">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@ChangeColor(p.ChangeType)">
                        @Humanize(p.ChangeType)
                    </MudChip>
                    @if (TargetLabel(p) is { } target)
                    {
                        <span class="nornis-proposal-target">@target</span>
                    }
                    @if (p.Confidence is not null)
                    {
                        <span class="nornis-list-meta">@($"{p.Confidence:P0}") confidence</span>
                    }
                    @if (p.Status != "Pending")
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">@p.Status</MudChip>
                    }
                    @if (!string.IsNullOrWhiteSpace(p.SourceTitle))
                    {
                        <span class="nornis-proposal-source" title="Source that produced this proposal">
                            <MudIcon Icon="@Icons.Material.Outlined.Description" Size="Size.Small" />
                            @p.SourceTitle
                        </span>
                    }
                </div>

                <div class="nornis-proposal-fields">
                    @foreach (var (key, value) in Fields(p.ProposedValueJson))
                    {
                        <div class="nornis-kv">
                            <span class="nornis-kv-key">@key</span>
                            <span class="nornis-kv-value">@value</span>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(p.Rationale))
                {
                    <div class="nornis-proposal-rationale">
                        <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" Size="Size.Small" Color="Color.Secondary" />
                        <span>@p.Rationale</span>
                    </div>
                }

                <div class="nornis-proposal-actions">
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Check"
                               OnClick="() => AcceptAsync(p)" Disabled="@_acting.Contains(p.Id)">
                        Accept
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="() => EditAsync(p)" Disabled="@_acting.Contains(p.Id)">
                        Edit
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Close"
                               OnClick="() => RejectAsync(p)" Disabled="@_acting.Contains(p.Id)">
                        Reject
                    </MudButton>
                </div>
            </MudPaper>
        }
    </div>
}

@code {
    private bool _loading;
    private bool _hasMore;
    private string? _error;
    private IReadOnlyList<ReviewProposal> _proposals = [];
    private readonly HashSet<Guid> _acting = [];
    private bool _batchActing;

    protected override async Task OnInitializedAsync()
    {
        Worlds.Changed += OnWorldChanged;
        await Worlds.EnsureLoadedAsync();
        await LoadAsync();
    }

    private void OnWorldChanged() => InvokeAsync(LoadAsync);

    private async Task LoadAsync()
    {
        if (Worlds.Current is null)
        {
            _proposals = [];
            _error = null;
            StateHasChanged();
            return;
        }

        _loading = true;
        _error = null;
        StateHasChanged();

        var result = await Api.GetReviewQueueAsync(Worlds.Current.Id);

        _loading = false;
        if (result.IsSuccess)
        {
            _proposals = result.Value!.Proposals;
            _hasMore = result.Value.HasMore;
        }
        else
        {
            _error = result.Error!.Message;
            _proposals = [];
        }
        StateHasChanged();
    }

    private async Task AcceptAsync(ReviewProposal p)
    {
        _acting.Add(p.Id);
        var result = await Api.AcceptProposalAsync(Worlds.Current!.Id, p.Id);
        _acting.Remove(p.Id);

        if (result.IsSuccess)
        {
            _proposals = _proposals.Where(x => x.Id != p.Id).ToList();
            Snackbar.Add("Proposal accepted.", Severity.Success);
        }
        else
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
        }
        StateHasChanged();
    }

    private async Task RejectAsync(ReviewProposal p)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Reject proposal?",
            "This discards the proposed change. It can't be undone.",
            yesText: "Reject", cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        _acting.Add(p.Id);
        var result = await Api.RejectProposalAsync(Worlds.Current!.Id, p.Id);
        _acting.Remove(p.Id);

        if (result.IsSuccess)
        {
            _proposals = _proposals.Where(x => x.Id != p.Id).ToList();
            Snackbar.Add("Proposal rejected.", Severity.Info);
        }
        else
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
        }
        StateHasChanged();
    }

    private List<Guid> PendingIds() =>
        _proposals.Where(p => p.Status == "Pending").Select(p => p.Id).ToList();

    /// <summary>
    /// Batch order matters: the server processes ids sequentially in request order, and facts or
    /// relationships may reference artifacts created in the same batch by name — those creates
    /// must be applied first or the references fail to resolve.
    /// </summary>
    private List<Guid> PendingIdsInDependencyOrder() =>
        _proposals
            .Where(p => p.Status == "Pending")
            .OrderBy(p => p.ChangeType switch
            {
                "CreateArtifact" => 0,
                "MergeArtifact" => 1,
                "UpdateArtifact" => 2,
                _ => 3,
            })
            .Select(p => p.Id)
            .ToList();

    private Task AcceptAllAsync() => RunBatchAsync(accept: true);

    private async Task RejectAllAsync()
    {
        var pendingCount = PendingIds().Count;
        var confirmed = await DialogService.ShowMessageBox(
            "Reject all proposals?",
            $"This discards all {pendingCount} pending proposed changes. It can't be undone.",
            yesText: "Reject all", cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        await RunBatchAsync(accept: false);
    }

    private async Task RunBatchAsync(bool accept)
    {
        var ids = accept ? PendingIdsInDependencyOrder() : PendingIds();
        if (ids.Count == 0 || Worlds.Current is null)
        {
            return;
        }

        _batchActing = true;
        foreach (var id in ids)
        {
            _acting.Add(id);
        }
        StateHasChanged();

        var worldId = Worlds.Current.Id;
        var succeeded = 0;
        var failed = 0;
        string? firstError = null;

        // The batch endpoints cap at 50 ids per call.
        foreach (var chunk in ids.Chunk(50))
        {
            var result = accept
                ? await Api.BatchAcceptProposalsAsync(worldId, chunk)
                : await Api.BatchRejectProposalsAsync(worldId, chunk);

            if (result.IsSuccess)
            {
                succeeded += result.Value!.Succeeded.Count;
                failed += result.Value!.Failed.Count;
            }
            else
            {
                failed += chunk.Length;
                firstError ??= result.Error!.Message;
            }
        }

        _batchActing = false;
        foreach (var id in ids)
        {
            _acting.Remove(id);
        }

        var verb = accept ? "accepted" : "rejected";
        if (failed == 0)
        {
            Snackbar.Add($"{succeeded} proposal{(succeeded == 1 ? "" : "s")} {verb}.",
                accept ? Severity.Success : Severity.Info);
        }
        else
        {
            var detail = firstError is null ? "" : $" {firstError}";
            Snackbar.Add($"{succeeded} {verb}, {failed} failed.{detail}", Severity.Warning);
        }

        await LoadAsync();
    }

    private async Task EditAsync(ReviewProposal p)
    {
        var parameters = new DialogParameters
        {
            { nameof(EditProposalDialog.WorldId), Worlds.Current!.Id },
            { nameof(EditProposalDialog.ProposalId), p.Id },
            { nameof(EditProposalDialog.ProposedValueJson), p.ProposedValueJson },
        };

        var dialog = await DialogService.ShowAsync<EditProposalDialog>("Edit proposal", parameters);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is ProposalActionResult updated)
        {
            _proposals = _proposals
                .Select(x => x.Id == p.Id
                    ? x with { ProposedValueJson = updated.ProposedValueJson ?? x.ProposedValueJson, Status = updated.Status }
                    : x)
                .ToList();
            Snackbar.Add("Proposal updated.", Severity.Success);
            StateHasChanged();
        }
    }

    private static IEnumerable<(string Key, string Value)> Fields(string json)
    {
        var list = new List<(string, string)>();
        try
        {
            using var doc = JsonDocument.Parse(json);
            if (doc.RootElement.ValueKind == JsonValueKind.Object)
            {
                foreach (var prop in doc.RootElement.EnumerateObject())
                {
                    var value = prop.Value.ValueKind switch
                    {
                        JsonValueKind.Null => "—",
                        JsonValueKind.String => prop.Value.GetString() ?? "",
                        _ => prop.Value.ToString(),
                    };
                    list.Add((Humanize(prop.Name), value));
                }
            }
        }
        catch (JsonException)
        {
            list.Add(("value", json));
        }
        return list;
    }

    /// <summary>
    /// What the proposal acts on, as a name rather than a GUID. Merges show both sides.
    /// </summary>
    private static string? TargetLabel(ReviewProposal p)
    {
        if (p.ChangeType == "MergeArtifact" && p.TargetName is not null && p.MergeSourceName is not null)
            return $"{p.MergeSourceName} → {p.TargetName}";
        return p.TargetName;
    }

    private static Color ChangeColor(string changeType) =>
        changeType.StartsWith("Create") ? Color.Success :
        changeType.StartsWith("Update") || changeType.StartsWith("Edit") ? Color.Info :
        changeType.StartsWith("Merge") ? Color.Warning :
        Color.Default;

    private static string Humanize(string pascal) =>
        string.Concat(pascal.Select((c, i) => i > 0 && char.IsUpper(c) ? " " + c : c.ToString()));

    public void Dispose() => Worlds.Changed -= OnWorldChanged;
}
